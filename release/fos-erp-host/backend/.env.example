DB_HOST=localhost
DB_PORT=3306
DB_NAME=fos_erp
DB_USER=root
DB_PASS=change-me

PORT=5000
NODE_ENV=production

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Must match the public URL users open in the browser (CORS)
FRONTEND_URL=http://localhost:5000

# Optional — served from ./public by default
# FRONTEND_DIST=./public

# Optional — auto-built from DB_* if omitted
# DATABASE_URL=mysql://root:change-me@localhost:3306/fos_erp
