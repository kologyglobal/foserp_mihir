  sourceDocumentType  String?                    @db.VarChar(32)
  sourceDocumentId    String?
  sourceLineReference String?                    @db.VarChar(64)
  sourceLineKey       String?                    @db.VarChar(150)
  sourceSnapshotJson  Json?
  salesOrderId        String?
  customerId          String?
  projectRef          String?                    @db.VarChar(100)
  productItemId       String
  requestedQuantity   Decimal                    @db.Decimal(18, 4)
  convertedQuantity   Decimal                    @default(0) @db.Decimal(18, 4)
  remainingQuantity   Decimal                    @db.Decimal(18, 4)
  cancelledQuantity   Decimal                    @default(0) @db.Decimal(18, 4)
  uomId               String
  requiredDate        DateTime?
  priority            String                     @default("MEDIUM") @db.VarChar(16)
  plantCode           String?                    @db.VarChar(32)
  status              ProductionDemandStatus     @default(OPEN)
  idempotencyKey      String?                    @db.VarChar(150)
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?

