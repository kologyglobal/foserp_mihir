  invoiceOpenItem    ReceivableOpenItem                 @relation("CreditNoteInvoiceDebitOpenItem", fields: [invoiceOpenItemId], references: [id])

  @@unique([tenantId, legalEntityId, creditNoteId, allocationSequence], map: "cust_cn_alloc_seq_key")
  @@unique([batchId, allocationSequence], map: "cust_cn_alloc_batch_seq_key")
  @@index([creditNoteId])
  @@index([invoiceId])
  @@index([creditNoteOpenItemId])
  @@index([invoiceOpenItemId])
  @@index([customerId])
  @@index([status])
  @@index([allocationDate])
  @@index([tenantId, legalEntityId])
  @@index([batchId])
  @@map("customer_credit_note_allocations")
