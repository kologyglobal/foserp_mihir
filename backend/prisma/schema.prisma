  heldQty                  Decimal?                   @db.Decimal(18, 4)
  scrapQty                 Decimal?                   @db.Decimal(18, 4)
  pendingQty               Decimal?                   @db.Decimal(18, 4)
  stockDisposition         QualityStockDisposition?
  qualityHoldWarehouseId   String?
  warehouseFromId          String?
  warehouseToId            String?
  certificateRequired      Boolean                    @default(false)
  certificateStatus        QualityCertificateStatus?
  supersededById           String?
  supersedesId             String?
