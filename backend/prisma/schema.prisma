// ─── Manufacturing Phase 6A1 — Demand consolidation Production Plan ───────────
// Distinct from Phase 6A netting workbench (ProductionPlan /production_plans).
// Answers: what demand exists, WO coverage, remaining unplanned, WO suggestions.
// Does NOT create Work Orders, explode BOM, net inventory, or schedule capacity.

enum DemandConsolidationPlanStatus {
  DRAFT
  CALCULATING
  CALCULATED
  REVIEWED
  CANCELLED
  FAILED
}

enum DemandConsolidationMode {
  NONE
  BY_ITEM_AND_DATE
  BY_ITEM_PROJECT_AND_DATE
  BY_ITEM_CUSTOMER_AND_DATE
}

enum DemandConsolidationDateBucket {
  EXACT_DATE
  DAILY
  WEEKLY
}

enum DemandConsolidationCalcRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SUPERSEDED
}

enum DemandConsolidationSuggestionType {
  CREATE_WORK_ORDER
  MANUAL_REVIEW
  NO_ACTION
}

enum DemandConsolidationSuggestionStatus {
  PROPOSED
  ACCEPTED_FOR_LATER_RELEASE
  REJECTED
  BLOCKED
  SUPERSEDED
}

enum DemandConsolidationReadinessStatus {
  READY
  READY_WITH_WARNINGS
  BLOCKED
  NOT_CONFIGURED
}

enum DemandConsolidationExceptionSeverity {
  INFO
  WARNING
  ERROR
  BLOCKER
}

enum DemandConsolidationExceptionStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  IGNORED
}

/// Phase 6A1 Production Plan header (API: /manufacturing/production-plans).
model DemandConsolidationPlan {
  id                        String                        @id @default(uuid())
  tenantId                  String
  planNumber                String                        @db.VarChar(64)
  name                      String                        @db.VarChar(200)
  description               String?                       @db.Text
  planningPeriodStart       DateTime                      @db.Date
  planningPeriodEnd         DateTime                      @db.Date
  demandCutoffDate          DateTime?                     @db.Date
  plantCode                 String?                       @db.VarChar(32)
  branchId                  String?
  warehouseId               String?
  consolidationMode         DemandConsolidationMode       @default(NONE)
  dateBucket                DemandConsolidationDateBucket @default(EXACT_DATE)
  includeSalesOrderDemand   Boolean                       @default(true)
  includeManualDemand       Boolean                       @default(true)
  includeForecastDemand     Boolean                       @default(false)
  includeReorderDemand      Boolean                       @default(false)
  filterCustomerId          String?
  filterProjectRef          String?                       @db.VarChar(100)
  filterProductItemId       String?
  filterPriority            String?                       @db.VarChar(16)
  status                    DemandConsolidationPlanStatus @default(DRAFT)
  currentCalculationVersion Int                           @default(0)
  currentCalculationRunId   String?
  demandLineCount           Int                           @default(0)
  suggestionCount           Int                           @default(0)
  exceptionCount            Int                           @default(0)
  totalDemandQuantity       Decimal?                      @db.Decimal(18, 4)
  totalCoveredQuantity      Decimal?                      @db.Decimal(18, 4)
  totalUnplannedQuantity    Decimal?                      @db.Decimal(18, 4)
  calculatedAt              DateTime?
  calculatedBy              String?
  reviewedAt                DateTime?
  reviewedBy                String?
  cancelledAt               DateTime?
  cancelledBy               String?
  cancellationReason        String?                       @db.Text
  failureReason             String?                       @db.Text
  clonedFromPlanId          String?
  idempotencyKey            String?                       @db.VarChar(150)
  version                   Int                           @default(1)
  createdBy                 String?
  updatedBy                 String?
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  deletedAt                 DateTime?

  tenant          Tenant                          @relation(fields: [tenantId], references: [id])
  warehouse       MasterWarehouse?                @relation(fields: [warehouseId], references: [id])
  calculationRuns DemandConsolidationCalcRun[]
  demandLines     DemandConsolidationDemandLine[]
  suggestions     DemandConsolidationSuggestion[]
  exceptions      DemandConsolidationException[]

  @@unique([tenantId, planNumber], map: "dcp_tenant_num_key")
  @@unique([tenantId, idempotencyKey], map: "dcp_tenant_idem_key")
  @@index([tenantId], map: "dcp_tenant_idx")
  @@index([tenantId, status], map: "dcp_tenant_status_idx")
  @@index([tenantId, planningPeriodStart, planningPeriodEnd], map: "dcp_tenant_period_idx")
  @@index([tenantId, deletedAt], map: "dcp_tenant_del_idx")
  @@map("demand_consolidation_plans")
}

model DemandConsolidationCalcRun {
  id                  String                           @id @default(uuid())
  tenantId            String
  planId              String
  calculationVersion  Int
  status              DemandConsolidationCalcRunStatus @default(RUNNING)
  parametersJson      Json?
  sourceDemandCount   Int                              @default(0)
  eligibleDemandCount Int                              @default(0)
  excludedDemandCount Int                              @default(0)
  suggestionCount     Int                              @default(0)
  exceptionCount      Int                              @default(0)
  startedAt           DateTime                         @default(now())
  completedAt         DateTime?
  startedBy           String
  errorSummary        String?                          @db.Text
  sourceFingerprint   String?                          @db.VarChar(128)
  createdAt           DateTime                         @default(now())

  tenant      Tenant                          @relation(fields: [tenantId], references: [id])
  plan        DemandConsolidationPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  demandLines DemandConsolidationDemandLine[]
  suggestions DemandConsolidationSuggestion[]
  exceptions  DemandConsolidationException[]

  @@unique([tenantId, planId, calculationVersion], map: "dcp_run_tenant_plan_ver_key")
  @@index([tenantId], map: "dcp_run_tenant_idx")
  @@index([tenantId, planId], map: "dcp_run_tenant_plan_idx")
  @@index([tenantId, status], map: "dcp_run_tenant_status_idx")
  @@map("demand_consolidation_calc_runs")
}

model DemandConsolidationDemandLine {
  id                         String    @id @default(uuid())
  tenantId                   String
  planId                     String
  calculationRunId           String
  productionDemandId         String
  sourceType                 String    @db.VarChar(32)
  sourceDocumentId           String?
  sourceDocumentNumber       String?   @db.VarChar(64)
  sourceLineReference        String?   @db.VarChar(64)
  customerId                 String?
  customerNameSnapshot       String?   @db.VarChar(200)
  projectRef                 String?   @db.VarChar(100)
  projectNameSnapshot        String?   @db.VarChar(200)
  itemId                     String
  itemCodeSnapshot           String    @db.VarChar(64)
  itemNameSnapshot           String    @db.VarChar(200)
  uomId                      String
  uomCodeSnapshot            String    @db.VarChar(32)
  requiredDate               DateTime? @db.Date
  priority                   String    @db.VarChar(16)
  originalDemandQuantity     Decimal   @db.Decimal(18, 4)
  cancelledDemandQuantity    Decimal   @default(0) @db.Decimal(18, 4)
  convertedQuantity          Decimal   @default(0) @db.Decimal(18, 4)
  activeWorkOrderQuantity    Decimal   @default(0) @db.Decimal(18, 4)
  completedWorkOrderQuantity Decimal   @default(0) @db.Decimal(18, 4)
  remainingDemandQuantity    Decimal   @db.Decimal(18, 4)
  quantityAllocatedElsewhere Decimal   @default(0) @db.Decimal(18, 4)
  quantityIncludedInPlan     Decimal   @default(0) @db.Decimal(18, 4)
  quantityExcluded           Decimal   @default(0) @db.Decimal(18, 4)
  exclusionReason            String?   @db.VarChar(200)
  demandStatus               String    @db.VarChar(32)
  sourceUpdatedAt            DateTime?
  sourceFingerprint          String?   @db.VarChar(128)
  createdAt                  DateTime  @default(now())

  tenant           Tenant                     @relation(fields: [tenantId], references: [id])
  plan             DemandConsolidationPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  calculationRun   DemandConsolidationCalcRun @relation(fields: [calculationRunId], references: [id], onDelete: Cascade)
  productionDemand ProductionDemand           @relation(fields: [productionDemandId], references: [id])
  item             MasterItem                 @relation(fields: [itemId], references: [id])
  uom              MasterUom                  @relation(fields: [uomId], references: [id])

  @@index([tenantId], map: "dcp_dline_tenant_idx")
  @@index([tenantId, planId], map: "dcp_dline_tenant_plan_idx")
  @@index([tenantId, calculationRunId], map: "dcp_dline_tenant_run_idx")
  @@index([tenantId, productionDemandId], map: "dcp_dline_tenant_demand_idx")
  @@index([tenantId, itemId], map: "dcp_dline_tenant_item_idx")
  @@index([tenantId, requiredDate], map: "dcp_dline_tenant_req_idx")
  @@map("demand_consolidation_demand_lines")
}

model DemandConsolidationSuggestion {
  id                     String                              @id @default(uuid())
  tenantId               String
  planId                 String
  calculationRunId       String
  suggestionNumber       String?                             @db.VarChar(64)
  suggestionType         DemandConsolidationSuggestionType
  status                 DemandConsolidationSuggestionStatus @default(PROPOSED)
  itemId                 String
  itemCodeSnapshot       String                              @db.VarChar(64)
  itemNameSnapshot       String                              @db.VarChar(200)
  uomId                  String
  plantCode              String?                             @db.VarChar(32)
  customerId             String?
  projectRef             String?                             @db.VarChar(100)
  requiredDate           DateTime?                           @db.Date
  suggestedQuantity      Decimal                             @db.Decimal(18, 4)
  priority               String                              @db.VarChar(16)
  consolidationKey       String                              @db.VarChar(250)
  sourceDemandCount      Int                                 @default(1)
  demandSummaryJson      Json?
  manufacturingProfileId String?
  bomVersionId           String?
  routingVersionId       String?
  readinessStatus        DemandConsolidationReadinessStatus  @default(NOT_CONFIGURED)
  readinessSummaryJson   Json?
  warningCount           Int                                 @default(0)
  exceptionCount         Int                                 @default(0)
  decisionReason         String?                             @db.Text
  reviewedBy             String?
  reviewedAt             DateTime?
  createdAt              DateTime                            @default(now())
  updatedAt              DateTime                            @updatedAt

  tenant         Tenant                         @relation(fields: [tenantId], references: [id])
  plan           DemandConsolidationPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  calculationRun DemandConsolidationCalcRun     @relation(fields: [calculationRunId], references: [id], onDelete: Cascade)
  item           MasterItem                     @relation(fields: [itemId], references: [id])
  uom            MasterUom                      @relation(fields: [uomId], references: [id])
  exceptions     DemandConsolidationException[]

  @@index([tenantId], map: "dcp_sug_tenant_idx")
  @@index([tenantId, planId], map: "dcp_sug_tenant_plan_idx")
  @@index([tenantId, calculationRunId], map: "dcp_sug_tenant_run_idx")
  @@index([tenantId, status], map: "dcp_sug_tenant_status_idx")
  @@index([tenantId, consolidationKey], map: "dcp_sug_tenant_ckey_idx")
  @@map("demand_consolidation_suggestions")
}

model DemandConsolidationException {
  id                 String                               @id @default(uuid())
  tenantId           String
  planId             String
  calculationRunId   String
  demandLineId       String?
  suggestionId       String?
  exceptionType      String                               @db.VarChar(64)
  severity           DemandConsolidationExceptionSeverity
  itemId             String?
  productionDemandId String?
  message            String                               @db.VarChar(500)
  detailsJson        Json?
  status             DemandConsolidationExceptionStatus   @default(OPEN)
  resolvedBy         String?
  resolvedAt         DateTime?
  createdAt          DateTime                             @default(now())

  tenant           Tenant                         @relation(fields: [tenantId], references: [id])
  plan             DemandConsolidationPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  calculationRun   DemandConsolidationCalcRun     @relation(fields: [calculationRunId], references: [id], onDelete: Cascade)
  suggestion       DemandConsolidationSuggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)
  productionDemand ProductionDemand?              @relation(fields: [productionDemandId], references: [id])

  @@index([tenantId], map: "dcp_exc_tenant_idx")
  @@index([tenantId, planId], map: "dcp_exc_tenant_plan_idx")
  @@index([tenantId, calculationRunId], map: "dcp_exc_tenant_run_idx")
  @@index([tenantId, severity, status], map: "dcp_exc_tenant_sev_status_idx")
  @@map("demand_consolidation_exceptions")
}

// ─── Manufacturing Phase 6B — Costing / manufacturing GL (feature-flagged) ────
// Always persist idempotent events. Call posting.service.post() only when
// FinanceFeatureKey.MANUFACTURING_ACCOUNTING is enabled for the legal entity.
// See docs/manufacturing/PRODUCTION_PHASE6B_README.md + ADR-031.

enum ProductionAccountingEventType {
  MATERIAL_RESERVED
  MATERIAL_ISSUED
  MATERIAL_RETURNED
  MATERIAL_CONSUMED
  WIP_MOVED
  SEMI_FINISHED_RECEIVED
  PRODUCTION_COMPLETED
  FINISHED_GOODS_RECEIVED
  SCRAP_RECORDED
  PRODUCTION_ORDER_CLOSED
  LABOUR_ABSORPTION
  MACHINE_ABSORPTION
  OVERHEAD_ABSORPTION
  JOB_WORK_RECEIPT_COST
  PRODUCTION_VARIANCE
  MANUFACTURING_REVERSAL
}

enum ProductionAccountingEventStatus {
  RECORDED
  POSTED
  SKIPPED_ZERO
  SKIPPED_FLAG_OFF
  FAILED
  REVERSED
}

model ProductionAccountingEvent {
  id                 String                          @id @default(uuid())
  tenantId           String
  legalEntityId      String
  eventType          ProductionAccountingEventType
  status             ProductionAccountingEventStatus @default(RECORDED)
  productionOrderId  String?
  idempotencyKey     String                          @db.VarChar(150)
  sourceDocumentType String                          @db.VarChar(64)
  sourceDocumentId   String
  quantity           Decimal                         @db.Decimal(18, 4)
  amount             Decimal                         @default(0) @db.Decimal(18, 4)
  currencyCode       String                          @default("INR") @db.VarChar(8)
  payloadJson        Json?
  voucherId          String?
  postingEventId     String?
  postedAt           DateTime?
  failureReason      String?                         @db.Text
  createdBy          String?
  createdAt          DateTime                        @default(now())
  updatedAt          DateTime                        @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity          @relation(fields: [legalEntityId], references: [id])
  productionOrder ProductionOrder?     @relation(fields: [productionOrderId], references: [id])
  costEntries     WorkOrderCostEntry[]

  @@unique([tenantId, idempotencyKey], map: "mfg_acct_evt_tenant_idem_key")
  @@index([tenantId], map: "mfg_acct_evt_tenant_idx")
  @@index([tenantId, productionOrderId], map: "mfg_acct_evt_tenant_wo_idx")
  @@index([tenantId, eventType], map: "mfg_acct_evt_tenant_type_idx")
  @@index([tenantId, status], map: "mfg_acct_evt_tenant_status_idx")
  @@index([tenantId, legalEntityId], map: "mfg_acct_evt_tenant_le_idx")
  @@map("production_accounting_events")
}

enum ManufacturingCostingMethod {
  ACTUAL
  PLANNED_AS_PROVISIONAL
}

enum ManufacturingMaterialValuationSource {
  MOVEMENT_UNIT_COST
  PROVISIONAL_RATE
}

enum ManufacturingLabourRateSource {
  WORK_CENTRE_RATE
  TENANT_DEFAULT
}

enum ManufacturingMachineRateSource {
  MACHINE_RATE
  WORK_CENTRE_RATE
}

enum ManufacturingJobWorkCostSource {
  LINKED_INVOICE
  APPROVED_CHARGE
  PROVISIONAL_RATE
}

enum ManufacturingOverheadMethod {
  NONE
  PER_LABOUR_HOUR
  PER_MACHINE_HOUR
  PER_GOOD_UNIT
  PERCENT_OF_MATERIAL_COST
}

enum ManufacturingPostingMode {
  MANUAL
  NONE
}

enum ManufacturingCostingPolicyStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum WorkOrderCostSnapshotType {
  PLANNED
  CURRENT_ACTUAL
  FG_RECEIPT
  WORK_ORDER_CLOSE
  REVERSAL
}

enum WorkOrderCostCategory {
  MATERIAL
  LABOUR
  MACHINE
  JOB_WORK
  OVERHEAD
  SCRAP
  REWORK
  VARIANCE
  REVERSAL
}

model ManufacturingCostingPolicy {
  id                      String                               @id @default(uuid())
  tenantId                String
  legalEntityId           String?
  plantCode               String?                              @db.VarChar(32)
  name                    String                               @db.VarChar(191)
  costingMethod           ManufacturingCostingMethod           @default(PLANNED_AS_PROVISIONAL)
  materialValuationSource ManufacturingMaterialValuationSource @default(MOVEMENT_UNIT_COST)
  labourRateSource        ManufacturingLabourRateSource        @default(WORK_CENTRE_RATE)
  machineRateSource       ManufacturingMachineRateSource       @default(MACHINE_RATE)
  jobWorkCostSource       ManufacturingJobWorkCostSource       @default(LINKED_INVOICE)
  overheadMethod          ManufacturingOverheadMethod          @default(NONE)
  overheadRate            Decimal                              @default(0) @db.Decimal(18, 4)
  defaultLabourRate       Decimal                              @default(0) @db.Decimal(18, 2)
  defaultMachineRate      Decimal                              @default(0) @db.Decimal(18, 2)
  fgPostingMode           ManufacturingPostingMode             @default(MANUAL)
  variancePostingMode     ManufacturingPostingMode             @default(MANUAL)
  status                  ManufacturingCostingPolicyStatus     @default(DRAFT)
  effectiveFrom           DateTime?                            @db.Date
  currencyCode            String                               @default("INR") @db.VarChar(8)
  createdBy               String?
  updatedBy               String?
  createdAt               DateTime                             @default(now())
  updatedAt               DateTime                             @updatedAt
  deletedAt               DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@index([tenantId, plantCode, status])
