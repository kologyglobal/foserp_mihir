// ─── Manufacturing Phase 4B — Job Work / subcontracting ──────────────────────

enum JobWorkStatus {
  DRAFT
  MATERIAL_SENT
  PARTIALLY_RECEIVED
  RECEIVED
  RECONCILIATION_PENDING
  CLOSED
  CANCELLED
}

enum JobWorkRateBasis {
  PER_PIECE
  PER_KG
  PER_HOUR
  PER_BATCH
  FIXED
}

enum JobWorkInvoiceStatus {
  NONE
  LINKED
  PENDING
}

enum JobWorkMaterialLineStatus {
  PENDING
  PARTIAL
  SENT
  RECONCILED
  DIFFERENCE
}

model JobWorkOrder {
  id                  String               @id @default(uuid())
  tenantId            String
  jwNumber            String               @db.VarChar(64)
  status              JobWorkStatus        @default(DRAFT)
  vendorId            String
  productionOrderId   String?
  processName         String               @db.VarChar(200)
  itemId              String
