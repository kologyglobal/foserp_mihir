  PARTIALLY_FILLED
  COMPLETE
  VERIFIED
  REOPENED
  CANCELLED
}

enum DispatchPackageLineStatus {
  PACKED
  MOVED
  UNPACKED
  CANCELLED
}

enum DispatchPackingEventType {
  SESSION_CREATED
  SESSION_STARTED
  PACKAGE_CREATED
  PACK
  UNPACK
  MOVE_BETWEEN_PACKAGES
  PACKAGE_COMPLETED
  PACKAGE_REOPENED
  PACKAGE_VERIFIED
  SHORTAGE_REPORTED
  SHORTAGE_RESOLVED
  SESSION_COMPLETED
  SESSION_VERIFIED
  SESSION_CANCELLED
}

model DispatchPackageType {
