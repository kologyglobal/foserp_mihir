}

model PurchaseOrder {
  id                    String              @id @default(uuid())
  tenantId              String
  orderNumber           String              @db.VarChar(64)
  orderDate             DateTime            @db.Date
  vendorId              String
  origin                PurchaseOrderOrigin @default(MANUAL)
  status                PurchaseOrderStatus @default(DRAFT)
  purchaseRequisitionId String?
  requestForQuotationId String?
  vendorQuotationId     String?
  vendorComparisonId    String?
  currencyCode          String              @default("INR") @db.VarChar(8)
  expectedDeliveryDate  DateTime?           @db.Date
  paymentTerms          String?             @db.VarChar(200)
  deliveryTerms         String?             @db.VarChar(200)
  subtotalAmount        Decimal             @default(0) @db.Decimal(18, 2)
  taxAmount             Decimal             @default(0) @db.Decimal(18, 2)
  freightAmount         Decimal             @default(0) @db.Decimal(18, 2)
  totalAmount           Decimal             @default(0) @db.Decimal(18, 2)
  remarks               String?             @db.Text
  submittedAt           DateTime?
  approvedAt            DateTime?
  sentAt                DateTime?
  closedAt              DateTime?
  cancelledAt           DateTime?
  createdById           String?             @db.VarChar(36)
  updatedById           String?             @db.VarChar(36)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  vendor              MasterVendor          @relation(fields: [vendorId], references: [id])
  purchaseRequisition PurchaseRequisition?  @relation(fields: [purchaseRequisitionId], references: [id])
  requestForQuotation RequestForQuotation?  @relation(fields: [requestForQuotationId], references: [id])
  vendorQuotation     VendorQuotation?      @relation(fields: [vendorQuotationId], references: [id])
  vendorComparison    VendorComparison?     @relation(fields: [vendorComparisonId], references: [id])
  lines                         PurchaseOrderLine[]
  planningRows                  PurchasePlanningRow[]
  convertedRequisitionLines     PurchaseRequisitionLine[]
  approvals                     PurchaseApproval[]    @relation("PurchaseApprovalPo")

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, vendorId])
  @@index([tenantId, purchaseRequisitionId])
  @@index([tenantId, requestForQuotationId])
  @@index([tenantId, orderDate])
  @@index([tenantId, origin])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id                        String    @id @default(uuid())
  tenantId                  String
  purchaseOrderId           String
  lineNumber                Int
  purchaseRequisitionLineId String?
  purchasePlanningRowId     String?
  itemId                    String?
  itemCodeSnapshot          String    @default("") @db.VarChar(64)
  itemNameSnapshot          String    @default("") @db.VarChar(300)
  description               String?   @db.Text
  quantity                  Decimal   @default(0) @db.Decimal(18, 4)
  uomId                     String?
  rate                      Decimal   @default(0) @db.Decimal(18, 2)
  amount                    Decimal   @default(0) @db.Decimal(18, 2)
  receivedQuantity          Decimal   @default(0) @db.Decimal(18, 4)
  requiredDate              DateTime? @db.Date
  remarks                   String?   @db.Text
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  purchaseOrder           PurchaseOrder            @relation(fields: [purchaseOrderId], references: [id])
  purchaseRequisitionLine PurchaseRequisitionLine? @relation(fields: [purchaseRequisitionLineId], references: [id])
  purchasePlanningRow     PurchasePlanningRow?     @relation(fields: [purchasePlanningRowId], references: [id])
  item                    MasterItem?              @relation(fields: [itemId], references: [id])
  uom                     MasterUom?               @relation(fields: [uomId], references: [id])

  @@unique([tenantId, purchaseOrderId, lineNumber])
  @@index([tenantId])
  @@index([tenantId, purchaseOrderId])
  @@index([tenantId, purchaseRequisitionLineId])
  @@index([tenantId, purchasePlanningRowId])
  @@index([tenantId, itemId])
  @@map("purchase_order_lines")
}

model PurchaseApproval {
  id                    String                       @id @default(uuid())
  tenantId              String
  documentType          PurchaseApprovalDocumentType
  documentId            String                       @db.VarChar(36)
  documentNumber        String?                      @db.VarChar(64)
  purchaseRequisitionId String?
  purchaseOrderId       String?
  level                 Int                          @default(1)
  status                PurchaseApprovalStatus       @default(PENDING)
  approverRole          String?                      @db.VarChar(64)
  approverId            String?                      @db.VarChar(36)
  requesterId           String?                      @db.VarChar(36)
  amount                Decimal?                     @db.Decimal(18, 2)
  remarks               String?                      @db.Text
  requestedAt           DateTime                     @default(now())
  respondedAt           DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  purchaseRequisition PurchaseRequisition? @relation("PurchaseApprovalPr", fields: [purchaseRequisitionId], references: [id])
  purchaseOrder       PurchaseOrder?       @relation("PurchaseApprovalPo", fields: [purchaseOrderId], references: [id])

  @@index([tenantId])
  @@index([tenantId, documentType, documentId])
  @@index([tenantId, status])
  @@index([tenantId, purchaseRequisitionId])
  @@index([tenantId, purchaseOrderId])
  @@index([tenantId, approverId])
  @@map("purchase_approvals")
}

model PurchaseStatusHistory {
  id             String                            @id @default(uuid())
  tenantId       String
  documentType   PurchaseStatusHistoryDocumentType
  documentId     String                            @db.VarChar(36)
  documentNumber String?                           @db.VarChar(64)
  action         String                            @db.VarChar(64)
  fromStatus     String?                           @db.VarChar(64)
  toStatus       String?                           @db.VarChar(64)
  actorId        String?                           @db.VarChar(36)
  actorName      String?                           @db.VarChar(200)
  remarks        String?                           @db.Text
  actedAt        DateTime                          @default(now())
  createdAt      DateTime                          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, documentType, documentId])
  @@index([tenantId, actedAt])
  @@index([tenantId, action])
  @@map("purchase_status_histories")
}
