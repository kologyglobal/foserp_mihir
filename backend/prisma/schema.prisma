  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, countryId])
  @@index([tenantId, stateId])
  @@index([tenantId, cityId])
  @@map("master_vendors")
}

