generator client {
  provider   = "prisma-client-js"
  // Rust-free JS/Wasm engine — avoids Hostinger/cPanel "PANIC: timer has gone away"
  // (native query engine exceeds shared-hosting process/thread limits).
  engineType = "client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
  BLOCKED
  ARCHIVED
}

enum CodeSeriesEntity {
  USER
  LEAD
  CONTACT
  CRM_COMPANY
  OPPORTUNITY
  QUOTATION
  SALES_ORDER
  PRODUCTION_DEMAND
  PRODUCTION_ORDER
  DAILY_PRODUCTION_BATCH
  PRODUCTION_ISSUE
  STOCK_MOVEMENT
  STOCK_RESERVATION
  PURCHASE_REQUISITION
  QUALITY_INSPECTION
  QUALITY_NCR
  JOB_WORK_ORDER
  PRODUCTION_RUNTIME_CHANGE
  PRODUCTION_WIP_MOVEMENT
  MANUFACTURING_CORRECTION
  PRODUCTION_PLAN
  DEMAND_CONSOLIDATION_PLAN
  OUTBOUND_DISPATCH
  PRODUCTION_FG_RECEIPT
  DISPATCH_REQUIREMENT
  DISPATCH_PICK_LIST
  DISPATCH_PACKING_SESSION
  DISPATCH_PACKAGE
  DELIVERY_CHALLAN
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  WHATSAPP
  FOLLOW_UP
  NOTE
  DEMO
  TASK
  SITE_VISIT
  STAGE_CHANGE
}

enum ActivityStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ON_HOLD
  ARCHIVED
}

enum PipelineStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// ─── Tenants ─────────────────────────────────────────────────────────────────

model Tenant {
  id                 String       @id @default(uuid())
  name               String       @db.VarChar(200)
  slug               String       @unique @db.VarChar(100)
  legalName          String?      @db.VarChar(300)
  email              String       @db.VarChar(255)
  phone              String?      @db.VarChar(30)
  country            String?      @db.VarChar(100)
  state              String?      @db.VarChar(100)
  city               String?      @db.VarChar(100)
  timezone           String       @default("Asia/Kolkata") @db.VarChar(64)
  currency           String       @default("INR") @db.VarChar(8)
  status             TenantStatus @default(TRIAL)
  subscriptionPlan   String?      @db.VarChar(64)
  subscriptionStatus String?      @db.VarChar(64)
  trialEndsAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  users                                  User[]
  roles                                  Role[]
  codeSeries                             CodeSeries[]
  auditLogs                              AuditLog[]
  crmCompanies                           CrmCompany[]
  crmContacts                            CrmContact[]
  crmLeads                               CrmLead[]
  crmActivities                          CrmActivity[]
  crmPipelines                           CrmPipeline[]
  crmPipelineStages                      CrmPipelineStage[]
  crmOpportunities                       CrmOpportunity[]
  crmFollowUps                           CrmFollowUp[]
  crmMasters                             CrmMaster[]
  crmNotes                               CrmNote[]
  crmAttachments                         CrmAttachment[]
  crmQuotations                          CrmQuotation[]
  crmQuotationDocuments                  CrmQuotationDocument[]
  crmQuotationTemplates                  CrmQuotationTemplate[]
  crmSalesOrders                         CrmSalesOrder[]
  masterCountries                        MasterCountry[]
  masterStates                           MasterState[]
  masterCities                           MasterCity[]
  masterProducts                         MasterProduct[]
  masterUoms                             MasterUom[]
  masterWarehouses                       MasterWarehouse[]
  masterLocations                        MasterLocation[]
  masterItemCategories                   MasterItemCategory[]
  masterHsnCodes                         MasterHsnCode[]
  masterGstGroups                        MasterGstGroup[]
  masterGstRates                         MasterGstRate[]
  masterItems                            MasterItem[]
  masterVendors                          MasterVendor[]
  legalEntities                          LegalEntity[]
  branches                               Branch[]
  financialYears                         FinancialYear[]
  accountingPeriods                      AccountingPeriod[]
  accounts                               Account[]
  defaultAccountMappings                 DefaultAccountMapping[]
  financeSettings                        FinanceSettings[]
  costCentres                            CostCentre[]
  financeFeatureControls                 FinanceFeatureControl[]
  financeApprovalRules                   FinanceApprovalRule[]
  financeNumberSeries                    FinanceNumberSeries[]
  accountingVouchers                     AccountingVoucher[]
  accountingVoucherLines                 AccountingVoucherLine[]
  generalLedgerEntries                   GeneralLedgerEntry[]
  postingEvents                          PostingEvent[]
  postingRules                           PostingRule[]
  financeApprovalRequests                FinanceApprovalRequest[]
  financeApprovalSteps                   FinanceApprovalStep[]
  salesInvoices                          SalesInvoice[]
  salesInvoiceLines                      SalesInvoiceLine[]
  receivableOpenItems                    ReceivableOpenItem[]
  customerReceipts                       CustomerReceipt[]
  customerReceiptAllocations             CustomerReceiptAllocation[]
  customerReceiptDeductionLines          CustomerReceiptDeductionLine[]
  customerReceiptAllocationBatches       CustomerReceiptAllocationBatch[]
  creditNoteReasons                      CreditNoteReason[]
  customerCreditNotes                    CustomerCreditNote[]
  customerCreditNoteLines                CustomerCreditNoteLine[]
  customerCreditNoteAllocations          CustomerCreditNoteAllocation[]
  customerCreditNoteAllocationBatches    CustomerCreditNoteAllocationBatch[]
  vendorInvoices                         VendorInvoice[]
  vendorInvoiceLines                     VendorInvoiceLine[]
  vendorInvoiceSourceLinks               VendorInvoiceSourceLink[]
  payableOpenItems                       PayableOpenItem[]
  vendorPayments                         VendorPayment[]
  vendorPaymentAdjustmentLines           VendorPaymentAdjustmentLine[]
  payableAllocationBatches               PayableAllocationBatch[]
  payableAllocationLines                 PayableAllocationLine[]
  payableAllocationReversalBatches       PayableAllocationReversalBatch[]
  payableAllocationReversalLines         PayableAllocationReversalLine[]
  vendorAdjustments                      VendorAdjustment[]
  vendorAdjustmentLines                  VendorAdjustmentLine[]
  vendorAdjustmentSourceLinks            VendorAdjustmentSourceLink[]
  payableReconciliationRuns              PayableReconciliationRun[]
  payableReconciliationAccountResults    PayableReconciliationAccountResult[]
  payableReconciliationExceptions        PayableReconciliationException[]
  payableCloseGateRuns                   PayableCloseGateRun[]
  payableCloseGateChecks                 PayableCloseGateCheck[]
  treasuryAccounts                       TreasuryAccount[]
  treasuryBankProfiles                   TreasuryBankProfile[]
  treasuryCashProfiles                   TreasuryCashProfile[]
  paymentAccountMappings                 PaymentAccountMapping[]
  bankReconciliationProfiles             BankReconciliationProfile[]
  bankStatementImportBatches             BankStatementImportBatch[]
  bankStatements                         BankStatement[]
  bankStatementLines                     BankStatementLine[]
  bankStatementColumnMappingTemplates    BankStatementColumnMappingTemplate[]
  bankStatementImportIssues              BankStatementImportIssue[]
  bankReconciliationSessions             BankReconciliationSession[]
  bankReconciliationMatches              BankReconciliationMatch[]
  bankReconciliationStatementAllocations BankReconciliationStatementAllocation[]
  bankReconciliationLedgerAllocations    BankReconciliationLedgerAllocation[]
  bankReconciliationSuggestions          BankReconciliationSuggestion[]
  bankReconciliationMatchRuns            BankReconciliationMatchRun[]
  bankLedgerReconciliationPositions      BankLedgerReconciliationPosition[]
  bankReconciliationExceptions           BankReconciliationException[]
  treasuryTransfers                      TreasuryTransfer[]
  treasuryCheques                        TreasuryCheque[]
  treasuryAdjustments                    TreasuryAdjustment[]
  treasuryAdjustmentLines                TreasuryAdjustmentLine[]
  bankPostingRules                       BankPostingRule[]
  standingInstructions                   StandingInstruction[]
  standingInstructionExecutions          StandingInstructionExecution[]
  treasuryDayCloses                      TreasuryDayClose[]
  bankConnectors                         BankConnector[]
  bankConnectorConsents                  BankConnectorConsent[]
  budgetVersions                         BudgetVersion[]
  budgetLines                            BudgetLine[]

  savedReportViews            SavedReportView[]
  operationalExceptionActions OperationalExceptionAction[]

  fixedAssetCategories        FixedAssetCategory[]
  fixedAssets                 FixedAsset[]
  fixedAssetDepreciationRuns  FixedAssetDepreciationRun[]
  fixedAssetDepreciationLines FixedAssetDepreciationLine[]
  fixedAssetDisposals         FixedAssetDisposal[]
  fixedAssetTransfers         FixedAssetTransfer[]

  manufacturingWorkCentres           ManufacturingWorkCentre[]
  manufacturingMachines              ManufacturingMachine[]
  manufacturingCostingPolicies       ManufacturingCostingPolicy[]
  manufacturingBoms                  ManufacturingBom[]
  manufacturingBomVersions           ManufacturingBomVersion[]
  manufacturingBomLines              ManufacturingBomLine[]
  manufacturingRoutings              ManufacturingRouting[]
  manufacturingRoutingVersions       ManufacturingRoutingVersion[]
  manufacturingStageGroups           ManufacturingStageGroup[]
  manufacturingRoutingOperations     ManufacturingRoutingOperation[]
  manufacturingOperationDependencies ManufacturingOperationDependency[]
  manufacturingProfiles              ManufacturingProfile[]
  manufacturingWarehouseMappings     ManufacturingWarehouseMapping[]

  productionDemands                 ProductionDemand[]
  productionOrders                  ProductionOrder[]
  productionOrderBomSnapshots       ProductionOrderBomSnapshot[]
  productionOrderBomLines           ProductionOrderBomLine[]
  productionOrderRoutingSnapshots   ProductionOrderRoutingSnapshot[]
  productionOrderStages             ProductionOrderStage[]
  productionOrderOperations         ProductionOrderOperation[]
  productionOrderDependencies       ProductionOrderDependency[]
  productionStageLedgerEntries      ProductionStageLedger[]
  productionActivities              ProductionActivity[]
  productionAssignments             ProductionAssignment[]
  dailyProductionBatches            DailyProductionBatch[]
  dailyProductionLines              DailyProductionLine[]
  productionIssues                  ProductionIssue[]
  productionDowntimes               ProductionDowntime[]
  inventoryStockBalances            InventoryStockBalance[]
  inventoryStockMovements           InventoryStockMovement[]
  inventoryStockReservations        InventoryStockReservation[]
  purchaseRequisitions              PurchaseRequisition[]
  purchaseRequisitionLines          PurchaseRequisitionLine[]
  productionOrderMaterials          ProductionOrderMaterial[]
  qualityInspections                QualityInspection[]
  qualityNcrs                       QualityNcr[]
  qualityParameters                 QualityParameter[]
  qualityInspectionPlans            QualityInspectionPlan[]
  qualityInspectionPlanLines        QualityInspectionPlanLine[]
  qualityInspectionPlanRevisions    QualityInspectionPlanRevision[]
  qualityInspectionParameterResults QualityInspectionParameterResult[]
  qualityCertificates               QualityCertificate[]
  jobWorkOrders                     JobWorkOrder[]
  jobWorkMaterialLines              JobWorkMaterialLine[]
  jobWorkDispatches                 JobWorkDispatch[]
  jobWorkReceipts                   JobWorkReceipt[]
  jobWorkDispatchLines              JobWorkDispatchLine[]
  productionRuntimeChanges          ProductionRuntimeChange[]
  productionWipMovements            ProductionWipMovement[]
  manufacturingCorrections          ManufacturingTransactionCorrection[]
  manufacturingCorrectionLinks      ManufacturingTransactionReversalLink[]
  manufacturingRuntimeChangeRules   ManufacturingRuntimeChangeRule[]
  productionPlans                   ProductionPlan[]
  productionPlanLines               ProductionPlanLine[]
  demandConsolidationPlans          DemandConsolidationPlan[]
  demandConsolidationCalcRuns       DemandConsolidationCalcRun[]
  demandConsolidationDemandLines    DemandConsolidationDemandLine[]
  demandConsolidationSuggestions    DemandConsolidationSuggestion[]
  demandConsolidationExceptions     DemandConsolidationException[]
  productionAccountingEvents        ProductionAccountingEvent[]
  workOrderCostSnapshots            WorkOrderCostSnapshot[]
  workOrderCostEntries              WorkOrderCostEntry[]
  productionFinishedGoodsReceipts   ProductionFinishedGoodsReceipt[]

  // Dispatch Phase 7C0 — SO fulfilment + thin FG outbound dispatch
  salesOrderLineFulfilments          SalesOrderLineFulfilment[]
  outboundDispatches                 OutboundDispatch[]
  outboundDispatchLines              OutboundDispatchLine[]
  // Dispatch Phase 7C1 — requirements / readiness workbench
  dispatchRequirements               DispatchRequirement[]
  // Dispatch Phase 7C2 — reservation + picking
  dispatchPickLists                  DispatchPickList[]
  dispatchPickLines                  DispatchPickLine[]
  dispatchPickEvents                 DispatchPickEvent[]
  dispatchTrackingAllocations        DispatchTrackingAllocation[]
  // Dispatch Phase 7C3 — packing (operational allocation)
  dispatchPackageTypes               DispatchPackageType[]
  dispatchPackingSessions            DispatchPackingSession[]
  dispatchPackages                   DispatchPackage[]
  dispatchPackageLines               DispatchPackageLine[]
  dispatchPackingEvents              DispatchPackingEvent[]
  // Dispatch Phase 7C4 — Delivery Challan (document only; no stock/fulfilment)
  deliveryChallans                   DeliveryChallan[]
  deliveryChallanLines               DeliveryChallanLine[]
  deliveryChallanPackages            DeliveryChallanPackage[]
  deliveryChallanTrackingAllocations DeliveryChallanTrackingAllocation[]

  @@index([status])
  @@index([deletedAt])
  @@map("tenants")
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  tenantId      String
  firstName     String     @db.VarChar(100)
  lastName      String     @db.VarChar(100)
  email         String     @db.VarChar(255)
  mobile        String?    @db.VarChar(20)
  passwordHash  String     @db.VarChar(255)
  designation   String?    @db.VarChar(100)
  department    String?    @db.VarChar(100)
  status        UserStatus @default(INVITED)
  emailVerified Boolean    @default(false)
  lastLoginAt   DateTime?
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  userRoles           UserRole[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid())
  tenantId    String? // null = global system role (Super Admin)
  name        String    @db.VarChar(100)
  description String?   @db.Text
  isSystem    Boolean   @default(false)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  module      String   @db.VarChar(64)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  tenantId  String
  createdAt DateTime @default(now())
  createdBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([tenantId])
  @@index([userId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tenantId  String
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?   @db.VarChar(512)
  ipAddress String?   @db.VarChar(64)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  module    String   @db.VarChar(64)
  entity    String   @db.VarChar(64)
  entityId  String?  @db.VarChar(36)
  action    String   @db.VarChar(64)
  oldValues Json?
  newValues Json?
  ipAddress String?  @db.VarChar(64)
  userAgent String?  @db.VarChar(512)
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, module])
  @@index([tenantId, entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model CodeSeries {
  id           String           @id @default(uuid())
  tenantId     String
  entityType   CodeSeriesEntity
  prefix       String           @db.VarChar(20)
  currentValue Int              @default(0)
  padLength    Int              @default(6)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, entityType])
  @@index([tenantId])
  @@map("code_series")
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model CrmCompany {
  id             String    @id @default(uuid())
  tenantId       String
  companyCode    String    @db.VarChar(32)
  name           String    @db.VarChar(300)
  customerType   String    @default("corporate") @db.VarChar(32)
  website        String?   @db.VarChar(255)
  industry       String?   @db.VarChar(100)
  turnoverRange  String?   @db.VarChar(64)
  employeeRange  String?   @db.VarChar(64)
  email          String?   @db.VarChar(255)
  phone          String?   @db.VarChar(30)
  addressLine1   String?   @db.VarChar(500)
  addressLine2   String?   @db.VarChar(500)
  city           String?   @db.VarChar(100)
  state          String?   @db.VarChar(100)
  pincode        String?   @db.VarChar(20)
  country        String?   @default("India") @db.VarChar(100)
  gstin          String?   @db.VarChar(20)
  pan            String?   @db.VarChar(20)
  contactPerson  String?   @db.VarChar(200)
  contactPhone   String?   @db.VarChar(30)
  contactEmail   String?   @db.VarChar(255)
  creditDays     Int       @default(0)
  creditLimit    Decimal?  @db.Decimal(18, 2)
  salesTerritory String?   @db.VarChar(32)
  source         String?   @db.VarChar(64)
  ownerId        String?
  status         String    @default("active") @db.VarChar(32)
  isActive       Boolean   @default(true)
  notes          String?   @db.Text
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  contacts      CrmContact[]
  leads         CrmLead[]
  activities    CrmActivity[]
  opportunities CrmOpportunity[]
  quotations    CrmQuotation[]
  salesOrders   CrmSalesOrder[]

  @@unique([tenantId, companyCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, name])
  @@map("crm_companies")
}

model CrmContact {
  id              String    @id @default(uuid())
  tenantId        String
  contactCode     String    @db.VarChar(32)
  companyId       String
  firstName       String    @db.VarChar(100)
  lastName        String    @default("") @db.VarChar(100)
  designation     String?   @db.VarChar(100)
  department      String?   @db.VarChar(100)
  email           String?   @db.VarChar(255)
  mobile          String?   @db.VarChar(20)
  alternateMobile String?   @db.VarChar(20)
  linkedInUrl     String?   @db.VarChar(255)
  ownerId         String?
  isPrimary       Boolean   @default(false)
  status          String    @default("active") @db.VarChar(32)
  isActive        Boolean   @default(true)
  masterContactId String?
  notes           String?   @db.Text
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  company       CrmCompany       @relation(fields: [companyId], references: [id])
  leads         CrmLead[]
  activities    CrmActivity[]
  opportunities CrmOpportunity[]

  @@unique([tenantId, contactCode])
  @@index([tenantId])
  @@index([tenantId, companyId])
  @@index([tenantId, email])
  @@index([tenantId, deletedAt])
  @@map("crm_contacts")
}

model CrmLead {
  id                  String    @id @default(uuid())
  tenantId            String
  leadCode            String    @db.VarChar(32)
  prospectName        String    @db.VarChar(300)
  companyName         String?   @db.VarChar(300)
  companyId           String?
  contactId           String?
  designation         String?   @db.VarChar(100)
  email               String?   @db.VarChar(255)
  mobile              String?   @db.VarChar(20)
  contactPerson       String?   @db.VarChar(200)
  source              String    @default("other") @db.VarChar(64)
  industry            String?   @db.VarChar(100)
  turnoverRange       String?   @db.VarChar(64)
  productRequirement  String?   @db.Text
  expectedQty         Int?
  expectedValue       Decimal   @default(0) @db.Decimal(18, 2)
  probability         Int       @default(0)
  stage               String    @default("new") @db.VarChar(64)
  priority            String    @default("medium") @db.VarChar(32)
  lifecycleStatus     String    @default("open") @db.VarChar(32)
  activityStatus      String    @default("active") @db.VarChar(32)
  qualificationStatus String?   @db.VarChar(32)
  temperature         String?   @db.VarChar(16)
  assignedTo          String?
  ownerId             String?
  lastContactedAt     DateTime?
  nextFollowUpAt      DateTime?
  expectedCloseDate   DateTime?
  inactiveReason      String?   @db.VarChar(64)
  notQualifiedReason  String?   @db.VarChar(64)
  closedReason        String?   @db.VarChar(64)
  closedDate          DateTime?
  lostReason          String?   @db.Text
  remarks             String?   @db.Text
  followUpType        String?   @db.VarChar(64)
  followUpNotes       String?   @db.Text
  opportunityId       String?
  convertedAt         DateTime?
  isArchived          Boolean   @default(false)
  locationId          String?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  tenant        Tenant                 @relation(fields: [tenantId], references: [id])
  company       CrmCompany?            @relation(fields: [companyId], references: [id])
  contact       CrmContact?            @relation(fields: [contactId], references: [id])
  activities    CrmActivity[]
  statusHistory CrmLeadStatusHistory[]
  assignments   CrmLeadAssignment[]

  @@unique([tenantId, leadCode])
  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, assignedTo])
  @@index([tenantId, ownerId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@map("crm_leads")
}

model CrmLeadStatusHistory {
  id        String   @id @default(uuid())
  tenantId  String
  leadId    String
  fromStage String?  @db.VarChar(64)
  toStage   String   @db.VarChar(64)
  changedBy String?
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  lead CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId])
  @@map("crm_lead_status_history")
}

model CrmLeadAssignment {
  id         String   @id @default(uuid())
  tenantId   String
  leadId     String
  assignedTo String
  assignedBy String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  lead CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId])
  @@index([tenantId, assignedTo])
  @@map("crm_lead_assignments")
}

model CrmActivity {
  id            String         @id @default(uuid())
  tenantId      String
  activityType  ActivityType
  subject       String         @db.VarChar(500)
  description   String?        @db.Text
  leadId        String?
  contactId     String?
  companyId     String?
  opportunityId String?
  assignedTo    String?
  scheduledAt   DateTime?
  completedAt   DateTime?
  priority      String?        @db.VarChar(32)
  status        ActivityStatus @default(PLANNED)
  outcome       String?        @db.Text
  nextAction    String?        @db.Text
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  lead        CrmLead?        @relation(fields: [leadId], references: [id])
  contact     CrmContact?     @relation(fields: [contactId], references: [id])
  company     CrmCompany?     @relation(fields: [companyId], references: [id])
  opportunity CrmOpportunity? @relation(fields: [opportunityId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
