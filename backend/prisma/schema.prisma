  CREDIT
}

enum DefaultAccountMappingKey {
  CUSTOMER_RECEIVABLE
  VENDOR_PAYABLE
  SALES_REVENUE
  SALES_RETURN
  PURCHASE
  PURCHASE_RETURN
  RAW_MATERIAL_INVENTORY
  WIP_INVENTORY
  FINISHED_GOODS_INVENTORY
  STOCK_ADJUSTMENT
  MATERIAL_CONSUMPTION
  /// Manufacturing costing uses the finance default-account mapping source (ADR-039);
  /// do not introduce a separate manufacturing account-mapping table.
  LABOUR_ABSORPTION
  MACHINE_ABSORPTION
  JOB_WORK_ABSORPTION
  PRODUCTION_OVERHEAD_ABSORPTION
  PRODUCTION_VARIANCE
  SCRAP_INVENTORY
  SCRAP_LOSS
  SUBCONTRACTING_EXPENSE
  FREIGHT_INWARD
  FREIGHT_OUTWARD
  GST_INPUT_CGST
  GST_INPUT_SGST
  GST_INPUT_IGST
  GST_OUTPUT_CGST
  GST_OUTPUT_SGST
  GST_OUTPUT_IGST
  GST_OUTPUT_CESS
  TDS_RECEIVABLE
  TDS_PAYABLE
  BANK_CHARGES
  ROUNDING
  DEPRECIATION_EXPENSE
  ACCUMULATED_DEPRECIATION
  ASSET_DISPOSAL_GAIN
  ASSET_DISPOSAL_LOSS
  /// Credit side for FA capitalization when not posting against cash/AP (Phase FA1).
  FIXED_ASSET_CLEARING
  RETAINED_EARNINGS
  /// Internal fund-transfer in-transit clearing (Phase 5B1).
  INTERNAL_TRANSFER_CLEARING
  /// Cheque received counterpart account (e.g. cheques-in-hand / debtor clearing) (Phase 5B2).
  CHEQUE_RECEIPT_CLEARING
  /// Cheque issued counterpart account (e.g. cheques-issued / creditor clearing) (Phase 5B2).
  CHEQUE_PAYMENT_CLEARING
  /// Bank interest income default mapping (Phase 5B3).
  BANK_INTEREST_INCOME
  /// Bank interest/finance expense default mapping (Phase 5B3).
  BANK_INTEREST_EXPENSE
  /// Collection fee expense default mapping (Phase 5B3).
  COLLECTION_FEE_EXPENSE
  /// Merchant/payment-gateway fee expense default mapping (Phase 5B3).
  MERCHANT_FEE_EXPENSE
}

enum FinanceFeatureKey {
  RECEIVABLES
  PAYABLES
  BANK_RECONCILIATION
  GST
  TDS
  FIXED_ASSETS
  MANUFACTURING_ACCOUNTING
  BUDGETING
  MULTI_CURRENCY
  COST_CENTRES
  PROJECT_ACCOUNTING
  APPROVALS
}

enum FinanceDocumentType {
  JOURNAL
  RECEIPT
  PAYMENT
  CONTRA
  CREDIT_NOTE
  DEBIT_NOTE
  OPENING_BALANCE
  REVERSAL
  /// AR invoice numbering — not mapped to AccountingVoucherType (Phase 3A1).
  SALES_INVOICE
  /// Customer-facing receipt number series — distinct from voucher RECEIPT (Phase 3B1).
  CUSTOMER_RECEIPT
  /// Customer-facing AR credit note number series (Phase 3C).
  CUSTOMER_CREDIT_NOTE
  /// Vendor invoice / purchase bill numbering — not mapped to AccountingVoucherType (Phase 4A1).
  VENDOR_INVOICE
  /// Vendor payment / advance numbering — not mapped to AccountingVoucherType (Phase 4B1).
  VENDOR_PAYMENT
  /// Vendor debit note numbering (Phase 4C2).
  VENDOR_DEBIT_NOTE
  /// Vendor credit adjustment numbering (Phase 4C2).
  VENDOR_CREDIT_ADJUSTMENT
  /// Bank reconciliation match reference — not a voucher number (Phase 5A3).
  BANK_RECONCILIATION_MATCH
  /// Internal treasury transfer number — not AccountingVoucherType (Phase 5B1).
  TREASURY_TRANSFER
  /// Cheque register number — not AccountingVoucherType (Phase 5B2).
  TREASURY_CHEQUE
  /// Treasury adjustment register number — not AccountingVoucherType (Phase 5B3).
  TREASURY_ADJUSTMENT
  /// Fixed asset register number (Phase FA1).
  FIXED_ASSET
  /// Fixed asset depreciation run number (Phase FA1).
  FA_DEPRECIATION_RUN
  /// Fixed asset disposal document number (Phase FA2 document workflow).
  FIXED_ASSET_DISPOSAL
}

enum RoundingMethod {
  ROUND_HALF_UP
  ROUND_HALF_EVEN
  ROUND_DOWN
  ROUND_UP
}

