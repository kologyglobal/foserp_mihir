/// Subledger-only allocation batch — one DEBIT source open item to many CREDIT targets.
/// Creates no PostingEvent, voucher, or GL. Phase 4B1 foundation only.
model PayableAllocationBatch {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  /// MasterVendor.id — soft reference.
  vendorId String

  allocationReference String @db.VarChar(64)

  sourceDebitOpenItemId String

  allocationDate DateTime @db.Date
  currencyCode   String   @default("INR") @db.VarChar(8)
  exchangeRate   Decimal  @default(1) @db.Decimal(18, 8)

  totalAllocatedAmount     Decimal @default(0) @db.Decimal(18, 4)
  baseTotalAllocatedAmount Decimal @default(0) @db.Decimal(18, 4)

  status PayableAllocationStatus @default(ACTIVE)

  idempotencyKey String? @unique @db.VarChar(128)
  payloadHash    String? @db.VarChar(128)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant                           @relation(fields: [tenantId], references: [id])
  legalEntity         LegalEntity                      @relation(fields: [legalEntityId], references: [id])
  branch              Branch?                          @relation(fields: [branchId], references: [id])
  sourceDebitOpenItem PayableOpenItem                  @relation("PayableAllocationSourceDebit", fields: [sourceDebitOpenItemId], references: [id])
  lines               PayableAllocationLine[]
  reversalBatches     PayableAllocationReversalBatch[]

  @@unique([tenantId, allocationReference], map: "pay_alloc_batch_ref_key")
  @@index([tenantId, legalEntityId])
  @@index([tenantId, legalEntityId, vendorId])
  @@index([tenantId, legalEntityId, status])
  @@index([sourceDebitOpenItemId])
  @@index([allocationDate])
  @@index([createdAt])
  @@map("payable_allocation_batches")
}

model PayableAllocationLine {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  allocationBatchId String

  sourceDebitOpenItemId  String
  targetCreditOpenItemId String

