  baseGrossAmount               Decimal @default(0) @db.Decimal(18, 4)
  baseDiscountAmount            Decimal @default(0) @db.Decimal(18, 4)
  baseTaxableAmount             Decimal @default(0) @db.Decimal(18, 4)
  baseInputCgstAmount           Decimal @default(0) @db.Decimal(18, 4)
  baseInputSgstAmount           Decimal @default(0) @db.Decimal(18, 4)
  baseInputIgstAmount           Decimal @default(0) @db.Decimal(18, 4)
  baseInputCessAmount           Decimal @default(0) @db.Decimal(18, 4)
  baseOtherRecoverableTaxAmount Decimal @default(0) @db.Decimal(18, 4)
  baseNonRecoverableTaxAmount   Decimal @default(0) @db.Decimal(18, 4)
  baseFreightAmount             Decimal @default(0) @db.Decimal(18, 4)
  baseOtherChargeAmount         Decimal @default(0) @db.Decimal(18, 4)
  baseRoundOffAmount            Decimal @default(0) @db.Decimal(18, 4)
  baseInvoiceGrandTotal         Decimal @default(0) @db.Decimal(18, 4)
  baseTdsBaseAmount             Decimal @default(0) @db.Decimal(18, 4)
  baseTdsAmount                 Decimal @default(0) @db.Decimal(18, 4)
  baseVendorPayableAmount       Decimal @default(0) @db.Decimal(18, 4)

  vendorPayableAccountId       String?
  inputCgstAccountId           String?
  inputSgstAccountId           String?
  inputIgstAccountId           String?
  inputCessAccountId           String?
  otherRecoverableTaxAccountId String?
  nonRecoverableTaxAccountId   String?
  tdsPayableAccountId          String?
  roundOffAccountId            String?

  paymentTermsDaysSnapshot Int?
  paymentTermsSnapshot     String? @db.VarChar(200)

  approvalRequired  Boolean @default(false)
  approvalRequestId String? @unique

  calculationVersion        Int   @default(1)
  /// Authoritative draft request inputs for re-validation (Phase 4A3).
  calculationContext        Json?
  calculationSnapshot       Json?
  accountingPreviewSnapshot Json?

  accountingVoucherId String? @unique
  postingEventId      String? @unique

  submittedAt            DateTime?
  submittedBy            String?
  approvedAt             DateTime?
  approvedBy             String?
  rejectedAt             DateTime?
  rejectedBy             String?
  readyToPostAt          DateTime?
  readyToPostBy          String?
  postedAt               DateTime?
  postedBy               String?
  cancelledAt            DateTime?
  cancelledBy            String?
  cancellationReason     String?   @db.VarChar(500)
  reversedAt             DateTime?
  reversedBy             String?
  reversalDate           DateTime? @db.Date
  reversalReason         String?   @db.VarChar(500)
  reversalVoucherId      String?   @unique
  reversalPostingEventId String?   @unique

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant               Tenant                  @relation(fields: [tenantId], references: [id])
  legalEntity          LegalEntity             @relation(fields: [legalEntityId], references: [id])
  branch               Branch?                 @relation(fields: [branchId], references: [id])
  financialYear        FinancialYear           @relation(fields: [financialYearId], references: [id])
  accountingVoucher    AccountingVoucher?      @relation(fields: [accountingVoucherId], references: [id])
  postingEvent         PostingEvent?           @relation(fields: [postingEventId], references: [id])
  reversalVoucher      AccountingVoucher?      @relation("VendorInvoiceReversalVoucher", fields: [reversalVoucherId], references: [id])
  reversalPostingEvent PostingEvent?           @relation("VendorInvoiceReversalPostingEvent", fields: [reversalPostingEventId], references: [id])
  approvalRequest      FinanceApprovalRequest? @relation(fields: [approvalRequestId], references: [id])

  vendorPayableAccount       Account? @relation("VendorInvoicePayableAccount", fields: [vendorPayableAccountId], references: [id])
  inputCgstAccount           Account? @relation("VendorInvoiceInputCgstAccount", fields: [inputCgstAccountId], references: [id])
  inputSgstAccount           Account? @relation("VendorInvoiceInputSgstAccount", fields: [inputSgstAccountId], references: [id])
  inputIgstAccount           Account? @relation("VendorInvoiceInputIgstAccount", fields: [inputIgstAccountId], references: [id])
  inputCessAccount           Account? @relation("VendorInvoiceInputCessAccount", fields: [inputCessAccountId], references: [id])
  otherRecoverableTaxAccount Account? @relation("VendorInvoiceOtherRecoverableTaxAccount", fields: [otherRecoverableTaxAccountId], references: [id])
  nonRecoverableTaxAccount   Account? @relation("VendorInvoiceNonRecoverableTaxAccount", fields: [nonRecoverableTaxAccountId], references: [id])
  tdsPayableAccount          Account? @relation("VendorInvoiceTdsPayableAccount", fields: [tdsPayableAccountId], references: [id])
  roundOffAccount            Account? @relation("VendorInvoiceRoundOffAccount", fields: [roundOffAccountId], references: [id])

  lines           VendorInvoiceLine[]
  sourceLinks     VendorInvoiceSourceLink[]
  /// Reverse of PayableOpenItem.sourceVendorInvoiceId (FK lives on open item).
  payableOpenItem PayableOpenItem?

  @@unique([tenantId, draftReference], map: "vend_inv_tenant_draft_ref_key")
  @@unique([tenantId, legalEntityId, vendorInvoiceNumber], map: "vend_inv_tenant_le_number_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId])
  @@index([tenantId, legalEntityId, status])
  @@index([tenantId, legalEntityId, vendorId])
  @@index([tenantId, legalEntityId, supplierInvoiceDate])
  @@index([tenantId, legalEntityId, dueDate])
  @@index([tenantId, legalEntityId, financialYearId])
  @@index([tenantId, legalEntityId, vendorId, supplierInvoiceNumberNormalized], map: "vend_inv_supplier_num_idx")
  @@index([financialYearId])
  @@index([branchId])
  @@index([createdBy])
  @@map("vendor_invoices")
}

