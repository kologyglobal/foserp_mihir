// ─── Bank & Cash Phase 5B2 — cheque management ─────────────────────────────

enum TreasuryChequeDirection {
  ISSUED
  RECEIVED
}

enum TreasuryChequeStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  READY
  ISSUED
  DEPOSITED
  CLEARED
  BOUNCED
  STOPPED
  CANCELLED
  REVERSED
}

enum TreasuryChequeAccountingMode {
  TRACK_ONLY
  POST_ON_LIFECYCLE
}

/// Cheque register — physical instrument lifecycle (issued/received → deposited/cleared/bounced/stopped),
/// optionally posting GL (POST_ON_LIFECYCLE) or purely tracking status (TRACK_ONLY, e.g. already posted via
/// a linked CustomerReceipt/VendorPayment). No MT940/CAMT, bank APIs, FX/intercompany (Phase 5B2 scope).
model TreasuryCheque {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  treasuryAccountId      String
  glAccountId            String
  counterpartGlAccountId String?

  direction      TreasuryChequeDirection
  status         TreasuryChequeStatus         @default(DRAFT)
  accountingMode TreasuryChequeAccountingMode @default(POST_ON_LIFECYCLE)

  draftReference       String  @db.VarChar(64)
  chequeRegisterNumber String? @db.VarChar(64)

  chequeNumber String   @db.VarChar(32)
  chequeDate   DateTime @db.Date
  bankName     String?  @db.VarChar(200)
  branchName   String?  @db.VarChar(200)
  ifsc         String?  @db.VarChar(20)

  payeeOrDrawerName String @db.VarChar(200)

  currencyCode String  @default("INR") @db.VarChar(8)
  exchangeRate Decimal @default(1) @db.Decimal(18, 8)
  amount       Decimal @db.Decimal(18, 4)
  baseAmount   Decimal @db.Decimal(18, 4)

  isPdc           Boolean   @default(false)
  pdcMaturityDate DateTime? @db.Date

  depositDate   DateTime? @db.Date
  clearanceDate DateTime? @db.Date
  bounceDate    DateTime? @db.Date
  bounceReason  String?   @db.VarChar(500)
  stopReason    String?   @db.VarChar(500)

  /// Optional link to an already-posted CustomerReceipt (RECEIVED) — forces TRACK_ONLY.
  customerReceiptId String?
  /// Optional link to an already-posted VendorPayment (ISSUED) — forces TRACK_ONLY.
  vendorPaymentId   String?

  narration    String? @db.Text
  internalNote String? @db.Text

  approvalRequired  Boolean @default(false)
  approvalRequestId String?

  calculationVersion        Int   @default(1)
  validationSnapshot        Json?
  accountingPreviewSnapshot Json?

  postingEventId         String?
  voucherId              String?
  reversalPostingEventId String?
  reversalVoucherId      String?

  uniquenessKey String? @unique @db.VarChar(300)

  submittedAt     DateTime?
  submittedById   String?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?   @db.VarChar(500)

  readyAt   DateTime?
  readyById String?

  issuedAt      DateTime?
  issuedById    String?
  depositedAt   DateTime?
  depositedById String?
  clearedAt     DateTime?
  clearedById   String?
  bouncedAt     DateTime?
  bouncedById   String?
  stoppedAt     DateTime?
  stoppedById   String?

  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?   @db.VarChar(500)

  reversedAt     DateTime?
  reversedById   String?
  reversalDate   DateTime? @db.Date
  reversalReason String?   @db.VarChar(500)

  createdById String
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity     @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount @relation(fields: [treasuryAccountId], references: [id])

  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "treas_chq_le_status_idx")
  @@index([treasuryAccountId])
  @@index([chequeNumber])
  @@index([draftReference])
  @@map("treasury_cheques")
}

// ─── Bank & Cash Phase 5B3 — treasury adjustments, posting rules, standing instructions, books ────

/// Bank-originated (or standing-instruction-originated) GL adjustment: charges, interest, direct
/// debit/credit, collection/merchant fees, and other bank-side movements that are not cheques or
/// internal transfers. No AR/AP open items, no FX revaluation, no MT940/bank APIs (Phase 5B3 scope).
enum TreasuryAdjustmentType {
  BANK_CHARGES
  BANK_INTEREST_INCOME
  BANK_INTEREST_EXPENSE
  COLLECTION_FEE
  MERCHANT_FEE
  DIRECT_DEBIT
  DIRECT_CREDIT
  STANDING_INSTRUCTION_DEBIT
  STANDING_INSTRUCTION_CREDIT
  GST_ADJUSTMENT
  /// Requires narration + at least one explicit offset line + mandatory approval.
  OTHER_BANK_DEBIT
  /// Requires narration + at least one explicit offset line + mandatory approval.
  OTHER_BANK_CREDIT
}

/// Direction of the bank leg — BANK_DEBIT = money leaves the bank account (bank GL credited);
/// BANK_CREDIT = money enters the bank account (bank GL debited). Fixed per adjustmentType except
/// GST_ADJUSTMENT, where the caller supplies it explicitly (see §18 direction table in architecture doc).
enum TreasuryAdjustmentDirection {
  BANK_DEBIT
  BANK_CREDIT
}

enum TreasuryAdjustmentStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  READY_TO_POST
  POSTED
  CANCELLED
  REVERSED
}

enum TreasuryAdjustmentSourceMode {
  MANUAL
  BANK_STATEMENT
  STANDING_INSTRUCTION
}

enum TreasuryAdjustmentLineType {
  EXPENSE
  INCOME
  ASSET
  LIABILITY
  RECOVERABLE_TAX
  NON_RECOVERABLE_TAX
  TDS_RECEIVABLE
  ROUND_OFF
  OTHER
}

enum GstTreatment {
  GST_APPLICABLE
  GST_NOT_APPLICABLE
  GST_NON_RECOVERABLE
  GST_PENDING_REVIEW
}

enum TdsTreatment {
  TDS_NOT_APPLICABLE
  TDS_DEDUCTED
  TDS_PENDING_REVIEW
}

enum StandingInstructionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum Frequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum AmountMode {
  FIXED
  VARIABLE
}

enum ExecutionStatus {
  PENDING
  DRAFT_CREATED
  SKIPPED
  FAILED
}

/// Deterministic keyword/rule scorer configuration for classifying bank statement lines into a
/// TreasuryAdjustmentType + line template. No AI/ML — pure rule matching (Phase 5B3 §52-57).
model BankPostingRule {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  /// Null = applies to all treasury accounts for the legal entity.
  treasuryAccountId String?

  name        String  @db.VarChar(200)
  description String? @db.Text

  isActive Boolean @default(true)
  /// Lower value = higher priority when multiple rules match; ties are ambiguous (BANK_POSTING_RULE_AMBIGUOUS).
  priority Int     @default(100)

  /// Null = matches either direction.
  direction       BankStatementLineDirection?
  /// Array of case-insensitive keyword strings; a rule scores when any keyword is found in the statement line description.
  keywordPatterns Json
  minAmount       Decimal?                    @db.Decimal(18, 4)
  maxAmount       Decimal?                    @db.Decimal(18, 4)

  adjustmentType   TreasuryAdjustmentType
  /// Template for the generated TreasuryAdjustment offset line(s): [{ lineType, accountId, gstTreatment, gstRate, tdsTreatment, tdsRate, description }].
  lineTemplateJson Json

  matchCount    Int       @default(0)
  lastMatchedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity      @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount? @relation(fields: [treasuryAccountId], references: [id])

  @@index([tenantId])
  @@index([tenantId, legalEntityId, isActive, priority], map: "bank_posting_rule_scope_idx")
  @@map("bank_posting_rules")
}

/// Recurring bank-side instruction definition. Generation is draft-only and idempotent per due
/// date — standing instructions never auto-post (Phase 5B3).
model StandingInstruction {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  treasuryAccountId String

  name        String  @db.VarChar(200)
  description String? @db.Text

  status StandingInstructionStatus @default(ACTIVE)

  adjustmentType TreasuryAdjustmentType
  direction      TreasuryAdjustmentDirection

  frequency   Frequency
  amountMode  AmountMode
  /// Required when amountMode = FIXED; ignored (user fills in at draft-generation review) when VARIABLE.
  fixedAmount Decimal?   @db.Decimal(18, 4)

  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  nextDueDate DateTime  @db.Date

  /// Template for the generated TreasuryAdjustment offset line(s) — same shape as BankPostingRule.lineTemplateJson.
  lineTemplateJson  Json
  narrationTemplate String? @db.VarChar(500)

  lastGeneratedAt      DateTime?
  lastGeneratedForDate DateTime? @db.Date

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity     @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount @relation(fields: [treasuryAccountId], references: [id])

  executions StandingInstructionExecution[]

  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "standing_instr_le_status_idx")
  @@index([nextDueDate])
  @@map("standing_instructions")
}

/// One row per due-date generation attempt — the idempotency ledger for `generate-due-drafts`.
model StandingInstructionExecution {
  id                    String @id @default(uuid())
  tenantId              String
  standingInstructionId String

  dueDate DateTime        @db.Date
  status  ExecutionStatus @default(PENDING)

  /// Set once a DRAFT TreasuryAdjustment is created for this due date.
  treasuryAdjustmentId String? @unique

  failureReason String? @db.VarChar(500)

  generatedAt   DateTime?
  generatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  standingInstruction StandingInstruction @relation(fields: [standingInstructionId], references: [id])

  @@unique([standingInstructionId, dueDate], map: "standing_instr_exec_due_key")
  @@index([tenantId])
  @@map("standing_instruction_executions")
}

/// Bank charges/interest/direct debit-credit and other bank-originated adjustments. The bank leg
/// (Dr/Cr treasury account GL) is always system-generated from the offset lines below — never a
/// user-entered line. No AR/AP open items, no FX, no MT940/bank APIs (Phase 5B3 scope).
model TreasuryAdjustment {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  treasuryAccountId String
  glAccountId       String

  adjustmentType TreasuryAdjustmentType
  direction      TreasuryAdjustmentDirection
  status         TreasuryAdjustmentStatus     @default(DRAFT)
  sourceMode     TreasuryAdjustmentSourceMode @default(MANUAL)

  draftReference   String  @db.VarChar(64)
  adjustmentNumber String? @db.VarChar(64)

  adjustmentDate DateTime @db.Date

  currencyCode   String  @default("INR") @db.VarChar(8)
  exchangeRate   Decimal @default(1) @db.Decimal(18, 8)
  /// System-computed balancing amount for the bank leg (transaction currency).
  bankAmount     Decimal @db.Decimal(18, 4)
  baseBankAmount Decimal @db.Decimal(18, 4)

  /// Statement-led creation (Phase 5B3 §-atomic post+recon). One statement line → at most one adjustment.
  bankStatementLineId            String? @unique
  /// Standing-instruction-led creation. One execution → at most one adjustment.
  standingInstructionExecutionId String? @unique

  narration    String? @db.Text
  internalNote String? @db.Text

  approvalRequired  Boolean @default(false)
  approvalRequestId String?

  calculationVersion        Int   @default(1)
  validationSnapshot        Json?
  accountingPreviewSnapshot Json?

  postingEventId String?
  voucherId      String?

  /// Set when the statement-led post also creates a bank-reconciliation match in the same transaction.
  reconciliationMatchId String?

  reversalPostingEventId String?
  reversalVoucherId      String?

  uniquenessKey String? @unique @db.VarChar(300)

  submittedAt     DateTime?
  submittedById   String?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?   @db.VarChar(500)

  readyAt   DateTime?
  readyById String?

  postedAt   DateTime?
  postedById String?

  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?   @db.VarChar(500)

  reversedAt     DateTime?
  reversedById   String?
  reversalDate   DateTime? @db.Date
  reversalReason String?   @db.VarChar(500)

  createdById String
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  legalEntity       LegalEntity        @relation(fields: [legalEntityId], references: [id])
  treasuryAccount   TreasuryAccount    @relation(fields: [treasuryAccountId], references: [id])
  bankStatementLine BankStatementLine? @relation(fields: [bankStatementLineId], references: [id])

  lines TreasuryAdjustmentLine[]

  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "treas_adj_le_status_idx")
  @@index([treasuryAccountId])
  @@index([draftReference])
  @@map("treasury_adjustments")
}

/// One offset (non-bank) leg of a TreasuryAdjustment. The bank leg itself is derived, not stored here.
model TreasuryAdjustmentLine {
  id                   String @id @default(uuid())
  tenantId             String
  treasuryAdjustmentId String

  lineNumber Int
  lineType   TreasuryAdjustmentLineType
  accountId  String

  description String? @db.VarChar(500)
  /// Always positive except for ROUND_OFF, where sign determines debit (>=0) vs credit (<0) contribution.
  amount      Decimal @db.Decimal(18, 4)

  /// Classifies whether GST applies to this economic line — actual tax amounts are separate RECOVERABLE_TAX /
  /// NON_RECOVERABLE_TAX lines (either user-added or auto-derived from gstRate during calculation).
  gstTreatment GstTreatment @default(GST_NOT_APPLICABLE)
  gstRate      Decimal?     @db.Decimal(5, 2)

  tdsTreatment TdsTreatment @default(TDS_NOT_APPLICABLE)
  tdsRate      Decimal?     @db.Decimal(5, 2)

  narration String? @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  treasuryAdjustment TreasuryAdjustment @relation(fields: [treasuryAdjustmentId], references: [id], onDelete: Cascade)

  @@unique([treasuryAdjustmentId, lineNumber], map: "treas_adj_line_num_key")
  @@index([tenantId])
  @@map("treasury_adjustment_lines")
}

// ─── Fixed Assets Phase 1 ─────────────────────────────────────────────────────

enum FixedAssetStatus {
  DRAFT
  PENDING_CAPITALIZATION
  ACTIVE
  IDLE
  FULLY_DEPRECIATED
  DISPOSED
  CANCELLED
}

enum FixedAssetDepreciationMethod {
  STRAIGHT_LINE
}

/// Phase 2 simple dispose — full asset exit only (no partial / multi-asset batch).
enum FixedAssetDisposalType {
  SALE
  SCRAP
  WRITE_OFF
}

/// Phase FA2 disposal document workflow (mirrors treasury adjustment statuses).
enum FixedAssetDisposalStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  READY_TO_POST
  POSTED
  CANCELLED
  REVERSED
}

enum FixedAssetDepreciationRunStatus {
  DRAFT
  PREVIEWED
  POSTED
  CANCELLED
}

/// Asset category master — GL accounts + straight-line defaults (Phase FA1).
model FixedAssetCategory {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  code String @db.VarChar(32)
  name String @db.VarChar(200)

  depreciationMethod FixedAssetDepreciationMethod @default(STRAIGHT_LINE)
  usefulLifeYears    Int
  residualPercent    Decimal                      @db.Decimal(5, 2)

  assetAccountId      String
  accumDepAccountId   String
  depExpenseAccountId String

  isActive Boolean @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity       LegalEntity @relation(fields: [legalEntityId], references: [id])
  assetAccount      Account     @relation("FaCategoryAssetAccount", fields: [assetAccountId], references: [id])
  accumDepAccount   Account     @relation("FaCategoryAccumDepAccount", fields: [accumDepAccountId], references: [id])
  depExpenseAccount Account     @relation("FaCategoryDepExpenseAccount", fields: [depExpenseAccountId], references: [id])

  assets FixedAsset[]

  @@unique([legalEntityId, code], map: "fa_category_le_code_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId, isActive], map: "fa_category_le_active_idx")
  @@map("fixed_asset_categories")
}

/// Fixed asset register — capitalize-ready draft through active / fully depreciated (Phase FA1).
model FixedAsset {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String
  categoryId    String

  assetNumber    String  @db.VarChar(64)
  draftReference String? @db.VarChar(64)
  name           String  @db.VarChar(200)

  status FixedAssetStatus @default(DRAFT)

  acquisitionDate    DateTime  @db.Date
  capitalizationDate DateTime? @db.Date

  acquisitionCost         Decimal                      @db.Decimal(18, 4)
  residualValue           Decimal                      @default(0) @db.Decimal(18, 4)
  usefulLifeYears         Int
  depreciationMethod      FixedAssetDepreciationMethod @default(STRAIGHT_LINE)
  accumulatedDepreciation Decimal                      @default(0) @db.Decimal(18, 4)
  netBookValue            Decimal                      @db.Decimal(18, 4)

  location   String? @db.VarChar(200)
  plant      String? @db.VarChar(200)
  department String? @db.VarChar(200)
  custodian  String? @db.VarChar(200)

  serialNumber String? @db.VarChar(100)
  manufacturer String? @db.VarChar(200)
  model        String? @db.VarChar(200)
  vendorName   String? @db.VarChar(200)
  notes        String? @db.Text
  currencyCode String  @default("INR") @db.VarChar(8)

  capitalizationVoucherId      String?
  capitalizationPostingEventId String? @unique

  capitalizedAt   DateTime?
  capitalizedById String?

  /// Phase 2 — simple full disposal (posted atomically with GL).
  disposalType              FixedAssetDisposalType?
  disposalDate              DateTime?               @db.Date
  disposalProceeds          Decimal?                @db.Decimal(18, 4)
  disposalGainLoss          Decimal?                @db.Decimal(18, 4)
  disposalProceedsAccountId String?
  disposalBuyerName         String?                 @db.VarChar(200)
  disposalReason            String?                 @db.VarChar(1000)
  disposalVoucherId         String?
  disposalPostingEventId    String?                 @unique
  disposedAt                DateTime?
  disposedById              String?

  /// Soft pointer to the current FA2 disposal document (no FK — history via disposalDocuments).
  disposalDocumentId String?

  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant                     Tenant             @relation(fields: [tenantId], references: [id])
  legalEntity                LegalEntity        @relation(fields: [legalEntityId], references: [id])
  category                   FixedAssetCategory @relation(fields: [categoryId], references: [id])
  capitalizationPostingEvent PostingEvent?      @relation("FixedAssetCapitalizationPostingEvent", fields: [capitalizationPostingEventId], references: [id])
  disposalPostingEvent       PostingEvent?      @relation("FixedAssetDisposalPostingEvent", fields: [disposalPostingEventId], references: [id])

  depreciationLines FixedAssetDepreciationLine[]
  transfers         FixedAssetTransfer[]
  disposalDocuments FixedAssetDisposal[]

  @@unique([tenantId, legalEntityId, assetNumber], map: "fa_asset_le_number_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "fa_asset_le_status_idx")
  @@index([categoryId])
  @@map("fixed_assets")
}

/// Phase 3 — intra-LE location/plant/department/custodian transfer (no GL).
enum FixedAssetTransferStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model FixedAssetTransfer {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String
  assetId       String

  transferNumber String   @db.VarChar(64)
  transferDate   DateTime @db.Date

  status FixedAssetTransferStatus @default(DRAFT)

  fromLocation   String? @db.VarChar(200)
  fromPlant      String? @db.VarChar(200)
  fromDepartment String? @db.VarChar(200)
  fromCustodian  String? @db.VarChar(200)

  toLocation   String? @db.VarChar(200)
  toPlant      String? @db.VarChar(200)
  toDepartment String? @db.VarChar(200)
  toCustodian  String? @db.VarChar(200)

  reason String @db.VarChar(1000)

  completedAt   DateTime?
  completedById String?

  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])
  asset       FixedAsset  @relation(fields: [assetId], references: [id])

  @@unique([tenantId, legalEntityId, transferNumber], map: "fa_transfer_le_number_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "fa_transfer_le_status_idx")
  @@index([assetId])
  @@map("fixed_asset_transfers")
}

/// Phase 2 — disposal document (full exit SALE/SCRAP/WRITE_OFF). Partial dispose remains Phase 3+.
model FixedAssetDisposal {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?
  assetId       String

  disposalNumber String? @db.VarChar(64)
  draftReference String  @db.VarChar(64)

  status       FixedAssetDisposalStatus @default(DRAFT)
  disposalType FixedAssetDisposalType
  /// Reserved for Phase 3+; Phase 2 always false (full exit only).
  isPartial    Boolean                  @default(false)

  disposalDate DateTime  @db.Date
  postingDate  DateTime? @db.Date

  currencyCode String @default("INR") @db.VarChar(8)

  /// Sale/scrap consideration before GST (taxable base when GST applies).
  proceeds Decimal @default(0) @db.Decimal(18, 4)

  buyerName String? @db.VarChar(200)
  reason    String  @db.VarChar(1000)

  /// Snapshot of asset status before post (restored on reverse).
  preDisposalAssetStatus FixedAssetStatus?

  acquisitionCostSnapshot         Decimal? @db.Decimal(18, 4)
  accumulatedDepreciationSnapshot Decimal? @db.Decimal(18, 4)
  netBookValueSnapshot            Decimal? @db.Decimal(18, 4)
  disposedCost                    Decimal? @db.Decimal(18, 4)
  disposedAccumDep                Decimal? @db.Decimal(18, 4)
  disposedNbv                     Decimal? @db.Decimal(18, 4)
  gainLoss                        Decimal? @db.Decimal(18, 4)

  proceedsTreasuryAccountId String?
  proceedsAccountId         String?

  gstApplicable  Boolean @default(false)
  placeOfSupply  String? @db.VarChar(8)
  partyGstin     String? @db.VarChar(15)
  taxableAmount  Decimal @default(0) @db.Decimal(18, 4)
  cgstAmount     Decimal @default(0) @db.Decimal(18, 4)
  sgstAmount     Decimal @default(0) @db.Decimal(18, 4)
  igstAmount     Decimal @default(0) @db.Decimal(18, 4)
  cessAmount     Decimal @default(0) @db.Decimal(18, 4)
  totalTaxAmount Decimal @default(0) @db.Decimal(18, 4)
  totalProceeds  Decimal @default(0) @db.Decimal(18, 4)

  approvalRequired  Boolean @default(false)
  approvalRequestId String?

  postingEventId String? @unique
  voucherId      String?

  reversalPostingEventId String? @unique
  reversalVoucherId      String?

  uniquenessKey String? @unique @db.VarChar(300)

  validationSnapshot        Json?
  accountingPreviewSnapshot Json?

  submittedAt     DateTime?
  submittedById   String?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?   @db.VarChar(500)

  readyAt   DateTime?
  readyById String?

  postedAt   DateTime?
  postedById String?

  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?   @db.VarChar(500)

  reversedAt     DateTime?
  reversedById   String?
  reversalDate   DateTime? @db.Date
  reversalReason String?   @db.VarChar(500)

  createdById String
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                  Tenant           @relation(fields: [tenantId], references: [id])
  legalEntity             LegalEntity      @relation(fields: [legalEntityId], references: [id])
  asset                   FixedAsset       @relation(fields: [assetId], references: [id])
  proceedsTreasuryAccount TreasuryAccount? @relation(fields: [proceedsTreasuryAccountId], references: [id])
  postingEvent            PostingEvent?    @relation("FixedAssetDisposalDocumentPostingEvent", fields: [postingEventId], references: [id])
  reversalPostingEvent    PostingEvent?    @relation("FixedAssetDisposalReversalPostingEvent", fields: [reversalPostingEventId], references: [id])

  @@unique([tenantId, legalEntityId, disposalNumber], map: "fa_disposal_le_number_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "fa_disposal_le_status_idx")
  @@index([assetId])
  @@index([draftReference])
  @@map("fixed_asset_disposals")
}

/// Monthly depreciation run header (Phase FA1 — straight-line only).
model FixedAssetDepreciationRun {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  runNumber   String    @db.VarChar(64)
  /// Calendar period key YYYY-MM (one posted run per LE per period).
  periodKey   String    @db.VarChar(7)
  periodFrom  DateTime  @db.Date
  periodTo    DateTime  @db.Date
  runDate     DateTime  @db.Date
  postingDate DateTime? @db.Date

  status FixedAssetDepreciationRunStatus @default(DRAFT)

  totalDepreciation Decimal @default(0) @db.Decimal(18, 4)
  assetCount        Int     @default(0)

  voucherId      String?
  postingEventId String? @unique

  postedAt   DateTime?
  postedById String?

  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  legalEntity  LegalEntity   @relation(fields: [legalEntityId], references: [id])
  postingEvent PostingEvent? @relation("FixedAssetDepreciationPostingEvent", fields: [postingEventId], references: [id])

  lines FixedAssetDepreciationLine[]

  @@unique([tenantId, legalEntityId, periodKey], map: "fa_dep_run_le_period_key")
  @@unique([tenantId, legalEntityId, runNumber], map: "fa_dep_run_le_number_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "fa_dep_run_le_status_idx")
  @@map("fixed_asset_depreciation_runs")
}

model FixedAssetDepreciationLine {
  id       String @id @default(uuid())
  tenantId String
  runId    String
  assetId  String

  lineNumber Int

  assetNumber  String @db.VarChar(64)
  assetName    String @db.VarChar(200)
  categoryName String @db.VarChar(200)

  openingNbv              Decimal @db.Decimal(18, 4)
  depreciationAmount      Decimal @db.Decimal(18, 4)
  closingNbv              Decimal @db.Decimal(18, 4)
  accumulatedDepreciation Decimal @db.Decimal(18, 4)

  depExpenseAccountId String
  accumDepAccountId   String

  createdAt DateTime @default(now())

  tenant Tenant                    @relation(fields: [tenantId], references: [id])
  run    FixedAssetDepreciationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  asset  FixedAsset                @relation(fields: [assetId], references: [id])

  @@unique([runId, lineNumber], map: "fa_dep_line_num_key")
  @@unique([runId, assetId], map: "fa_dep_line_asset_key")
  @@index([tenantId])
  @@index([assetId])
  @@map("fixed_asset_depreciation_lines")
}

// ─── Finance Phase 5C1 — Treasury day-close controls ─────────────────────────

enum TreasuryDayCloseStatus {
  OPEN
  REVIEWED
  CLOSED
}

/// Soft day-close acknowledgement for bank/cash closing controls. Does not lock GL periods
/// (period close remains separate). Snapshot balances are advisory; live position APIs remain source of truth.
model TreasuryDayClose {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  closeDate DateTime               @db.Date
  status    TreasuryDayCloseStatus @default(OPEN)

  bookBankBalance    Decimal @db.Decimal(18, 4)
  bookCashBalance    Decimal @db.Decimal(18, 4)
  availableLiquidity Decimal @db.Decimal(18, 4)
  currencyCode       String  @default("INR") @db.VarChar(8)

  /// Snapshot of closing-control checklist at review/close time.
  checklistJson Json

  notes String? @db.VarChar(1000)

  reviewedAt   DateTime?
  reviewedById String?
  closedAt     DateTime?
  closedById   String?
  reopenReason String?   @db.VarChar(500)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])

  @@unique([tenantId, legalEntityId, closeDate], map: "treasury_day_close_date_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "treasury_day_close_status_idx")
  @@map("treasury_day_closes")
}

// ─── Finance Phase 5D1 — Bank connector scaffold (no live bank calls) ─────────

enum BankConnectorProvider {
  MANUAL_FILE
  GENERIC_REST
  MT940_SFTP
  CAMT_SFTP
  OPEN_BANKING
}

enum BankConnectorStatus {
  DISABLED
  ENABLED
  ERROR
}

enum BankConnectorProbeStatus {
  NOT_CONFIGURED
  NOT_IMPLEMENTED
  PROVIDER_DISABLED
  OK
  ERROR
}

/// Bank API / PSD2 / H2H connector configuration scaffold.
/// Phase 5D1 stores non-secret config only — credentials via secrets manager in a later phase.
/// testConnection / sync never invent statement data or mark the connector as live-connected.
model BankConnector {
  id                String @id @default(uuid())
  tenantId          String
  legalEntityId     String
  treasuryAccountId String

  code     String                @db.VarChar(32)
  name     String                @db.VarChar(200)
  provider BankConnectorProvider
  status   BankConnectorStatus   @default(DISABLED)

  baseUrl      String? @db.VarChar(500)
  scheduleCron String? @db.VarChar(64)

  /// Non-secret config only (expectedFormat MT940/CAMT, remote paths, etc.). Never store secrets here.
  configJson Json?

  lastTestAt      DateTime?
  lastTestStatus  BankConnectorProbeStatus?
  lastTestMessage String?                   @db.VarChar(500)

  lastSyncAt      DateTime?
  lastSyncStatus  BankConnectorProbeStatus?
  lastSyncMessage String?                   @db.VarChar(500)

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity            @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount        @relation(fields: [treasuryAccountId], references: [id])
  consents        BankConnectorConsent[]

  @@unique([tenantId, code], map: "bank_connector_tenant_code_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "bank_connector_le_status_idx")
  @@index([tenantId, treasuryAccountId], map: "bank_connector_acct_idx")
  @@map("bank_connectors")
}

enum BankConnectorConsentStatus {
  DRAFT
  PENDING
  AUTHORIZED
  REVOKED
  EXPIRED
}

/// Open Banking consent scaffold (Phase 5D3) — no live token exchange in this phase.
model BankConnectorConsent {
  id               String                     @id @default(uuid())
  tenantId         String
  connectorId      String
  status           BankConnectorConsentStatus @default(DRAFT)
  authorizationUrl String?                    @db.VarChar(1000)
  state            String?                    @db.VarChar(200)
  redirectUri      String?                    @db.VarChar(500)
  expiresAt        DateTime?
  tokenCiphertext  String?                    @db.Text
  revokedAt        DateTime?
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  connector BankConnector @relation(fields: [connectorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, connectorId], map: "bank_connector_consent_connector_idx")
  @@index([tenantId, state], map: "bank_connector_consent_state_idx")
  @@map("bank_connector_consents")
}

// ─── Finance Budgeting Phase 1 — versions, annual lines, budget vs actual ─────

enum BudgetVersionStatus {
  DRAFT
  IN_PREPARATION
  PENDING_APPROVAL
  APPROVED
  LOCKED
  SUPERSEDED
  CANCELLED
}

enum BudgetVersionKind {
  ORIGINAL
  REVISED
  FORECAST_1
  FORECAST_2
  BEST_CASE
  EXPECTED_CASE
  WORST_CASE
}

model BudgetVersion {
  id                 String              @id @default(uuid())
  tenantId           String
  legalEntityId      String
  code               String              @db.VarChar(32)
  name               String              @db.VarChar(200)
  kind               BudgetVersionKind   @default(ORIGINAL)
  status             BudgetVersionStatus @default(DRAFT)
  financialYearLabel String              @db.VarChar(16)
  fyStartDate        DateTime            @db.Date
  fyEndDate          DateTime            @db.Date
  currencyCode       String              @default("INR") @db.VarChar(8)
  notes              String?             @db.VarChar(1000)
  isPrimary          Boolean             @default(false)

  submittedAt DateTime?
  submittedBy String?
  approvedAt  DateTime?
  approvedBy  String?
  lockedAt    DateTime?
  lockedBy    String?

  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity  @relation(fields: [legalEntityId], references: [id])
  lines       BudgetLine[]

  @@unique([tenantId, code], map: "budget_version_tenant_code_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId, status], map: "budget_version_le_status_idx")
  @@map("budget_versions")
}

model BudgetLine {
  id           String  @id @default(uuid())
  tenantId     String
  versionId    String
  accountId    String
  costCentreId String?

  amountApr Decimal @default(0) @db.Decimal(18, 4)
  amountMay Decimal @default(0) @db.Decimal(18, 4)
  amountJun Decimal @default(0) @db.Decimal(18, 4)
  amountJul Decimal @default(0) @db.Decimal(18, 4)
  amountAug Decimal @default(0) @db.Decimal(18, 4)
  amountSep Decimal @default(0) @db.Decimal(18, 4)
  amountOct Decimal @default(0) @db.Decimal(18, 4)
  amountNov Decimal @default(0) @db.Decimal(18, 4)
  amountDec Decimal @default(0) @db.Decimal(18, 4)
  amountJan Decimal @default(0) @db.Decimal(18, 4)
  amountFeb Decimal @default(0) @db.Decimal(18, 4)
  amountMar Decimal @default(0) @db.Decimal(18, 4)

  notes     String?  @db.VarChar(500)
  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  version BudgetVersion @relation(fields: [versionId], references: [id])
  account Account       @relation(fields: [accountId], references: [id])

  @@unique([versionId, accountId], map: "budget_line_version_account_key")
  @@index([tenantId])
  @@index([tenantId, versionId], map: "budget_line_version_idx")
  @@index([accountId])
  @@map("budget_lines")
}

// ─── Manufacturing Phase 7D — Reporting foundation (saved views + exception centre) ─
// Additive only. Reports themselves are computed on read from existing operational
// tables (ProductionOrder, StageLedger, Quality, Dispatch 7C0, etc.) — no new ledger
// or cost data introduced here. Soft String references for userId (no FK to User),
// matching the rest of the schema's createdBy/updatedBy convention.

/// Per-user saved filter/column/sort preset for a given report key. One personal
/// default per (tenantId, userId, reportKey) enforced in the service layer.
model SavedReportView {
  id                  String    @id @default(uuid())
  tenantId            String
  userId              String
  reportKey           String    @db.VarChar(100)
  name                String    @db.VarChar(150)
  description         String?   @db.VarChar(500)
  filtersJson         Json
  sortingJson         Json?
  groupingJson        Json?
  visibleColumnsJson  Json?
  pageSize            Int?
  chartPreferenceJson Json?
  isDefault           Boolean   @default(false)
  /// Shared views are visible to other users on the same reportKey (requires
  /// manufacturing.reports.shared_views to create); optionally scoped to a role.
  isShared            Boolean   @default(false)
  sharedRoleId        String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, userId, reportKey, name], map: "saved_report_view_tenant_user_key_name_key")
  @@index([tenantId, userId, reportKey], map: "saved_report_view_tenant_user_key_idx")
  @@index([tenantId, reportKey, isShared], map: "saved_report_view_tenant_key_shared_idx")
  @@map("saved_report_views")
}

enum OperationalExceptionResolutionStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

/// Ack/assign/resolve overlay for operational exceptions that are otherwise derived
/// live from source tables (overdue WOs, material shortages, open issues, pending
/// inspections, open NCRs, overdue job work, unfulfilled SO lines). exceptionKey is a
/// deterministic key (e.g. `WO_OVERDUE:<productionOrderId>`) computed by the exception
/// centre service — this table never becomes the source of truth for "is it open".
model OperationalExceptionAction {
  id               String                               @id @default(uuid())
  tenantId         String
  exceptionKey     String                               @db.VarChar(200)
  sourceType       String                               @db.VarChar(64)
  sourceId         String
  assignedTo       String?
  acknowledgedBy   String?
  acknowledgedAt   DateTime?
  resolutionStatus OperationalExceptionResolutionStatus @default(OPEN)
  resolutionNote   String?                              @db.VarChar(1000)
  resolvedBy       String?
  resolvedAt       DateTime?
  createdAt        DateTime                             @default(now())
  updatedAt        DateTime                             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, exceptionKey], map: "op_exception_action_tenant_key_key")
  @@index([tenantId, resolutionStatus], map: "op_exception_action_tenant_status_idx")
  @@map("operational_exception_actions")
}
