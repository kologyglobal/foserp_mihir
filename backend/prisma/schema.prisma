  @@unique([deliveryChallanId, lineNumber], map: "delivery_challan_line_challan_line_uidx")
  @@index([tenantId, deliveryChallanId], map: "delivery_challan_line_tenant_challan_idx")
  @@index([tenantId, outboundDispatchLineId], map: "delivery_challan_line_tenant_ob_line_idx")
  @@index([tenantId, salesOrderLineId], map: "delivery_challan_line_tenant_so_line_idx")
  @@index([tenantId, itemId], map: "delivery_challan_line_tenant_item_idx")
  @@map("delivery_challan_lines")
}

model DeliveryChallanPackage {
  id                    String                           @id @default(uuid())
  tenantId              String
  deliveryChallanId     String
  packageId             String
  packageNumberSnapshot String                           @db.VarChar(64)
  packageTypeSnapshot   String?                          @db.VarChar(64)
