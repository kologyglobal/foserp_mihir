/// Optional soft links to Purchase/Contract/Project documents — no FK to deferred Purchase models.
model VendorInvoiceSourceLink {
  id              String @id @default(uuid())
  tenantId        String
  legalEntityId   String
  vendorInvoiceId String

  sourceType                   VendorInvoiceSourceLinkType
  sourceDocumentId             String
  sourceDocumentNumberSnapshot String?                     @db.VarChar(64)
  sourceDocumentDateSnapshot   DateTime?                   @db.Date
  metadata                     Json?

  createdAt DateTime @default(now())

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  legalEntity   LegalEntity   @relation(fields: [legalEntityId], references: [id])
  vendorInvoice VendorInvoice @relation(fields: [vendorInvoiceId], references: [id], onDelete: Cascade)

  @@unique([vendorInvoiceId, sourceType, sourceDocumentId], map: "vend_inv_src_link_key")
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([vendorInvoiceId])
  @@index([sourceType, sourceDocumentId], map: "vend_inv_src_doc_idx")
  @@map("vendor_invoice_source_links")
}

/// AP subledger open item — separate from ReceivableOpenItem.
/// Future invariants (service-enforced, not DB triggers):
///   outstanding = original − allocated − adjusted − writtenOff (all >= 0)
/// Vendor invoice posting creates side=CREDIT, documentType=VENDOR_INVOICE.
model PayableOpenItem {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  /// MasterVendor.id — soft reference.
  vendorId           String
  vendorCodeSnapshot String @db.VarChar(32)
  vendorNameSnapshot String @db.VarChar(300)

  side         PayableOpenItemSide
  documentType PayableOpenItemDocumentType

  documentId     String
  documentNumber String    @db.VarChar(64)
  documentDate   DateTime  @db.Date
  postingDate    DateTime  @db.Date
  dueDate        DateTime? @db.Date

  currencyCode String  @default("INR") @db.VarChar(8)
  exchangeRate Decimal @default(1) @db.Decimal(18, 8)

  originalAmount    Decimal @db.Decimal(18, 4)
  allocatedAmount   Decimal @default(0) @db.Decimal(18, 4)
  adjustedAmount    Decimal @default(0) @db.Decimal(18, 4)
  writtenOffAmount  Decimal @default(0) @db.Decimal(18, 4)
  outstandingAmount Decimal @db.Decimal(18, 4)

  baseOriginalAmount    Decimal @db.Decimal(18, 4)
  baseAllocatedAmount   Decimal @default(0) @db.Decimal(18, 4)
  baseAdjustedAmount    Decimal @default(0) @db.Decimal(18, 4)
  baseWrittenOffAmount  Decimal @default(0) @db.Decimal(18, 4)
  baseOutstandingAmount Decimal @db.Decimal(18, 4)

  status     PayableOpenItemStatus @default(OPEN)
  isDisputed Boolean               @default(false)
  isOnHold   Boolean               @default(false)

  vendorPayableAccountId String

  /// Prevents duplicate AP liability for one vendor invoice (Phase 4A4).
  sourceVendorInvoiceId    String? @unique
  /// Prevents duplicate AP debit open item for one vendor payment / advance (Phase 4B3).
  sourceVendorPaymentId    String? @unique
  /// Prevents duplicate AP open item for one vendor adjustment (Phase 4C2).
  sourceVendorAdjustmentId String? @unique

  accountingVoucherId String?
  postingEventId      String?

  settledAt  DateTime?
  reversedAt DateTime?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                 Tenant             @relation(fields: [tenantId], references: [id])
  legalEntity            LegalEntity        @relation(fields: [legalEntityId], references: [id])
  branch                 Branch?            @relation(fields: [branchId], references: [id])
  sourceVendorInvoice    VendorInvoice?     @relation(fields: [sourceVendorInvoiceId], references: [id])
  sourceVendorPayment    VendorPayment?     @relation("PayableOpenItemSourceVendorPayment", fields: [sourceVendorPaymentId], references: [id])
  sourceVendorAdjustment VendorAdjustment?  @relation(fields: [sourceVendorAdjustmentId], references: [id])
  vendorPayableAccount   Account            @relation("PayableOpenItemPayableAccount", fields: [vendorPayableAccountId], references: [id])
  accountingVoucher      AccountingVoucher? @relation(fields: [accountingVoucherId], references: [id])

  /// Batches where this open item is the single DEBIT source.
  debitAllocationBatches        PayableAllocationBatch[]        @relation("PayableAllocationSourceDebit")
  /// Lines where this open item is the CREDIT target.
  creditAllocationLines         PayableAllocationLine[]         @relation("PayableAllocationTargetCredit")
  /// Lines where this open item is also referenced as the DEBIT source (denormalised for query).
  debitAllocationLines          PayableAllocationLine[]         @relation("PayableAllocationSourceDebitLine")
  debitAllocationReversalLines  PayableAllocationReversalLine[] @relation("PayableAllocRevSourceDebit")
  creditAllocationReversalLines PayableAllocationReversalLine[] @relation("PayableAllocRevTargetCredit")
  /// Optional header link from VendorPayment.payableOpenItemId (set on post).
  vendorPaymentHeaderLink       VendorPayment?                  @relation("VendorPaymentOpenItemHeaderLink")
  /// Optional header link from VendorAdjustment.payableOpenItemId (set on post).
  vendorAdjustmentHeaderLink    VendorAdjustment?               @relation("VendorAdjustmentOpenItemHeaderLink")

  @@unique([tenantId, legalEntityId, documentType, documentId], map: "pay_open_doc_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId])
  @@index([tenantId, legalEntityId, vendorId, status], map: "pay_open_vendor_status_idx")
  @@index([tenantId, legalEntityId, status, dueDate], map: "pay_open_status_due_idx")
  @@index([tenantId, legalEntityId, vendorPayableAccountId, status], map: "pay_open_acct_status_idx")
  @@index([tenantId, legalEntityId, side, status], map: "pay_open_side_status_idx")
  @@index([branchId])
  @@index([vendorId])
  @@index([status])
  @@index([side])
  @@index([documentType])
  @@index([postingDate])
  @@index([dueDate])
  @@index([currencyCode])
  @@index([vendorPayableAccountId])
  @@index([accountingVoucherId])
  @@map("payable_open_items")
}

// ─── Accounting Phase 4B1 — Vendor payment + AP allocation foundation ─────────

enum VendorPaymentStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  READY_TO_POST
  POSTED
  CANCELLED
  REVERSED
}

enum VendorPaymentPurpose {
  INVOICE_SETTLEMENT
  ADVANCE
  MIXED
}

/// Same values as CustomerReceiptPaymentMethod — dedicated AP enum for payment documents.
enum VendorPaymentMethod {
  BANK_TRANSFER
  CASH
  CHEQUE
  UPI
  CARD
  OTHER
}

enum VendorPaymentAdjustmentType {
  TDS
  DISCOUNT
  RETENTION
  WITHHOLDING
  BANK_CHARGE
  PROCESSING_CHARGE
  ROUND_OFF
  OTHER
}

/// Future posting intent for adjustment lines — Phase 4B1 stores only; no GL.
enum VendorPaymentAdjustmentAccountingRole {
  SETTLEMENT_CREDIT
  PAYMENT_EXPENSE_DEBIT
  ROUND_OFF_DEBIT
  ROUND_OFF_CREDIT
  INFORMATION_ONLY
}

enum PayableAllocationStatus {
  ACTIVE
  PARTIALLY_REVERSED
  REVERSED
}

enum PayableAllocationLineStatus {
  ACTIVE
  PARTIALLY_REVERSED
  REVERSED
}

/// One financial document for invoice settlement, vendor advance, or mixed.
/// Amounts stay positive; direction via open-item side / adjustment accounting role / future voucher.
/// Phase 4B1: foundation only — no calculation, API, posting, or allocation execution.
model VendorPayment {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  /// MasterVendor.id — soft reference (no FK); same vendor identity as VendorInvoice.
  vendorId        String
  financialYearId String

  draftReference      String  @db.VarChar(64)
  /// FOS internal final number — null until Phase 4B3 posting.
  vendorPaymentNumber String? @db.VarChar(64)

  paymentPurpose VendorPaymentPurpose
  paymentMethod  VendorPaymentMethod
  status         VendorPaymentStatus  @default(DRAFT)

  documentDate        DateTime  @db.Date
  paymentDate         DateTime  @db.Date
  proposedPostingDate DateTime? @db.Date
  valueDate           DateTime? @db.Date
  dueReferenceDate    DateTime? @db.Date

  currencyCode String  @default("INR") @db.VarChar(8)
  exchangeRate Decimal @default(1) @db.Decimal(18, 8)

  vendorCodeSnapshot      String  @db.VarChar(32)
  vendorNameSnapshot      String  @db.VarChar(300)
  vendorGstinSnapshot     String? @db.VarChar(20)
  vendorPanSnapshot       String? @db.VarChar(20)
  vendorStateCodeSnapshot String? @db.VarChar(8)
  vendorAddressSnapshot   Json?

  paymentAccountId          String?
  vendorPayableAccountId    String?
  tdsPayableAccountId       String?
  discountAccountId         String?
  /// TreasuryAccount.id — soft reference (no FK), Phase 5A1 foundation only; not populated by any posting flow yet.
  treasuryAccountId         String?
  retentionAccountId        String?
  bankChargeAccountId       String?
  processingChargeAccountId String?
  roundOffAccountId         String?
  otherAdjustmentAccountId  String?

  /// Amount paid directly to vendor via bank/cash/other method.
  paymentAmount              Decimal @default(0) @db.Decimal(18, 4)
  /// Settles liability without cash to vendor (TDS, discount, retention, withholding).
  settlementAdjustmentAmount Decimal @default(0) @db.Decimal(18, 4)
  /// Company expense that does not reduce vendor liability (bank/processing charges).
  paymentExpenseAmount       Decimal @default(0) @db.Decimal(18, 4)
  /// May be signed for balancing difference (existing finance convention).
  roundOffAmount             Decimal @default(0) @db.Decimal(18, 4)
  /// Total vendor payable liability the future posting is intended to reduce (open-item amount).
  vendorSettlementAmount     Decimal @default(0) @db.Decimal(18, 4)
  /// Total bank/cash credit created by future posting.
  cashOutflowAmount          Decimal @default(0) @db.Decimal(18, 4)

  basePaymentAmount              Decimal @default(0) @db.Decimal(18, 4)
  baseSettlementAdjustmentAmount Decimal @default(0) @db.Decimal(18, 4)
  basePaymentExpenseAmount       Decimal @default(0) @db.Decimal(18, 4)
  baseRoundOffAmount             Decimal @default(0) @db.Decimal(18, 4)
  baseVendorSettlementAmount     Decimal @default(0) @db.Decimal(18, 4)
  baseCashOutflowAmount          Decimal @default(0) @db.Decimal(18, 4)

  tdsBaseAmount     Decimal @default(0) @db.Decimal(18, 4)
  tdsAmount         Decimal @default(0) @db.Decimal(18, 4)
  baseTdsBaseAmount Decimal @default(0) @db.Decimal(18, 4)
  baseTdsAmount     Decimal @default(0) @db.Decimal(18, 4)

  paymentReference    String?   @db.VarChar(100)
  bankReference       String?   @db.VarChar(100)
  chequeNumber        String?   @db.VarChar(64)
  chequeDate          DateTime? @db.Date
  instrumentReference String?   @db.VarChar(100)
  narration           String?   @db.Text

  beneficiarySnapshot        Json?
  paymentInstructionSnapshot Json?

  approvalRequired  Boolean @default(false)
  approvalRequestId String? @unique

  calculationVersion        Int   @default(1)
  calculationContext        Json?
  calculationSnapshot       Json?
  accountingPreviewSnapshot Json?
  supplierUniquenessContext Json?

  /// Deterministic duplicate-payment guard claimed at submit/mark-ready (Phase 4B3).
  paymentUniquenessKey String? @unique @db.VarChar(512)

  accountingVoucherId String? @unique
  postingEventId      String? @unique
  /// Convenience header link set on future post (also sourceVendorPaymentId on open item).
  payableOpenItemId   String? @unique

  submittedAt            DateTime?
  submittedBy            String?
  approvedAt             DateTime?
  approvedBy             String?
  rejectedAt             DateTime?
  rejectedBy             String?
  readyToPostAt          DateTime?
  readyToPostBy          String?
  postedAt               DateTime?
  postedBy               String?
  cancelledAt            DateTime?
  cancelledBy            String?
  cancellationReason     String?   @db.VarChar(500)
  reversedAt             DateTime?
  reversedBy             String?
  reversalDate           DateTime? @db.Date
  reversalReason         String?   @db.VarChar(500)
  reversalVoucherId      String?   @unique
  reversalPostingEventId String?   @unique

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant               Tenant                  @relation(fields: [tenantId], references: [id])
  legalEntity          LegalEntity             @relation(fields: [legalEntityId], references: [id])
  branch               Branch?                 @relation(fields: [branchId], references: [id])
