  @@index([tenantId, outboundDispatchId], map: "dispatch_pick_list_tenant_ob_idx")
  @@index([tenantId, status], map: "dispatch_pick_list_tenant_status_idx")
  @@index([tenantId, deletedAt], map: "dispatch_pick_list_tenant_del_idx")
  @@map("dispatch_pick_lists")
}

model DispatchPickLine {
  id                     String                 @id @default(uuid())
  tenantId               String
  pickListId             String
  outboundDispatchLineId String
  dispatchRequirementId  String?
  salesOrderId           String?
  salesOrderLineId       String?                @db.VarChar(64)
  itemId                 String
  warehouseId            String
  requestedQuantity      Decimal                @db.Decimal(18, 4)
  reservedQuantity       Decimal                @db.Decimal(18, 4)
  pickedQuantity         Decimal                @default(0) @db.Decimal(18, 4)
  shortageQuantity       Decimal                @default(0) @db.Decimal(18, 4)
  status                 DispatchPickLineStatus @default(NOT_STARTED)
  primaryShortageReason  String?                @db.VarChar(500)
  sourceVersion          Int                    @default(1)
