  inspectionPlan QualityInspectionPlan @relation(fields: [inspectionPlanId], references: [id], onDelete: Cascade)
  inspections    QualityInspection[]

  @@unique([inspectionPlanId, revisionNumber])
  @@index([tenantId])
  @@index([tenantId, inspectionPlanId])
  @@index([tenantId, status])
  @@map("quality_inspection_plan_revisions")
}

model QualityInspectionPlanLine {
  id                    String                    @id @default(uuid())
  tenantId              String
  planId                String
  parameterId           String
  sortOrder             Int                       @default(0)
  mandatoryOverride     Boolean?
  minValueOverride      Decimal?                  @db.Decimal(18, 4)
  maxValueOverride      Decimal?                  @db.Decimal(18, 4)
  targetValueOverride   Decimal?                  @db.Decimal(18, 4)
  severityOverride      QualityParameterSeverity?
  photoRequiredOverride Boolean?
  remarksRequired       Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  tenant    Tenant                @relation(fields: [tenantId], references: [id])
