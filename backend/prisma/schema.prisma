/// Phase 7A1 — tenant/plant warehouse role mapping for stores / FG / WIP / scrap.
/// plantCode null = tenant-wide default row; service enforces at most one isDefault where plantCode is null
/// (MySQL unique allows multiple NULLs on plantCode).
model ManufacturingWarehouseMapping {
  id                         String    @id @default(uuid())
  tenantId                   String
  plantCode                  String?   @db.VarChar(32)
  rawMaterialWarehouseId     String
  productionIssueWarehouseId String?
  wipWarehouseId             String?
  finishedGoodsWarehouseId   String
  qualityHoldWarehouseId     String?
  reworkWarehouseId          String?
  scrapWarehouseId           String?
  jobWorkWarehouseId         String?
  defaultReturnWarehouseId   String?
  isDefault                  Boolean   @default(false)
  isActive                   Boolean   @default(true)
  createdBy                  String?
  updatedBy                  String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  deletedAt                  DateTime?

  tenant                   Tenant           @relation(fields: [tenantId], references: [id])
  rawMaterialWarehouse     MasterWarehouse  @relation("MfgWhMapRawMaterial", fields: [rawMaterialWarehouseId], references: [id])
  productionIssueWarehouse MasterWarehouse? @relation("MfgWhMapProductionIssue", fields: [productionIssueWarehouseId], references: [id])
  wipWarehouse             MasterWarehouse? @relation("MfgWhMapWip", fields: [wipWarehouseId], references: [id])
  finishedGoodsWarehouse   MasterWarehouse  @relation("MfgWhMapFinishedGoods", fields: [finishedGoodsWarehouseId], references: [id])
  qualityHoldWarehouse     MasterWarehouse? @relation("MfgWhMapQualityHold", fields: [qualityHoldWarehouseId], references: [id])
  reworkWarehouse          MasterWarehouse? @relation("MfgWhMapRework", fields: [reworkWarehouseId], references: [id])
  scrapWarehouse           MasterWarehouse? @relation("MfgWhMapScrap", fields: [scrapWarehouseId], references: [id])
  jobWorkWarehouse         MasterWarehouse? @relation("MfgWhMapJobWork", fields: [jobWorkWarehouseId], references: [id])
  defaultReturnWarehouse   MasterWarehouse? @relation("MfgWhMapDefaultReturn", fields: [defaultReturnWarehouseId], references: [id])

  @@unique([tenantId, plantCode], map: "mfg_wh_map_tenant_plant_key")
  @@index([tenantId], map: "mfg_wh_map_tenant_idx")
  @@index([tenantId, isDefault, isActive], map: "mfg_wh_map_tenant_default_idx")
  @@index([tenantId, deletedAt], map: "mfg_wh_map_tenant_deleted_idx")
  @@map("manufacturing_warehouse_mappings")
}

