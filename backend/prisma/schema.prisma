}

model VendorComparison {
  id                       String                 @id @default(uuid())
  tenantId                 String
  comparisonNumber         String                 @db.VarChar(64)
  comparisonDate           DateTime               @db.Date
  requestForQuotationId    String
  status                   VendorComparisonStatus @default(DRAFT)
