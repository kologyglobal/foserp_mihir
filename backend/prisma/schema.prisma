  @@unique([planId, parameterId])
  @@index([tenantId])
  @@index([tenantId, planId])
  @@map("quality_inspection_plan_lines")
}

model QualityInspection {
  id                       String                     @id @default(uuid())
  tenantId                 String
  inspectionNumber         String                     @db.VarChar(64)
  category                 QualityInspectionCategory
  status                   QualityInspectionStatus    @default(PENDING)
  decision                 QualityInspectionDecision?
  productionOrderId        String?
  jobWorkOrderId           String?
  stageId                  String?
  operationId              String?
  itemId                   String?
