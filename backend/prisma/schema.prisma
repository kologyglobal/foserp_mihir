  description      String?   @db.Text
  plantCode        String?   @db.VarChar(32)
  departmentRef    String?   @db.VarChar(100)
  locationId       String?
  capacityPerShift Decimal?  @db.Decimal(18, 4)
  capacityUomId    String?
  defaultShiftRef  String?   @db.VarChar(64)
  costRate         Decimal?  @db.Decimal(18, 2)
