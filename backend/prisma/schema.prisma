// ─── Accounting Phase 2C2A — Runtime approval requests (not posting) ──────────

enum FinanceApprovalDocumentType {
  JOURNAL
  PAYMENT
  RECEIPT
  CREDIT_NOTE
  DEBIT_NOTE
  PERIOD_REOPEN
  /// Vendor invoice approval (Phase 4A1 compatibility; workflow execution in later AP phases).
  VENDOR_INVOICE
  /// Vendor payment / advance approval (Phase 4B1 compatibility; workflow execution in later AP phases).
  VENDOR_PAYMENT
  /// Vendor debit note / credit adjustment approval (Phase 4C2).
  VENDOR_ADJUSTMENT
  /// Internal treasury transfer approval (Phase 5B1).
  TREASURY_TRANSFER
  /// Treasury cheque approval (Phase 5B2).
  TREASURY_CHEQUE
  /// Treasury adjustment approval (Phase 5B3).
  TREASURY_ADJUSTMENT
  /// Fixed asset disposal approval (Phase FA2).
  FIXED_ASSET_DISPOSAL
}

enum FinanceApprovalRequestStatus {
  PENDING
  APPROVED
  SENT_BACK
  REJECTED
  CANCELLED
}

enum FinanceApprovalStepStatus {
  WAITING
  PENDING
  APPROVED
  SENT_BACK
  REJECTED
  SKIPPED
  CANCELLED
}

/// Runtime approval transaction — distinct from FinanceApprovalRule (configuration).
model FinanceApprovalRequest {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  documentType           FinanceApprovalDocumentType
  documentId             String
  documentNumberSnapshot String?                     @db.VarChar(64)
  documentStatusSnapshot String?                     @db.VarChar(32)

  cycleNumber Int                          @default(1)
  status      FinanceApprovalRequestStatus @default(PENDING)

  amountBasis  Decimal @db.Decimal(18, 4)
  currencyCode String  @default("INR") @db.VarChar(8)

  currentLevel Int @default(1)
  totalLevels  Int @default(1)

  requestedBy String?
  requestedAt DateTime @default(now())

  completedAt DateTime?
  completedBy String?

  ruleSnapshotJson     Json?
  workflowSnapshotJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant                @relation(fields: [tenantId], references: [id])
  legalEntity        LegalEntity           @relation(fields: [legalEntityId], references: [id])
  steps              FinanceApprovalStep[]
  customerCreditNote CustomerCreditNote?
  vendorInvoice      VendorInvoice?
  vendorPayment      VendorPayment?
  vendorAdjustment   VendorAdjustment?

  @@unique([tenantId, legalEntityId, documentType, documentId, cycleNumber], map: "fin_appr_req_doc_cycle_key")
  @@index([tenantId, legalEntityId, status], map: "fin_appr_req_le_status_idx")
  @@index([documentType, documentId], map: "fin_appr_req_doc_idx")
  @@index([requestedBy, requestedAt], map: "fin_appr_req_requester_idx")
  @@index([currentLevel, status], map: "fin_appr_req_level_status_idx")
  @@map("finance_approval_requests")
}

model FinanceApprovalStep {
  id                String @id @default(uuid())
  tenantId          String
  legalEntityId     String
  approvalRequestId String

  level    Int
  sequence Int @default(1)

  approverRoleId String?
  approverUserId String?

  status FinanceApprovalStepStatus @default(WAITING)

  actedBy  String?
  actedAt  DateTime?
  comments String?   @db.VarChar(1000)

  delegatedFromUserId String?
  metadataJson        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity            @relation(fields: [legalEntityId], references: [id])
  approvalRequest FinanceApprovalRequest @relation(fields: [approvalRequestId], references: [id])

  @@unique([approvalRequestId, level, sequence], map: "fin_appr_step_level_seq_key")
  @@index([tenantId])
  @@index([approvalRequestId, status], map: "fin_appr_step_req_status_idx")
  @@index([approverUserId, status], map: "fin_appr_step_user_status_idx")
  @@map("finance_approval_steps")
}

// ─── Accounting Phase 3A1 — AR database foundation (no posting / no HTTP routes) ─

enum SalesInvoiceStatus {
  DRAFT
  READY_TO_POST
  POSTED
  CANCELLED
  REVERSED
}

enum SalesInvoiceSourceType {
  DIRECT
  SALES_ORDER
}

enum SalesInvoiceSupplyType {
  INTRA_STATE
  INTER_STATE
  EXPORT
  SEZ
  NON_GST
}

enum SalesInvoiceTaxTreatment {
  REGISTERED
  UNREGISTERED
  EXPORT_WITH_TAX
  EXPORT_WITHOUT_TAX
  SEZ_WITH_TAX
  SEZ_WITHOUT_TAX
  NON_GST
}

/// Receivable document kinds — CREDIT_NOTE / DEBIT_NOTE / OPENING_BALANCE reserved for later phases.
enum ReceivableDocumentType {
  SALES_INVOICE
  CREDIT_NOTE
  CUSTOMER_CREDIT_NOTE
  DEBIT_NOTE
  OPENING_BALANCE
  /// Customer receipt credit open item (Phase 3B1).
  CUSTOMER_RECEIPT
}

enum ReceivableOpenItemSide {
  /// Invoice / debit balance — included in outstanding reporting.
  DEBIT
  /// Receipt / credit note balance — excluded from invoice outstanding (Phase 3B1).
  CREDIT
}

enum ReceivableOpenItemStatus {
  OPEN
  PARTIALLY_SETTLED
  SETTLED
  DISPUTED
  ON_HOLD
}

/// Operational AR invoice header.
/// Customer master: CrmCompany only (via customer-party adapter). customerId is application-validated UUID — no Prisma FK (avoids CRM soft-delete coupling).
/// Sales order link: sourceType + sourceDocumentId + snapshot — no FK to CrmSalesOrder (supports partial invoicing later).
/// invoiceNumber null while DRAFT; MySQL unique (legalEntityId, invoiceNumber) allows multiple NULLs.
/// draftReference unique per LE when set; multiple NULLs allowed.
model SalesInvoice {
  id              String  @id @default(uuid())
  tenantId        String
  legalEntityId   String
  branchId        String?
  financialYearId String?

  invoiceNumber  String?            @db.VarChar(64)
  draftReference String?            @db.VarChar(64)
  status         SalesInvoiceStatus @default(DRAFT)

  /// CrmCompany.id — validated by customer-party service, not a DB FK.
  customerId                      String
  customerCodeSnapshot            String? @db.VarChar(32)
  customerNameSnapshot            String  @db.VarChar(300)
  customerGstinSnapshot           String? @db.VarChar(20)
  customerPanSnapshot             String? @db.VarChar(20)
  customerBillingAddressSnapshot  Json?
  customerStateCodeSnapshot       String? @db.VarChar(8)
  customerShippingAddressSnapshot Json?

  /// Commercial inputs needed to recalculate without trusting client totals
  calculationContext Json?

  sourceType             SalesInvoiceSourceType @default(DIRECT)
  sourceDocumentId       String?
  sourceDocumentSnapshot Json?

  invoiceDate        DateTime  @db.Date
  postingDate        DateTime? @db.Date
  referenceNumber    String?   @db.VarChar(64)
  customerPoNumber   String?   @db.VarChar(64)
  paymentTermsDays   Int?
  freightAmount      Decimal   @default(0) @db.Decimal(18, 4)
  otherChargesAmount Decimal   @default(0) @db.Decimal(18, 4)
  dueDate            DateTime? @db.Date
  placeOfSupply      String?   @db.VarChar(8)

  supplyType   SalesInvoiceSupplyType   @default(INTRA_STATE)
  taxTreatment SalesInvoiceTaxTreatment @default(REGISTERED)

  currencyCode String  @default("INR") @db.VarChar(8)
  exchangeRate Decimal @default(1) @db.Decimal(18, 8)

  subtotalAmount Decimal @default(0) @db.Decimal(18, 4)
  discountAmount Decimal @default(0) @db.Decimal(18, 4)
  taxableAmount  Decimal @default(0) @db.Decimal(18, 4)
  cgstAmount     Decimal @default(0) @db.Decimal(18, 4)
  sgstAmount     Decimal @default(0) @db.Decimal(18, 4)
  igstAmount     Decimal @default(0) @db.Decimal(18, 4)
  cessAmount     Decimal @default(0) @db.Decimal(18, 4)
  totalTaxAmount Decimal @default(0) @db.Decimal(18, 4)
  roundOffAmount Decimal @default(0) @db.Decimal(18, 4)
  totalAmount    Decimal @default(0) @db.Decimal(18, 4)

  baseSubtotalAmount Decimal @default(0) @db.Decimal(18, 4)
  baseDiscountAmount Decimal @default(0) @db.Decimal(18, 4)
  baseTaxableAmount  Decimal @default(0) @db.Decimal(18, 4)
  baseCgstAmount     Decimal @default(0) @db.Decimal(18, 4)
  baseSgstAmount     Decimal @default(0) @db.Decimal(18, 4)
  baseIgstAmount     Decimal @default(0) @db.Decimal(18, 4)
  baseCessAmount     Decimal @default(0) @db.Decimal(18, 4)
  baseTotalTaxAmount Decimal @default(0) @db.Decimal(18, 4)
  baseRoundOffAmount Decimal @default(0) @db.Decimal(18, 4)
  baseTotalAmount    Decimal @default(0) @db.Decimal(18, 4)

  narration String? @db.Text

  accountingVoucherId String? @unique
  postingEventId      String? @unique

  postedAt           DateTime?
  postedBy           String?
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?   @db.VarChar(500)

  /// Document reverse (allocation-first) — Phase AR invoice reverse.
  reversalVoucherId String?   @unique
  reversedAt        DateTime?
  reversedBy        String?
  reversalReason    String?   @db.VarChar(500)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                         @relation(fields: [tenantId], references: [id])
  legalEntity           LegalEntity                    @relation(fields: [legalEntityId], references: [id])
  branch                Branch?                        @relation(fields: [branchId], references: [id])
  financialYear         FinancialYear?                 @relation(fields: [financialYearId], references: [id])
  accountingVoucher     AccountingVoucher?             @relation(fields: [accountingVoucherId], references: [id])
  postingEvent          PostingEvent?                  @relation(fields: [postingEventId], references: [id])
  reversalVoucher       AccountingVoucher?             @relation("SalesInvoiceReversalVoucher", fields: [reversalVoucherId], references: [id])
  lines                 SalesInvoiceLine[]
  receivableOpenItems   ReceivableOpenItem[]
  receiptAllocations    CustomerReceiptAllocation[]
  creditNoteAllocations CustomerCreditNoteAllocation[]

  @@unique([legalEntityId, invoiceNumber], map: "sales_inv_le_number_key")
  @@unique([legalEntityId, draftReference], map: "sales_inv_le_draft_ref_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId])
  @@index([legalEntityId, status])
  @@index([legalEntityId, customerId])
  @@index([legalEntityId, invoiceDate])
  @@index([legalEntityId, dueDate])
  @@index([sourceType, sourceDocumentId], map: "sales_inv_src_doc_idx")
  @@index([financialYearId])
  @@index([createdBy])
  @@map("sales_invoices")
}

model SalesInvoiceLine {
  id             String  @id @default(uuid())
  tenantId       String
  legalEntityId  String
  salesInvoiceId String
  lineNumber     Int
  sourceLineId   String? @db.VarChar(64)

  /// MasterItem.id when known — soft reference only (no FK; item master lifecycle independent).
  itemId           String?
  itemCodeSnapshot String? @db.VarChar(64)
  itemNameSnapshot String? @db.VarChar(300)
  hsnCodeSnapshot  String? @db.VarChar(16)
  uomSnapshot      String? @db.VarChar(32)
  description      String? @db.VarChar(500)

  quantity        Decimal @db.Decimal(18, 6)
  unitRate        Decimal @db.Decimal(18, 4)
  grossAmount     Decimal @default(0) @db.Decimal(18, 4)
  discountPercent Decimal @default(0) @db.Decimal(9, 4)
  discountAmount  Decimal @default(0) @db.Decimal(18, 4)
  taxableAmount   Decimal @default(0) @db.Decimal(18, 4)
  cgstRate        Decimal @default(0) @db.Decimal(9, 4)
  cgstAmount      Decimal @default(0) @db.Decimal(18, 4)
  sgstRate        Decimal @default(0) @db.Decimal(9, 4)
  sgstAmount      Decimal @default(0) @db.Decimal(18, 4)
  igstRate        Decimal @default(0) @db.Decimal(9, 4)
  igstAmount      Decimal @default(0) @db.Decimal(18, 4)
  cessRate        Decimal @default(0) @db.Decimal(9, 4)
  cessAmount      Decimal @default(0) @db.Decimal(18, 4)
  lineTotal       Decimal @default(0) @db.Decimal(18, 4)

  revenueAccountId String?
  costCentreId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  legalEntity    LegalEntity  @relation(fields: [legalEntityId], references: [id])
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id])
  revenueAccount Account?     @relation(fields: [revenueAccountId], references: [id])
  costCentre     CostCentre?  @relation(fields: [costCentreId], references: [id])

  @@unique([salesInvoiceId, lineNumber])
  @@index([tenantId])
  @@index([salesInvoiceId])
  @@index([itemId])
  @@index([revenueAccountId])
  @@index([costCentreId])
  @@map("sales_invoice_lines")
}

/// Open receivable balance row — unified debit (invoice) and credit (receipt) subledger.
/// side=DEBIT for invoices; side=CREDIT for customer receipts (Phase 3B1 — no separate credit table).
/// documentId holds source document UUID; salesInvoiceId optional join helper for SALES_INVOICE rows.
/// customerReceiptId links credit-side rows to CustomerReceipt.
model ReceivableOpenItem {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  /// DEBIT = invoice outstanding; CREDIT = receipt/credit unallocated balance.
  side                   ReceivableOpenItemSide @default(DEBIT)
  documentType           ReceivableDocumentType
  documentId             String
  documentNumberSnapshot String?                @db.VarChar(64)
  salesInvoiceId         String?                @unique
  /// FK to CustomerReceipt when side=CREDIT.
  customerReceiptId      String?                @unique
  /// FK to CustomerCreditNote when side=CREDIT.
  customerCreditNoteId   String?                @unique

  /// CrmCompany.id — application-validated, no DB FK.
  customerId           String
  customerNameSnapshot String? @db.VarChar(300)

  receivableAccountId String?

  currencyCode String  @default("INR") @db.VarChar(8)
  exchangeRate Decimal @default(1) @db.Decimal(18, 8)

  originalAmount   Decimal @db.Decimal(18, 4)
  openAmount       Decimal @db.Decimal(18, 4)
  allocatedAmount  Decimal @default(0) @db.Decimal(18, 4)
  adjustedAmount   Decimal @default(0) @db.Decimal(18, 4)
  writtenOffAmount Decimal @default(0) @db.Decimal(18, 4)

  baseOriginalAmount   Decimal @db.Decimal(18, 4)
  baseOpenAmount       Decimal @db.Decimal(18, 4)
  baseAllocatedAmount  Decimal @default(0) @db.Decimal(18, 4)
  baseAdjustedAmount   Decimal @default(0) @db.Decimal(18, 4)
  baseWrittenOffAmount Decimal @default(0) @db.Decimal(18, 4)

  documentDate DateTime?                @db.Date
  dueDate      DateTime?                @db.Date
  status       ReceivableOpenItemStatus @default(OPEN)
  /// Set when status becomes SETTLED (Phase 3B5 allocation).
  settledAt    DateTime?

  accountingVoucherId String?

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                  Tenant                           @relation(fields: [tenantId], references: [id])
  legalEntity             LegalEntity                      @relation(fields: [legalEntityId], references: [id])
  branch                  Branch?                          @relation(fields: [branchId], references: [id])
  salesInvoice            SalesInvoice?                    @relation(fields: [salesInvoiceId], references: [id])
  customerReceipt         CustomerReceipt?                 @relation("ReceiptOpenItemSide", fields: [customerReceiptId], references: [id])
  customerCreditNote      CustomerCreditNote?              @relation("CreditNoteOpenItemSide", fields: [customerCreditNoteId], references: [id])
  receivableAccount       Account?                         @relation(fields: [receivableAccountId], references: [id])
  accountingVoucher       AccountingVoucher?               @relation(fields: [accountingVoucherId], references: [id])
  linkedReceipt           CustomerReceipt?                 @relation("ReceiptCreditOpenItemLink")
  linkedCreditNote        CustomerCreditNote?              @relation("CreditNoteCreditOpenItemLink")
  creditAllocations       CustomerReceiptAllocation[]      @relation("ReceiptCreditOpenItem")
  debitAllocations        CustomerReceiptAllocation[]      @relation("InvoiceDebitOpenItem")
  creditAllocationBatches CustomerReceiptAllocationBatch[] @relation("ReceiptCreditAllocationBatch")

  /// Phase 3C5 — credit note allocation relations.
  creditNoteCreditAllocations       CustomerCreditNoteAllocation[]      @relation("CreditNoteCreditOpenItem")
  creditNoteDebitAllocations        CustomerCreditNoteAllocation[]      @relation("CreditNoteInvoiceDebitOpenItem")
  creditNoteCreditAllocationBatches CustomerCreditNoteAllocationBatch[] @relation("CreditNoteCreditAllocationBatch")

  @@unique([tenantId, legalEntityId, documentType, documentId], map: "recv_open_doc_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId])
  @@index([legalEntityId, customerId])
  @@index([legalEntityId, status])
  @@index([legalEntityId, dueDate])
  @@index([tenantId, legalEntityId, status, dueDate])
  @@index([tenantId, legalEntityId, customerId, status])
  @@index([tenantId, legalEntityId, receivableAccountId, status])
  @@index([tenantId, legalEntityId, side, status])
  @@index([customerReceiptId])
  @@index([customerCreditNoteId])
  @@index([receivableAccountId])
  @@index([accountingVoucherId])
  @@map("receivable_open_items")
}

enum CustomerCreditNoteStatus {
  DRAFT
  PENDING_APPROVAL
  READY_TO_POST
  POSTED
  REJECTED
  CANCELLED
  REVERSED
}

enum CreditNotePurpose {
