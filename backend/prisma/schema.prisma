  inputSgstAmount           Decimal @default(0) @db.Decimal(18, 4)
  inputIgstAmount           Decimal @default(0) @db.Decimal(18, 4)
  inputCessAmount           Decimal @default(0) @db.Decimal(18, 4)
  otherRecoverableTaxAmount Decimal @default(0) @db.Decimal(18, 4)
  nonRecoverableTaxAmount   Decimal @default(0) @db.Decimal(18, 4)

  freightAmount     Decimal @default(0) @db.Decimal(18, 4)
  otherChargeAmount Decimal @default(0) @db.Decimal(18, 4)
  roundOffAmount    Decimal @default(0) @db.Decimal(18, 4)

