/// ERP organisation using FOS — distinct from CrmCompany (customer account).
model LegalEntity {
  id                    String          @id @default(uuid())
  tenantId              String
  code                  String          @db.VarChar(32)
  legalName             String          @db.VarChar(300)
  displayName           String          @db.VarChar(300)
  entityType            LegalEntityType @default(PRIVATE_LIMITED)
  pan                   String?         @db.VarChar(10)
  cin                   String?         @db.VarChar(21)
  gstin                 String?         @db.VarChar(15)
  baseCurrency          String          @default("INR") @db.VarChar(8)
  countryCode           String          @default("IN") @db.VarChar(2)
  stateCode             String?         @db.VarChar(8)
  registeredAddressJson Json?
  billingAddressJson    Json?
  fiscalYearStartMonth  Int             @default(4)
  isDefault             Boolean         @default(false)
  isActive              Boolean         @default(true)
  createdBy             String?
  updatedBy             String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  branches               Branch[]
  financialYears         FinancialYear[]
  accountingPeriods      AccountingPeriod[]
  accounts               Account[]
  defaultAccountMappings DefaultAccountMapping[]
  financeSettings        FinanceSettings?
  costCentres            CostCentre[]
  financeFeatureControls FinanceFeatureControl[]
  financeApprovalRules   FinanceApprovalRule[]
  financeNumberSeries    FinanceNumberSeries[]
  accountingVouchers     AccountingVoucher[]
  accountingVoucherLines AccountingVoucherLine[]
  generalLedgerEntries   GeneralLedgerEntry[]
  postingEvents          PostingEvent[]
  postingRules           PostingRule[]
  financeApprovalRequests FinanceApprovalRequest[]
  financeApprovalSteps    FinanceApprovalStep[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isDefault])
  @@index([tenantId, isActive])
  @@map("legal_entities")
}

model Branch {
  id            String     @id @default(uuid())
  tenantId      String
  legalEntityId String
  code          String     @db.VarChar(32)
  name          String     @db.VarChar(200)
  branchType    BranchType @default(HEAD_OFFICE)
  gstin         String?    @db.VarChar(15)
  stateCode     String?    @db.VarChar(8)
  addressJson   Json?
  phone         String?    @db.VarChar(30)
  email         String?    @db.VarChar(255)
  isHeadOffice  Boolean    @default(false)
  isDefault     Boolean    @default(false)
  isActive      Boolean    @default(true)
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])
  accountingVouchers AccountingVoucher[]
  generalLedgerEntries GeneralLedgerEntry[]

  @@unique([legalEntityId, code])
  @@index([tenantId])
  @@index([tenantId, legalEntityId])
  @@index([legalEntityId, isHeadOffice])
  @@index([legalEntityId, isDefault])
  @@map("branches")
}

model FinancialYear {
  id            String              @id @default(uuid())
  tenantId      String
  legalEntityId String
  name          String              @db.VarChar(64)
  startDate     DateTime            @db.Date
  endDate       DateTime            @db.Date
  status        FinancialYearStatus @default(DRAFT)
  isCurrent     Boolean             @default(false)
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  legalEntity       LegalEntity        @relation(fields: [legalEntityId], references: [id])
  periods           AccountingPeriod[]
  financeNumberSeries FinanceNumberSeries[]
  accountingVouchers AccountingVoucher[]
  generalLedgerEntries GeneralLedgerEntry[]

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([legalEntityId, startDate, endDate])
  @@index([legalEntityId, isCurrent])
  @@map("financial_years")
}

model AccountingPeriod {
  id              String                 @id @default(uuid())
  tenantId        String
  legalEntityId   String
  financialYearId String
  periodNumber    Int
  name            String                 @db.VarChar(64)
  startDate       DateTime               @db.Date
  endDate         DateTime               @db.Date
  status          AccountingPeriodStatus @default(OPEN)
  closedAt        DateTime?
  closedBy        String?
  reopenedAt      DateTime?
  reopenedBy      String?
  reopenReason    String?                @db.VarChar(500)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  legalEntity   LegalEntity   @relation(fields: [legalEntityId], references: [id])
  financialYear FinancialYear @relation(fields: [financialYearId], references: [id])
  accountingVouchers AccountingVoucher[]
  generalLedgerEntries GeneralLedgerEntry[]

  @@unique([financialYearId, periodNumber])
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([financialYearId])
  @@index([legalEntityId, startDate, endDate])
  @@map("accounting_periods")
}

model Account {
  id                   String          @id @default(uuid())
  tenantId             String
  legalEntityId        String
  accountCode          String          @db.VarChar(32)
  accountName          String          @db.VarChar(200)
  parentAccountId      String?
  category             AccountCategory
  accountType          AccountType     @default(GENERAL)
  level                Int             @default(1)
  isGroup              Boolean         @default(false)
  isControlAccount     Boolean         @default(false)
  allowManualPosting   Boolean         @default(true)
  normalBalance        NormalBalance   @default(DEBIT)
  currencyCode         String?         @db.VarChar(8)
  requiresParty        Boolean         @default(false)
  requiresReconciliation Boolean       @default(false)
  isActive             Boolean         @default(true)
  description          String?         @db.Text
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  tenant      Tenant                   @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity              @relation(fields: [legalEntityId], references: [id])
  parent      Account?                 @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  children    Account[]                @relation("AccountHierarchy")
  mappings    DefaultAccountMapping[]
  voucherLines AccountingVoucherLine[]
  generalLedgerEntries GeneralLedgerEntry[]

  @@unique([legalEntityId, accountCode])
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([legalEntityId, category])
  @@index([parentAccountId])
  @@index([legalEntityId, isActive])
  @@map("accounts")
}

model DefaultAccountMapping {
  id            String                   @id @default(uuid())
  tenantId      String
  legalEntityId String
  mappingKey    DefaultAccountMappingKey
  accountId     String
  isMandatory   Boolean                  @default(false)
  description   String?                  @db.VarChar(500)
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])
  account     Account     @relation(fields: [accountId], references: [id])

  @@unique([legalEntityId, mappingKey])
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([accountId])
  @@map("default_account_mappings")
}

model FinanceSettings {
  id                             String         @id @default(uuid())
  tenantId                       String
  legalEntityId                  String         @unique
  baseCurrency                   String         @default("INR") @db.VarChar(8)
  dateFormat                     String         @default("DD/MM/YYYY") @db.VarChar(32)
  amountPrecision                Int            @default(2)
  quantityPrecision              Int            @default(3)
  roundingMethod                 RoundingMethod @default(ROUND_HALF_UP)
  roundingTolerance              Decimal        @default(1) @db.Decimal(18, 4)
  allowBackdatedPosting          Boolean        @default(false)
  backdatedDaysLimit             Int            @default(0)
  requireAttachmentAbove         Decimal?       @db.Decimal(18, 4)
  receiptApprovalLimit           Decimal?       @db.Decimal(18, 4)
  paymentApprovalLimit           Decimal?       @db.Decimal(18, 4)
  journalApprovalLimit           Decimal?       @db.Decimal(18, 4)
  writeOffTolerance              Decimal?       @db.Decimal(18, 4)
  bankChargeTolerance            Decimal?       @db.Decimal(18, 4)
  allowManualControlAccountPosting Boolean      @default(false)
  financeActivated               Boolean        @default(false)
  activatedAt                    DateTime?
  activatedBy                    String?
  createdAt                      DateTime       @default(now())
  updatedAt                      DateTime       @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])

  @@index([tenantId])
  @@map("finance_settings")
}

model CostCentre {
  id            String   @id @default(uuid())
  tenantId      String
  legalEntityId String
  code          String   @db.VarChar(32)
  name          String   @db.VarChar(200)
  parentId      String?
  isGroup       Boolean  @default(false)
  managerUserId String?
  isActive      Boolean  @default(true)
  description   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity  @relation(fields: [legalEntityId], references: [id])
  parent      CostCentre?  @relation("CostCentreHierarchy", fields: [parentId], references: [id])
  children    CostCentre[] @relation("CostCentreHierarchy")
  voucherLines AccountingVoucherLine[]
  generalLedgerEntries GeneralLedgerEntry[]

  @@unique([legalEntityId, code])
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([parentId])
  @@map("cost_centres")
}

model FinanceFeatureControl {
  id                String            @id @default(uuid())
  tenantId          String
  legalEntityId     String
  featureKey        FinanceFeatureKey
  isEnabled         Boolean           @default(false)
  configurationJson Json?
  updatedBy         String?
  updatedAt         DateTime          @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])

  @@unique([legalEntityId, featureKey])
  @@index([tenantId])
  @@map("finance_feature_controls")
}

model FinanceApprovalRule {
  id             String   @id @default(uuid())
  tenantId       String
  legalEntityId  String
  documentType   String   @db.VarChar(64)
  ruleName       String   @db.VarChar(200)
  amountFrom     Decimal  @default(0) @db.Decimal(18, 4)
  amountTo       Decimal? @db.Decimal(18, 4)
  conditionJson  Json?
  approverRoleId String?
  approverUserId String?
  approvalLevel  Int      @default(1)
  isActive       Boolean  @default(true)
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([legalEntityId, documentType])
  @@map("finance_approval_rules")
}

/// Finance voucher numbering scoped by legal entity (+ optional FY). Does not replace CRM CodeSeries.
model FinanceNumberSeries {
  id              String              @id @default(uuid())
  tenantId        String
  legalEntityId   String
  documentType    FinanceDocumentType
  financialYearId String?
  prefix          String              @db.VarChar(20)
  currentValue    Int                 @default(0)
  padLength       Int                 @default(6)
  resetEachYear   Boolean             @default(true)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  legalEntity   LegalEntity    @relation(fields: [legalEntityId], references: [id])
  financialYear FinancialYear? @relation(fields: [financialYearId], references: [id])

  @@unique([legalEntityId, documentType])
  @@index([tenantId])
  @@index([legalEntityId])
  @@map("finance_number_series")
}

// ─── Accounting Phase 2A — Core ledger foundation (no posting engine) ─────────

enum AccountingVoucherType {
  JOURNAL
  RECEIPT
  PAYMENT
  CONTRA
  DEBIT_NOTE
  CREDIT_NOTE
  OPENING_BALANCE
  REVERSAL
  SYSTEM
}

enum AccountingVoucherStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  SENT_BACK
  REJECTED
  REVERSED
  CANCELLED
}

enum AccountingPartyType {
  CUSTOMER
  VENDOR
  EMPLOYEE
  OTHER
}

enum PostingEventStatus {
  RECEIVED
  VALIDATING
  VALIDATED
  PROCESSING
  POSTED
  FAILED
  REVERSED
  IGNORED
}

model AccountingVoucher {
  id                   String                   @id @default(uuid())
  tenantId             String
  legalEntityId        String
  branchId             String?
  financialYearId      String
  accountingPeriodId   String

  voucherType          AccountingVoucherType
  voucherNumber        String?                  @db.VarChar(64)
  status               AccountingVoucherStatus  @default(DRAFT)

  documentDate         DateTime                 @db.Date
  postingDate          DateTime                 @db.Date
  referenceNumber      String?                  @db.VarChar(100)
  externalReference    String?                  @db.VarChar(100)
  narration            String?                  @db.Text

  currencyCode         String                   @default("INR") @db.VarChar(8)
  exchangeRate         Decimal                  @default(1) @db.Decimal(18, 8)

  totalDebit           Decimal                  @default(0) @db.Decimal(18, 4)
  totalCredit          Decimal                  @default(0) @db.Decimal(18, 4)
  baseTotalDebit       Decimal                  @default(0) @db.Decimal(18, 4)
  baseTotalCredit      Decimal                  @default(0) @db.Decimal(18, 4)

  sourceModule         String?                  @db.VarChar(64)
  sourceDocumentType   String?                  @db.VarChar(64)
  sourceDocumentId     String?
  sourceDocumentLineId String?

  reversalOfVoucherId  String?
  reversedByVoucherId  String?
  reversalReason       String?                  @db.VarChar(500)

  approvalRequired     Boolean                  @default(false)
  currentApprovalLevel Int                      @default(0)

  postedAt             DateTime?
  postedBy             String?
  reversedAt           DateTime?
  reversedBy           String?
  cancelledAt          DateTime?
  cancelledBy          String?
  cancellationReason   String?                  @db.VarChar(500)

  createdBy            String?
  updatedBy            String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  legalEntity        LegalEntity        @relation(fields: [legalEntityId], references: [id])
  branch             Branch?            @relation(fields: [branchId], references: [id])
  financialYear      FinancialYear      @relation(fields: [financialYearId], references: [id])
  accountingPeriod   AccountingPeriod   @relation(fields: [accountingPeriodId], references: [id])

  /// This voucher reverses the target voucher (reversalOfVoucherId → original).
  reversalOf         AccountingVoucher? @relation("VoucherReversalOf", fields: [reversalOfVoucherId], references: [id])
  reversedByOriginal AccountingVoucher[] @relation("VoucherReversalOf")

  /// Original voucher points at its effective reversing voucher.
  reversedByVoucher  AccountingVoucher? @relation("VoucherReversedBy", fields: [reversedByVoucherId], references: [id])
  reversesTarget     AccountingVoucher[] @relation("VoucherReversedBy")

  lines              AccountingVoucherLine[]
  generalLedgerEntries GeneralLedgerEntry[]
  postingEvents      PostingEvent[]

  @@unique([tenantId, legalEntityId, financialYearId, voucherType, voucherNumber], map: "acc_vch_tenant_le_fy_type_num_key")
  @@index([tenantId])
  @@index([tenantId, legalEntityId])
  @@index([legalEntityId, postingDate])
  @@index([legalEntityId, voucherType])
  @@index([legalEntityId, status])
  @@index([legalEntityId, voucherNumber])
  @@index([accountingPeriodId, status])
  @@index([sourceModule, sourceDocumentType, sourceDocumentId], map: "acc_vch_src_doc_idx")
  @@index([reversalOfVoucherId])
  @@index([createdBy])
  @@map("accounting_vouchers")
}

model AccountingVoucherLine {
  id                     String               @id @default(uuid())
  tenantId               String
  legalEntityId          String
  voucherId              String
  lineNumber             Int

  accountId              String

  partyType              AccountingPartyType?
  partyId                String?
  partyNameSnapshot      String?              @db.VarChar(300)

  debitAmount            Decimal              @default(0) @db.Decimal(18, 4)
  creditAmount           Decimal              @default(0) @db.Decimal(18, 4)
  baseDebitAmount        Decimal              @default(0) @db.Decimal(18, 4)
  baseCreditAmount       Decimal              @default(0) @db.Decimal(18, 4)

  currencyCode           String               @default("INR") @db.VarChar(8)
  exchangeRate           Decimal              @default(1) @db.Decimal(18, 8)

  costCentreId           String?
  /// Soft reference until a shared Project model exists — not a foreign key.
  projectReference       String?              @db.VarChar(64)
  departmentReference    String?              @db.VarChar(64)

  referenceDocumentType  String?              @db.VarChar(64)
  referenceDocumentId    String?
  referenceDocumentLineId String?

  dueDate                DateTime?            @db.Date
  lineNarration          String?              @db.VarChar(500)
  metadataJson           Json?

  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  legalEntity  LegalEntity       @relation(fields: [legalEntityId], references: [id])
  voucher      AccountingVoucher @relation(fields: [voucherId], references: [id])
  account      Account           @relation(fields: [accountId], references: [id])
  costCentre   CostCentre?       @relation(fields: [costCentreId], references: [id])
  generalLedgerEntry GeneralLedgerEntry?

  @@unique([voucherId, lineNumber])
  @@index([tenantId])
  @@index([voucherId])
  @@index([accountId])
  @@index([partyType, partyId])
  @@index([costCentreId])
  @@index([referenceDocumentType, referenceDocumentId], map: "acc_vch_line_ref_doc_idx")
  @@map("accounting_voucher_lines")
}

/// Immutable posted ledger rows. Application repositories must not update or delete.
model GeneralLedgerEntry {
  id                   String                 @id @default(uuid())
  tenantId             String
  legalEntityId        String
  branchId             String?
  financialYearId      String
  accountingPeriodId   String

  voucherId            String
  voucherLineId        String                 @unique
  voucherType          AccountingVoucherType
  voucherNumber        String                 @db.VarChar(64)
  lineNumber           Int

  postingDate          DateTime               @db.Date
  documentDate         DateTime               @db.Date

  accountId            String
  partyType            AccountingPartyType?
  partyId              String?
  partyNameSnapshot    String?                @db.VarChar(300)

  debitAmount          Decimal                @default(0) @db.Decimal(18, 4)
  creditAmount         Decimal                @default(0) @db.Decimal(18, 4)
  baseDebitAmount      Decimal                @default(0) @db.Decimal(18, 4)
  baseCreditAmount     Decimal                @default(0) @db.Decimal(18, 4)

  currencyCode         String                 @default("INR") @db.VarChar(8)
  exchangeRate         Decimal                @default(1) @db.Decimal(18, 8)

  costCentreId         String?
  projectReference     String?                @db.VarChar(64)
  departmentReference  String?                @db.VarChar(64)

  sourceModule         String?                @db.VarChar(64)
  sourceDocumentType   String?                @db.VarChar(64)
  sourceDocumentId     String?
  sourceDocumentLineId String?

  isReversal           Boolean                @default(false)
  reversalOfEntryId    String?
  reversedByEntryId    String?

  postedBy             String?
  postedAt             DateTime               @default(now())
  createdAt            DateTime               @default(now())

  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  legalEntity      LegalEntity         @relation(fields: [legalEntityId], references: [id])
  branch           Branch?             @relation(fields: [branchId], references: [id])
  financialYear    FinancialYear       @relation(fields: [financialYearId], references: [id])
  accountingPeriod AccountingPeriod    @relation(fields: [accountingPeriodId], references: [id])
  voucher          AccountingVoucher   @relation(fields: [voucherId], references: [id])
  voucherLine      AccountingVoucherLine @relation(fields: [voucherLineId], references: [id])
  account          Account             @relation(fields: [accountId], references: [id])
  costCentre       CostCentre?         @relation(fields: [costCentreId], references: [id])

  reversalOf       GeneralLedgerEntry? @relation("GlEntryReversalOf", fields: [reversalOfEntryId], references: [id])
  reversedEntries  GeneralLedgerEntry[] @relation("GlEntryReversalOf")
  reversedByEntry  GeneralLedgerEntry? @relation("GlEntryReversedBy", fields: [reversedByEntryId], references: [id])
  reversesEntries  GeneralLedgerEntry[] @relation("GlEntryReversedBy")

  @@index([tenantId, legalEntityId, postingDate])
  @@index([accountId, postingDate])
  @@index([partyType, partyId, postingDate])
  @@index([voucherId])
  @@index([accountingPeriodId])
  @@index([sourceModule, sourceDocumentType, sourceDocumentId], map: "gl_src_doc_idx")
  @@index([costCentreId, postingDate])
  @@index([reversalOfEntryId])
  @@map("general_ledger_entries")
}

model PostingEvent {
  id                   String             @id @default(uuid())
  tenantId             String
  legalEntityId        String

  eventKey             String             @db.VarChar(200)
  eventType            String             @db.VarChar(100)
  eventVersion         Int                @default(1)
  status               PostingEventStatus @default(RECEIVED)

  sourceModule         String?            @db.VarChar(64)
  sourceDocumentType   String?            @db.VarChar(64)
  sourceDocumentId     String?
  sourceDocumentLineId String?

  payloadHash          String             @db.VarChar(64)
  payloadJson          Json?

  voucherId            String?

  numberSeriesId       String?
  reservedVoucherNumber String?           @db.VarChar(64)
  numberReservedAt     DateTime?

  attemptCount         Int                @default(0)
  lastAttemptAt        DateTime?
  processedAt          DateTime?

  errorCode            String?            @db.VarChar(64)
  errorMessage         String?            @db.VarChar(500)

  createdBy            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity        @relation(fields: [legalEntityId], references: [id])
  voucher     AccountingVoucher? @relation(fields: [voucherId], references: [id])

  @@unique([tenantId, legalEntityId, eventKey])
  @@index([status])
  @@index([eventType])
  @@index([sourceModule, sourceDocumentType, sourceDocumentId], map: "post_evt_src_doc_idx")
  @@index([voucherId])
  @@index([createdAt])
  @@index([numberSeriesId])
  @@map("posting_events")
}

model PostingRule {
  id                   String    @id @default(uuid())
  tenantId             String
  legalEntityId        String

  ruleCode             String    @db.VarChar(64)
  ruleName             String    @db.VarChar(200)
  eventType            String    @db.VarChar(100)
  version              Int       @default(1)
  priority             Int       @default(100)

  effectiveFrom        DateTime  @db.Date
  effectiveTo          DateTime? @db.Date

  conditionsJson       Json?
  lineDefinitionsJson  Json

  isSystemRule         Boolean   @default(false)
  isActive             Boolean   @default(true)

  createdBy            String?
  updatedBy            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])

  @@unique([legalEntityId, ruleCode, version])
  @@index([tenantId])
  @@index([legalEntityId, eventType, isActive])
  @@index([legalEntityId, priority])
  @@map("posting_rules")
}

// ─── Accounting Phase 2C2A — Runtime approval requests (not posting) ──────────

enum FinanceApprovalDocumentType {
  JOURNAL
  PAYMENT
  RECEIPT
  CREDIT_NOTE
  DEBIT_NOTE
  PERIOD_REOPEN
}

enum FinanceApprovalRequestStatus {
  PENDING
  APPROVED
  SENT_BACK
  REJECTED
  CANCELLED
}

enum FinanceApprovalStepStatus {
  WAITING
  PENDING
  APPROVED
  SENT_BACK
  REJECTED
  SKIPPED
  CANCELLED
}

/// Runtime approval transaction — distinct from FinanceApprovalRule (configuration).
model FinanceApprovalRequest {
  id                      String                        @id @default(uuid())
  tenantId                String
  legalEntityId           String

  documentType            FinanceApprovalDocumentType
  documentId              String
  documentNumberSnapshot  String?                       @db.VarChar(64)
  documentStatusSnapshot  String?                       @db.VarChar(32)

  cycleNumber             Int                           @default(1)
  status                  FinanceApprovalRequestStatus  @default(PENDING)

  amountBasis             Decimal                       @db.Decimal(18, 4)
  currencyCode            String                        @default("INR") @db.VarChar(8)

  currentLevel            Int                           @default(1)
  totalLevels             Int                           @default(1)

  requestedBy             String?
  requestedAt             DateTime                      @default(now())

  completedAt             DateTime?
  completedBy             String?

  ruleSnapshotJson        Json?
  workflowSnapshotJson    Json?

  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity            @relation(fields: [legalEntityId], references: [id])
  steps       FinanceApprovalStep[]

  @@unique([tenantId, legalEntityId, documentType, documentId, cycleNumber], map: "fin_appr_req_doc_cycle_key")
  @@index([tenantId, legalEntityId, status], map: "fin_appr_req_le_status_idx")
  @@index([documentType, documentId], map: "fin_appr_req_doc_idx")
  @@index([requestedBy, requestedAt], map: "fin_appr_req_requester_idx")
  @@index([currentLevel, status], map: "fin_appr_req_level_status_idx")
  @@map("finance_approval_requests")
}

model FinanceApprovalStep {
  id                  String                     @id @default(uuid())
  tenantId            String
  legalEntityId       String
  approvalRequestId   String

  level               Int
  sequence            Int                        @default(1)

  approverRoleId      String?
  approverUserId      String?

  status              FinanceApprovalStepStatus  @default(WAITING)

  actedBy             String?
  actedAt             DateTime?
  comments            String?                    @db.VarChar(1000)

  delegatedFromUserId String?
  metadataJson        Json?

  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity            @relation(fields: [legalEntityId], references: [id])
  approvalRequest FinanceApprovalRequest @relation(fields: [approvalRequestId], references: [id])

  @@unique([approvalRequestId, level, sequence], map: "fin_appr_step_level_seq_key")
  @@index([tenantId])
  @@index([approvalRequestId, status], map: "fin_appr_step_req_status_idx")
  @@index([approverUserId, status], map: "fin_appr_step_user_status_idx")
  @@map("finance_approval_steps")
}

