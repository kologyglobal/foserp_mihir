// ─── Inventory Phase 3A — Stock ledger foundation ────────────────────────────
// Physical stock SoT. Production must not maintain a parallel ledger.
// Deferred: bin/heat/batch-serial docs, stock count docs, MRP, valuation/GL.

enum InventoryMovementType {
  OPENING
  INWARD
  ISSUE
  ADJUSTMENT
}

enum InventoryReferenceType {
  OPN
  INW
  ISS
  ADJ
  GRN
  ISSUE_TO_WO
  RETURN_FROM_WO
  WIP_RECEIVE
  WIP_TRANSFER
  MOVE_TO_WIP
  MOVE_FROM_WIP
  SA_RECEIPT
  FG_RECEIPT
  DISPATCH
  FG_DISPATCH
  SUBCON_OUT
  SUBCON_IN
  QUALITY_RELEASE
  QUALITY_HOLD
  QUALITY_REJECT
}

enum InventoryReservationDemandType {
  SO
  WO
  DISPATCH
}

enum InventoryReservationStatus {
  ACTIVE
  FULFILLED
  CANCELLED
}

/// Cached balance per item+warehouse. Ledger (InventoryStockMovement) is SoT;
/// balance rows are maintained in the same transaction as movements/reservations.
model InventoryStockBalance {
  id          String   @id @default(uuid())
  tenantId    String
  itemId      String
  warehouseId String
  onHandQty   Decimal  @default(0) @db.Decimal(18, 4)
  reservedQty Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  item      MasterItem      @relation(fields: [itemId], references: [id])
  warehouse MasterWarehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, itemId, warehouseId])
  @@index([tenantId])
  @@index([tenantId, warehouseId])
  @@map("inventory_stock_balances")
}

model InventoryStockMovement {
  id                String                 @id @default(uuid())
  tenantId          String
  movementNumber    String                 @db.VarChar(64)
  movementDate      DateTime               @db.Date
  movementType      InventoryMovementType
  referenceType     InventoryReferenceType
  /// Signed quantity: inward/opening positive; issue negative; adjustment either sign.
  quantity          Decimal                @db.Decimal(18, 4)
  rate              Decimal                @default(0) @db.Decimal(18, 2)
  value             Decimal                @default(0) @db.Decimal(18, 2)
  balanceAfter      Decimal                @db.Decimal(18, 4)
  itemId            String
  warehouseId       String
  /// Soft Production Order reference until Production materials FKs land in Phase 3C.
  workOrderId       String?
  sourceWorkOrderId String?
  parentWorkOrderId String?
  reservationId     String?
  referenceNo       String?                @db.VarChar(100)
  remarks           String?                @db.Text
  idempotencyKey    String?                @db.VarChar(150)
  createdBy         String?
  createdAt         DateTime               @default(now())

  tenant      Tenant                     @relation(fields: [tenantId], references: [id])
  item        MasterItem                 @relation(fields: [itemId], references: [id])
  warehouse   MasterWarehouse            @relation(fields: [warehouseId], references: [id])
  reservation InventoryStockReservation? @relation(fields: [reservationId], references: [id])

  @@unique([tenantId, movementNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, itemId, warehouseId])
  @@index([tenantId, workOrderId])
  @@index([tenantId, movementDate])
  @@index([tenantId, referenceType])
  @@map("inventory_stock_movements")
}

model InventoryStockReservation {
  id                     String                         @id @default(uuid())
  tenantId               String
  reservationNumber      String                         @db.VarChar(64)
  itemId                 String
  warehouseId            String
  quantity               Decimal                        @db.Decimal(18, 4)
  fulfilledQty           Decimal                        @default(0) @db.Decimal(18, 4)
  releasedQty            Decimal                        @default(0) @db.Decimal(18, 4)
  demandType             InventoryReservationDemandType
  demandId               String
  outboundDispatchId     String?
  outboundDispatchLineId String?
  dispatchRequirementId  String?
  salesOrderId           String?
  salesOrderLineId       String?                        @db.VarChar(64)
  referenceNo            String?                        @db.VarChar(100)
  status                 InventoryReservationStatus     @default(ACTIVE)
  sourceVersion          Int                            @default(1)
  remarks                String?                        @db.Text
  idempotencyKey         String?                        @db.VarChar(150)
  cancelledAt            DateTime?
  cancelledBy            String?
  fulfilledAt            DateTime?
  createdBy              String?
  updatedBy              String?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id])
  item                        MasterItem                   @relation(fields: [itemId], references: [id])
  warehouse                   MasterWarehouse              @relation(fields: [warehouseId], references: [id])
  outboundDispatch            OutboundDispatch?            @relation(fields: [outboundDispatchId], references: [id])
  outboundDispatchLine        OutboundDispatchLine?        @relation(fields: [outboundDispatchLineId], references: [id])
  dispatchRequirement         DispatchRequirement?         @relation(fields: [dispatchRequirementId], references: [id])
  movements                   InventoryStockMovement[]
  productionMaterials         ProductionOrderMaterial[]
  dispatchTrackingAllocations DispatchTrackingAllocation[]

  @@unique([tenantId, reservationNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, itemId, warehouseId, status], map: "inv_stock_res_tenant_item_wh_st_idx")
  @@index([tenantId, demandType, demandId], map: "inv_stock_res_tenant_demand_idx")
  @@index([tenantId, outboundDispatchId], map: "inv_stock_res_tenant_ob_dispatch_idx")
  @@index([tenantId, outboundDispatchLineId], map: "inv_stock_res_tenant_ob_line_idx")
  @@map("inventory_stock_reservations")
}

// ─── Dispatch Phase 7C0 — SO line fulfilment + thin FG outbound dispatch ──────
// JSON SO line IDs remain interim; fulfilment ledger keys by salesOrderId + salesOrderLineId.
// Net dispatched qty is derived from CONFIRMED OutboundDispatch lines (not a cached column).
// No pick/pack/challan/invoice/e-Way/POD in this slice.

enum OutboundDispatchStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

/// Optional cancelled-qty ledger per SO JSON line. Dispatched qty is projected from dispatches.
model SalesOrderLineFulfilment {
  id               String   @id @default(uuid())
  tenantId         String
  salesOrderId     String
  /// Matches CrmSalesOrder.lines[].id (UUID string in JSON).
  salesOrderLineId String   @db.VarChar(64)
  cancelledQty     Decimal  @default(0) @db.Decimal(18, 4)
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  salesOrder CrmSalesOrder @relation(fields: [salesOrderId], references: [id])

  @@unique([tenantId, salesOrderId, salesOrderLineId], map: "so_line_fulfil_tenant_so_line_uidx")
  @@index([tenantId, salesOrderId], map: "so_line_fulfil_tenant_so_idx")
  @@map("sales_order_line_fulfilments")
}

enum OutboundDispatchPlanningSource {
  BASIC_7C0
  WORKBENCH_7C1
}

model OutboundDispatch {
  id                     String                         @id @default(uuid())
  tenantId               String
  dispatchNo             String                         @db.VarChar(64)
  status                 OutboundDispatchStatus         @default(DRAFT)
  /// Soft SO link for fulfilment; FK when present for integrity.
  salesOrderId           String?
  salesOrderNo           String?                        @db.VarChar(64)
  /// Phase 7C1 draft planning fields (nullable for 7C0 compatibility).
  customerId             String?
  shipToKey              String?                        @db.VarChar(200)
  shipToAddress          String?                        @db.Text
  plannedDispatchDate    DateTime?                      @db.Date
  preferredWarehouseId   String?
  planningSource         OutboundDispatchPlanningSource @default(BASIC_7C0)
  planBeforeStockAllowed Boolean                        @default(false)
  remarks                String?                        @db.Text
  confirmedAt            DateTime?
  confirmedBy            String?
  cancelledAt            DateTime?
  cancelledBy            String?
  cancellationReason     String?                        @db.Text
  idempotencyKey         String?                        @db.VarChar(150)
  createdBy              String?
  updatedBy              String?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  deletedAt              DateTime?

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id])
  salesOrder                  CrmSalesOrder?               @relation(fields: [salesOrderId], references: [id])
  lines                       OutboundDispatchLine[]
  pickLists                   DispatchPickList[]
  packingSessions             DispatchPackingSession[]
  packages                    DispatchPackage[]
  deliveryChallans            DeliveryChallan[]
  inventoryStockReservations  InventoryStockReservation[]
  dispatchTrackingAllocations DispatchTrackingAllocation[]

  @@unique([tenantId, dispatchNo])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, salesOrderId])
  @@index([tenantId, customerId])
  @@index([tenantId, plannedDispatchDate])
  @@index([tenantId, deletedAt])
  @@map("outbound_dispatches")
}

model OutboundDispatchLine {
  id                    String   @id @default(uuid())
  tenantId              String
  outboundDispatchId    String
  lineNo                Int
  itemId                String
  warehouseId           String
  quantity              Decimal  @db.Decimal(18, 4)
  salesOrderId          String?
  /// Matches CrmSalesOrder.lines[].id when fulfilling an SO line.
  salesOrderLineId      String?  @db.VarChar(64)
  dispatchRequirementId String?
  readyQuantitySnapshot Decimal? @db.Decimal(18, 4)
  inventoryMovementId   String?
  inventoryMovementNo   String?  @db.VarChar(64)
  remarks               String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id])
  outboundDispatch            OutboundDispatch             @relation(fields: [outboundDispatchId], references: [id], onDelete: Cascade)
  item                        MasterItem                   @relation(fields: [itemId], references: [id])
  warehouse                   MasterWarehouse              @relation(fields: [warehouseId], references: [id])
  dispatchRequirement         DispatchRequirement?         @relation(fields: [dispatchRequirementId], references: [id])
  inventoryStockReservations  InventoryStockReservation[]
  dispatchPickLines           DispatchPickLine[]
  dispatchPackageLines        DispatchPackageLine[]
  dispatchTrackingAllocations DispatchTrackingAllocation[]

  @@unique([outboundDispatchId, lineNo])
  @@index([tenantId])
  @@index([tenantId, salesOrderId, salesOrderLineId], map: "ob_dispatch_line_so_line_idx")
  @@index([tenantId, outboundDispatchId])
  @@index([tenantId, dispatchRequirementId], map: "ob_dispatch_line_req_idx")
  @@map("outbound_dispatch_lines")
}

// ─── Dispatch Phase 7C1 — Dispatch Requirement + readiness workbench ─────────
// Commercial SoT remains CrmSalesOrder JSON lines. Requirement is an operational
// projection (not a second order line). Authoritative qty recalculated server-side.

enum DispatchRequirementStatus {
  ACTIVE
  ON_HOLD
  FULFILLED
  CANCELLED
  RECONCILIATION_REQUIRED
}

enum DispatchReadinessStatus {
  NOT_READY
  WAITING_FOR_PRODUCTION
  WAITING_FOR_QUALITY
  WAITING_FOR_STOCK
  PARTIALLY_READY
  READY_TO_DISPATCH
  ALREADY_IN_DRAFT_DISPATCH
  ON_HOLD
  BLOCKED
  FULLY_FULFILLED
  CANCELLED
  RECONCILIATION_REQUIRED
}

model DispatchRequirement {
  id                            String                    @id @default(uuid())
  tenantId                      String
  requirementNumber             String                    @db.VarChar(64)
  salesOrderId                  String
  salesOrderLineId              String                    @db.VarChar(64)
  customerId                    String
  shipToKey                     String?                   @db.VarChar(200)
  shipToAddress                 String?                   @db.Text
  itemId                        String?
  productId                     String?
  uomCode                       String?                   @db.VarChar(32)
  plantCode                     String?                   @db.VarChar(32)
  preferredWarehouseId          String?
  orderedQuantitySnapshot       Decimal                   @default(0) @db.Decimal(18, 4)
  cancelledQuantitySnapshot     Decimal                   @default(0) @db.Decimal(18, 4)
  netOrderedQuantitySnapshot    Decimal                   @default(0) @db.Decimal(18, 4)
  netDispatchedQuantitySnapshot Decimal                   @default(0) @db.Decimal(18, 4)
  remainingQuantitySnapshot     Decimal                   @default(0) @db.Decimal(18, 4)
  currentDraftDispatchQuantity  Decimal                   @default(0) @db.Decimal(18, 4)
  requestedDeliveryDate         DateTime?                 @db.Date
  committedDeliveryDate         DateTime?                 @db.Date
  priority                      String                    @default("MEDIUM") @db.VarChar(16)
  commercialHold                Boolean                   @default(false)
  dispatchHold                  Boolean                   @default(false)
  holdReason                    String?                   @db.VarChar(500)
  readinessStatus               DispatchReadinessStatus   @default(NOT_READY)
  primaryBlockerCode            String?                   @db.VarChar(64)
  status                        DispatchRequirementStatus @default(ACTIVE)
  sourceVersion                 Int                       @default(1)
  sourceFingerprint             String?                   @db.VarChar(128)
  lastCalculatedAt              DateTime?
  createdBy                     String?
  updatedBy                     String?
  createdAt                     DateTime                  @default(now())
  updatedAt                     DateTime                  @updatedAt
  deletedAt                     DateTime?

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id])
  salesOrder                 CrmSalesOrder               @relation(fields: [salesOrderId], references: [id])
  outboundDispatchLines      OutboundDispatchLine[]
  inventoryStockReservations InventoryStockReservation[]

  @@unique([tenantId, salesOrderId, salesOrderLineId], map: "dispatch_req_tenant_so_line_uidx")
  @@unique([tenantId, requirementNumber], map: "dispatch_req_tenant_number_uidx")
  @@index([tenantId, status], map: "dispatch_req_tenant_status_idx")
  @@index([tenantId, readinessStatus], map: "dispatch_req_tenant_ready_idx")
  @@index([tenantId, requestedDeliveryDate], map: "dispatch_req_tenant_due_idx")
  @@index([tenantId, customerId], map: "dispatch_req_tenant_customer_idx")
  @@index([tenantId, itemId], map: "dispatch_req_tenant_item_idx")
  @@index([tenantId, salesOrderId], map: "dispatch_req_tenant_so_idx")
  @@index([tenantId, deletedAt], map: "dispatch_req_tenant_del_idx")
  @@map("dispatch_requirements")
}

// ─── Dispatch Phase 7C2 — FG reservation + allocation-only picking ─────────────
// Reservation increases reservedQty only; pick/unpick does not post stock movements.

enum DispatchPickListStatus {
  DRAFT
  RELEASED
  IN_PROGRESS
  PARTIALLY_PICKED
  PICKED
  BLOCKED
  CANCELLED
}

enum DispatchPickLineStatus {
  NOT_STARTED
  IN_PROGRESS
  PARTIALLY_PICKED
  PICKED
  SHORT
  BLOCKED
  CANCELLED
}

enum DispatchPickEventType {
  PICK
  UNPICK
  SHORTAGE
  SHORTAGE_RESOLVED
  ASSIGNMENT_CHANGE
  RELEASE
  START
  COMPLETE
  CANCEL
}

enum DispatchTrackingAllocationStatus {
  ALLOCATED
  PICKED
  RELEASED
  CONSUMED
  CANCELLED
}

enum DispatchShortageResolutionStatus {
  OPEN
  RESOLVED
  ACCEPTED_PARTIAL
  DISMISSED
}

model DispatchTrackingAllocation {
  id                     String                           @id @default(uuid())
  tenantId               String
  inventoryReservationId String
  outboundDispatchId     String
  outboundDispatchLineId String
  itemId                 String
  warehouseId            String
