// ─── Accounting Phase 4A1 — Vendor invoice / AP open-item foundation ─────────
// One financial document (VendorInvoice) for purchase/expense/service/asset/mixed bills.
// Reuses MasterVendor identity via soft vendorId (no FinanceVendor). No calculation/API/posting in 4A1.
// Amount semantics (documented for Phase 4A2+; formulas not enforced here):
//   grossAmount              = total before discount and tax
//   discountAmount           = commercial discount
//   taxableAmount            = amount on which GST is calculated
//   invoiceGrandTotal        = final supplier invoice value before TDS settlement effect
//   tdsAmount                = statutory amount withheld per configured recognition policy
//   vendorPayableAmount      = vendor liability recognised by future posting logic
// Positive amounts only — direction is via PayableOpenItemSide, never negative money fields.

enum VendorInvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  READY_TO_POST
  POSTED
  CANCELLED
  REVERSED
}

enum VendorInvoiceType {
  GOODS
  SERVICE
  EXPENSE
  ASSET
  MIXED
}

enum VendorInvoiceLineType {
  ITEM
  SERVICE
  EXPENSE
  ASSET
  FREIGHT
  OTHER_CHARGE
}

enum VendorInvoiceSourceLinkType {
  PURCHASE_ORDER
  GOODS_RECEIPT
  PURCHASE_RECEIPT
  CONTRACT
  PROJECT
  OTHER
}

/// Purchase-side GST treatment — distinct from SalesInvoiceTaxTreatment (AR sales).
enum VendorInvoiceTaxTreatment {
  REGULAR
  REVERSE_CHARGE
  IMPORT_GOODS
  IMPORT_SERVICE
  SEZ
  NON_GST
  EXEMPT
  NIL_RATED
}

/// Accounting review state for input-tax credit — not statutory determination.
enum InputTaxCreditEligibility {
  PENDING_REVIEW
  ELIGIBLE
  PARTIALLY_ELIGIBLE
  INELIGIBLE
}

enum TdsRecognitionMode {
  NOT_APPLICABLE
  AT_INVOICE
  AT_PAYMENT
}

enum PayableOpenItemSide {
  /// Vendor invoice liability.
  CREDIT
  /// Payment / advance / debit note / credit adjustment (future).
  DEBIT
}

enum PayableOpenItemDocumentType {
  VENDOR_INVOICE
  VENDOR_PAYMENT
  VENDOR_ADVANCE
  VENDOR_DEBIT_NOTE
  VENDOR_CREDIT_ADJUSTMENT
  OPENING_BALANCE
}

enum PayableOpenItemStatus {
  OPEN
  PARTIALLY_SETTLED
  SETTLED
  ON_HOLD
  DISPUTED
  REVERSED
  CANCELLED
}

model VendorInvoice {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  /// MasterVendor.id — soft reference (no FK); same vendor identity as Purchase/Inventory.
  vendorId        String
  financialYearId String

  draftReference      String  @db.VarChar(64)
  /// FOS internal final number — null until Phase 4A4 posting.
  vendorInvoiceNumber String? @db.VarChar(64)

  supplierInvoiceNumber           String   @db.VarChar(128)
  supplierInvoiceNumberNormalized String   @db.VarChar(128)
