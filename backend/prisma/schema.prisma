  itemCategoryId      String?
  operationName       String?                     @db.VarChar(120)
  workCenterId        String?
  effectiveFrom       DateTime                    @default(now())
  effectiveTo         DateTime?
  revision            String?                     @db.VarChar(32)
  samplingMethod      QualitySamplingMethod?      @default(FULL_INSPECTION)
  sampleSizeMode      String?                     @db.VarChar(32)
  fixedSampleSize     Decimal?                    @db.Decimal(18, 4)
  samplePercentage    Decimal?                    @db.Decimal(7, 4)
  certificateRequired Boolean                     @default(false)
  currentRevisionId   String?
  acceptanceRule      String?                     @db.VarChar(64)
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  tenant      Tenant                          @relation(fields: [tenantId], references: [id])
  item        MasterItem?                     @relation(fields: [itemId], references: [id])
  lines       QualityInspectionPlanLine[]
  revisions   QualityInspectionPlanRevision[]
  inspections QualityInspection[]

  @@unique([tenantId, planCode])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, itemId])
  @@index([tenantId, deletedAt])
  @@map("quality_inspection_plans")
}

model QualityInspectionPlanRevision {
  id                String                    @id @default(uuid())
  tenantId          String
  inspectionPlanId  String
  revisionNumber    Int
  revisionCode      String                    @db.VarChar(32)
  status            QualityPlanRevisionStatus @default(DRAFT)
  effectiveFrom     DateTime                  @default(now())
  effectiveTo       DateTime?
  changeReason      String?                   @db.Text
  approvedBy        String?
  approvedAt        DateTime?
