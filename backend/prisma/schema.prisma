  fixedAssetDisposalDocument    FixedAssetDisposal?        @relation("FixedAssetDisposalDocumentPostingEvent")
  fixedAssetDisposalReversal    FixedAssetDisposal?        @relation("FixedAssetDisposalReversalPostingEvent")
