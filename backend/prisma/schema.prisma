  outboundDispatchLine OutboundDispatchLine      @relation(fields: [outboundDispatchLineId], references: [id])
  item                 MasterItem                @relation(fields: [itemId], references: [id])
  warehouse            MasterWarehouse           @relation(fields: [warehouseId], references: [id])

  @@index([tenantId, outboundDispatchId], map: "dispatch_track_alloc_ob_dispatch_idx")
  @@index([tenantId, outboundDispatchLineId], map: "dispatch_track_alloc_ob_line_idx")
  @@index([tenantId, inventoryReservationId], map: "dispatch_track_alloc_res_idx")
  @@map("dispatch_tracking_allocations")
}

model DispatchPickList {
  id                 String                 @id @default(uuid())
  tenantId           String
  pickListNumber     String                 @db.VarChar(64)
  outboundDispatchId String
  warehouseId        String
  assignedTo         String?
  plannedPickDate    DateTime?              @db.Date
  priority           String                 @default("MEDIUM") @db.VarChar(16)
  status             DispatchPickListStatus @default(DRAFT)
  releasedAt         DateTime?
  releasedBy         String?
  startedAt          DateTime?
  startedBy          String?
  completedAt        DateTime?
  completedBy        String?
  sourceVersion      Int                    @default(1)
  idempotencyKey     String?                @db.VarChar(150)
