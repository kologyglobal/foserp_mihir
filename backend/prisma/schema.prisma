  sentQty             Decimal              @default(0) @db.Decimal(18, 4)
  receivedQty         Decimal              @default(0) @db.Decimal(18, 4)
  acceptedQty         Decimal              @default(0) @db.Decimal(18, 4)
  rejectedQty         Decimal              @default(0) @db.Decimal(18, 4)
  reworkQty           Decimal              @default(0) @db.Decimal(18, 4)
  rate                Decimal              @default(0) @db.Decimal(18, 4)
  rateBasis           JobWorkRateBasis     @default(PER_PIECE)
  expectedCost        Decimal              @default(0) @db.Decimal(18, 4)
  expectedReturnDate  DateTime?            @db.Date
  invoiceStatus       JobWorkInvoiceStatus @default(NONE)
  invoiceId           String?
  invoiceNo           String?              @db.VarChar(100)
  invoiceAmount       Decimal?             @db.Decimal(18, 4)
  materialWarehouseId String
  receiptWarehouseId  String
  plantId             String?
  qualityRequired     Boolean              @default(false)
  materialSentAt      DateTime?
  vendorChallan       String?              @db.VarChar(100)
  transporter         String?              @db.VarChar(200)
  vehicle             String?              @db.VarChar(100)
  deliveryAddress     String?              @db.Text
  drawingRevision     String?              @db.VarChar(100)
  qualityInstructions String?              @db.Text
  remarks             String?              @db.Text
  materialToSend      String?              @db.Text
  differenceApproved  Boolean              @default(false)
  differenceReason    String?              @db.Text
  idempotencyKey      String?              @db.VarChar(150)
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  tenant             Tenant                    @relation(fields: [tenantId], references: [id])
  vendor             MasterVendor              @relation(fields: [vendorId], references: [id])
  productionOrder    ProductionOrder?          @relation(fields: [productionOrderId], references: [id])
  item               MasterItem                @relation("JobWorkOutputItem", fields: [itemId], references: [id])
  materialWarehouse  MasterWarehouse           @relation("JobWorkMaterialWarehouse", fields: [materialWarehouseId], references: [id])
  receiptWarehouse   MasterWarehouse           @relation("JobWorkReceiptWarehouse", fields: [receiptWarehouseId], references: [id])
  materialLines      JobWorkMaterialLine[]
  dispatches         JobWorkDispatch[]
  receipts           JobWorkReceipt[]
  qualityInspections QualityInspection[]
  runtimeChanges     ProductionRuntimeChange[]

  @@unique([tenantId, jwNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@index([tenantId, productionOrderId])
  @@index([tenantId, deletedAt])
  @@map("job_work_orders")
}

model JobWorkMaterialLine {
  id                String                    @id @default(uuid())
  tenantId          String
  jobWorkOrderId    String
  lineNo            Int
  itemId            String
  uomId             String?
  requiredQty       Decimal                   @default(0) @db.Decimal(18, 4)
  sentQty           Decimal                   @default(0) @db.Decimal(18, 4)
  additionalSentQty Decimal                   @default(0) @db.Decimal(18, 4)
  consumedQty       Decimal                   @default(0) @db.Decimal(18, 4)
  returnedQty       Decimal                   @default(0) @db.Decimal(18, 4)
  scrapReturnedQty  Decimal                   @default(0) @db.Decimal(18, 4)
  status            JobWorkMaterialLineStatus @default(PENDING)
  remarks           String?                   @db.Text
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  jobWorkOrder  JobWorkOrder          @relation(fields: [jobWorkOrderId], references: [id], onDelete: Cascade)
  item          MasterItem            @relation("JobWorkMaterialItem", fields: [itemId], references: [id])
  dispatchLines JobWorkDispatchLine[]

  @@unique([jobWorkOrderId, lineNo])
  @@index([tenantId, jobWorkOrderId])
  @@index([tenantId, itemId])
  @@map("job_work_material_lines")
}

model JobWorkDispatch {
  id             String   @id @default(uuid())
  tenantId       String
  jobWorkOrderId String
  dispatchNumber String?  @db.VarChar(64)
  dispatchedAt   DateTime
  vendorChallan  String?  @db.VarChar(100)
  vehicle        String?  @db.VarChar(100)
  transporter    String?  @db.VarChar(200)
  remarks        String?  @db.Text
  createdBy      String?
  createdAt      DateTime @default(now())

  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  jobWorkOrder JobWorkOrder          @relation(fields: [jobWorkOrderId], references: [id], onDelete: Cascade)
  lines        JobWorkDispatchLine[]

  @@index([tenantId, jobWorkOrderId])
  @@map("job_work_dispatches")
}

model JobWorkDispatchLine {
  id             String  @id @default(uuid())
  tenantId       String
  dispatchId     String
  materialLineId String
  quantity       Decimal @db.Decimal(18, 4)
  batchOrSerial  String? @db.VarChar(200)

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  dispatch     JobWorkDispatch     @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  materialLine JobWorkMaterialLine @relation(fields: [materialLineId], references: [id])

  @@index([tenantId, dispatchId])
  @@map("job_work_dispatch_lines")
}

model JobWorkReceipt {
  id                  String   @id @default(uuid())
  tenantId            String
  jobWorkOrderId      String
  receivedAt          DateTime
  receivedQty         Decimal  @db.Decimal(18, 4)
  acceptedQty         Decimal  @db.Decimal(18, 4)
  rejectedQty         Decimal  @default(0) @db.Decimal(18, 4)
  reworkQty           Decimal  @default(0) @db.Decimal(18, 4)
  scrapReturned       Decimal  @default(0) @db.Decimal(18, 4)
  unusedReturned      Decimal  @default(0) @db.Decimal(18, 4)
  vendorChallan       String?  @db.VarChar(100)
  batchOrSerial       String?  @db.VarChar(200)
  remarks             String?  @db.Text
  qualityInspectionId String?
  createdBy           String?
  createdAt           DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  jobWorkOrder JobWorkOrder @relation(fields: [jobWorkOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId, jobWorkOrderId])
  @@map("job_work_receipts")
}

// ─── Manufacturing Phase 5A — Runtime change requests ───────────────────────
// Manufacturing-scoped approval workflow (mirrors the finance approval engine's
// request/approve/reject/apply shape) for mid-execution work order changes.
// Deliberately NOT wired into FinanceApprovalDocumentType — the finance approval
// engine stays document-locked; approval here is local to ProductionRuntimeChange
// (approve/reject gated by permission) plus a configurable rule table for
// risk/approval thresholds per change type.

enum ProductionRuntimeChangeType {
  QUANTITY_CHANGE
  DUE_DATE_CHANGE
  PRIORITY_CHANGE
  SUPERVISOR_CHANGE
  OPERATOR_CHANGE
  MACHINE_CHANGE
  WORK_CENTRE_CHANGE
  ADD_OPERATION
  REPEAT_OPERATION
  SKIP_OPERATION
  CONVERT_TO_JOB_WORK
  WORK_ORDER_HOLD
  WORK_ORDER_RESUME
  STAGE_HOLD
  STAGE_RESUME
}

enum ProductionRuntimeChangeStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  APPLIED
  CANCELLED
  FAILED
}

enum ProductionRuntimeChangeRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Configurable per-tenant risk/approval threshold rules for runtime changes.
/// Falls back to hard-coded defaults (see runtime-change-risk.service.ts) when no
/// active rule matches a given changeType.
model ManufacturingRuntimeChangeRule {
  id               String                      @id @default(uuid())
  tenantId         String
  changeType       ProductionRuntimeChangeType
  name             String                      @db.VarChar(200)
  approvalRequired Boolean
  riskLevel        ProductionRuntimeChangeRisk
  /// e.g. { "qtyTolerancePct": 10, "dueDateDelayDays": 3 }
  configJson       Json?
  isActive         Boolean                     @default(true)
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  tenant  Tenant                    @relation(fields: [tenantId], references: [id])
  changes ProductionRuntimeChange[]

  @@unique([tenantId, changeType, name])
  @@index([tenantId])
  @@index([tenantId, changeType, isActive], name: "mfg_runtime_change_rules_tenant_type_active_idx")
  @@map("manufacturing_runtime_change_rules")
}

/// A single requested/applied mid-execution change against a Work Order. Immutable
/// history: never rewrites stage ledger, completed quantities, quality, job work
/// dispatches, or inventory — only remaining targets / header fields / incomplete ops.
model ProductionRuntimeChange {
  id                      String                        @id @default(uuid())
  tenantId                String
  changeNumber            String                        @db.VarChar(64)
  productionOrderId       String
  stageId                 String?
  operationId             String?
  assignmentId            String?
  jobWorkOrderId          String?
  changeType              ProductionRuntimeChangeType
  status                  ProductionRuntimeChangeStatus @default(DRAFT)
  riskLevel               ProductionRuntimeChangeRisk   @default(LOW)
  approvalRequired        Boolean                       @default(false)
  approvalRuleId          String?
  requestedBy             String?
  requestedAt             DateTime?
  reason                  String                        @db.Text
  businessJustification   String?                       @db.Text
  effectiveDate           DateTime?
  originalValueJson       Json
  proposedValueJson       Json
  approvedValueJson       Json?
  impactSummaryJson       Json?
  validationSummaryJson   Json?
  approvedBy              String?
  approvedAt              DateTime?
  rejectedBy              String?
  rejectedAt              DateTime?
  rejectionReason         String?                       @db.Text
  appliedBy               String?
  appliedAt               DateTime?
  applicationReference    String?                       @db.VarChar(150)
  failureReason           String?                       @db.Text
  /// ProductionOrder.updatedAt captured at preview/draft time — used to detect a
  /// stale change request when the work order moved on before apply.
  orderUpdatedAtAtRequest DateTime?
  idempotencyKey          String?                       @db.VarChar(150)
  createdBy               String?
  updatedBy               String?
  createdAt               DateTime                      @default(now())
  updatedAt               DateTime                      @updatedAt
  deletedAt               DateTime?

  tenant          Tenant                          @relation(fields: [tenantId], references: [id])
  productionOrder ProductionOrder                 @relation(fields: [productionOrderId], references: [id])
  stage           ProductionOrderStage?           @relation(fields: [stageId], references: [id])
  operation       ProductionOrderOperation?       @relation(fields: [operationId], references: [id])
  assignment      ProductionAssignment?           @relation(fields: [assignmentId], references: [id])
  jobWorkOrder    JobWorkOrder?                   @relation(fields: [jobWorkOrderId], references: [id])
  approvalRule    ManufacturingRuntimeChangeRule? @relation(fields: [approvalRuleId], references: [id])

  @@unique([tenantId, changeNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, productionOrderId])
  @@index([tenantId, status])
  @@index([tenantId, changeType])
  @@index([tenantId, deletedAt])
  @@map("production_runtime_changes")
}

// ─── Manufacturing Phase 5B — Material / WIP / WO transfers ───────────────────
// Manufacturing owns the transfer intent document; Inventory posts physical stock
// (paired ISSUE + INWARD). No second stock ledger in Production. No GL / split / reverse.

enum ProductionWipMovementType {
  LOCATION_WIP
  MATERIAL_RELOCATE
  WO_TO_WO
}

enum ProductionWipMovementStatus {
  DRAFT
  POSTED
  CANCELLED
}

model ProductionWipMovement {
  id                      String                      @id @default(uuid())
  tenantId                String
  movementNumber          String                      @db.VarChar(64)
  movementType            ProductionWipMovementType
  status                  ProductionWipMovementStatus @default(POSTED)
  productionOrderId       String
  targetProductionOrderId String?
  itemId                  String
  quantity                Decimal                     @db.Decimal(18, 4)
  uomId                   String?
  fromWarehouseId         String
  toWarehouseId           String
  stageId                 String?
  operationId             String?
  materialLineId          String?
  reason                  String                      @db.Text
  remarks                 String?                     @db.Text
  physicalPosted          Boolean                     @default(false)
  outboundMovementId      String?
  inboundMovementId       String?
  idempotencyKey          String?                     @db.VarChar(150)
  postedBy                String?
  postedAt                DateTime?
  createdBy               String?
  updatedBy               String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  deletedAt               DateTime?

  tenant                Tenant                    @relation(fields: [tenantId], references: [id])
  productionOrder       ProductionOrder           @relation("WipMovementSourceOrder", fields: [productionOrderId], references: [id])
  targetProductionOrder ProductionOrder?          @relation("WipMovementTargetOrder", fields: [targetProductionOrderId], references: [id])
  item                  MasterItem                @relation(fields: [itemId], references: [id])
  uom                   MasterUom?                @relation(fields: [uomId], references: [id])
  fromWarehouse         MasterWarehouse           @relation("WipMoveFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse           MasterWarehouse           @relation("WipMoveToWarehouse", fields: [toWarehouseId], references: [id])
  stage                 ProductionOrderStage?     @relation(fields: [stageId], references: [id])
  operation             ProductionOrderOperation? @relation(fields: [operationId], references: [id])
  materialLine          ProductionOrderMaterial?  @relation(fields: [materialLineId], references: [id])

  @@unique([tenantId, movementNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId], map: "prod_wip_move_tenant_idx")
  @@index([tenantId, productionOrderId], map: "prod_wip_move_tenant_wo_idx")
  @@index([tenantId, targetProductionOrderId], map: "prod_wip_move_tenant_tgt_idx")
  @@index([tenantId, status], map: "prod_wip_move_tenant_status_idx")
  @@index([tenantId, deletedAt], map: "prod_wip_move_tenant_del_idx")
  @@map("production_wip_movements")
}

// ─── Manufacturing Phase 7A4 — Finished goods receipt document ───────────────

enum ProductionFgReceiptStatus {
  DRAFT
  POSTED
  PARTIALLY_REVERSED
  FULLY_REVERSED
  CANCELLED
}

model ProductionFinishedGoodsReceipt {
  id                  String                    @id @default(uuid())
  tenantId            String
  receiptNumber       String                    @db.VarChar(64)
  productionOrderId   String
  itemId              String
  uomId               String
  receiptQuantity     Decimal                   @db.Decimal(18, 4)
  acceptedQuantity    Decimal                   @db.Decimal(18, 4)
  /// Cumulative qty reversed via Phase 5C (acceptedQuantity stays immutable).
  reversedQuantity    Decimal                   @default(0) @db.Decimal(18, 4)
  warehouseId         String
  qualityInspectionId String?
  qualityStatus       String?                   @db.VarChar(32)
  batchOrLotNumber    String?                   @db.VarChar(64)
  serialNumbersJson   Json?
  inventoryMovementId String?
  status              ProductionFgReceiptStatus @default(DRAFT)
  receiptDate         DateTime                  @db.Date
  remarks             String?                   @db.Text
  idempotencyKey      String?                   @db.VarChar(150)
  reversalStatus      String?                   @db.VarChar(32)
  latestCorrectionId  String?
  postedBy            String?
  postedAt            DateTime?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  deletedAt           DateTime?

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])
  item            MasterItem      @relation(fields: [itemId], references: [id])
  uom             MasterUom       @relation(fields: [uomId], references: [id])
  warehouse       MasterWarehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, receiptNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId], map: "prod_fg_rcp_tenant_idx")
  @@index([tenantId, productionOrderId], map: "prod_fg_rcp_tenant_wo_idx")
  @@index([tenantId, status], map: "prod_fg_rcp_tenant_status_idx")
  @@index([tenantId, deletedAt], map: "prod_fg_rcp_tenant_del_idx")
  @@map("production_finished_goods_receipts")
}

// ─── Manufacturing Phase 5C — Corrections / reversals ─────────────────────────
// Compensating transactions only. Never edit/delete posted ledgers or stock rows.
// Manufacturing-local approval (same pattern as Phase 5A runtime changes) — not Finance GL.

enum ManufacturingCorrectionTransactionType {
  PRODUCTION_PROGRESS
  DAILY_PRODUCTION_LINE
  DAILY_PRODUCTION_BATCH
  MATERIAL_ISSUE
  MATERIAL_RETURN
  ADDITIONAL_MATERIAL_ISSUE
  MATERIAL_TRANSFER
  RESERVATION_TRANSFER
  WIP_MOVEMENT
  FG_RECEIPT
  JOB_WORK_DISPATCH
  JOB_WORK_RECEIPT
  JOB_WORK_RETURN
  JOB_WORK_RECONCILIATION
  WORK_ORDER_SPLIT
  QUALITY_DECISION
}

enum ManufacturingCorrectionType {
  REVERSE_ONLY
  REVERSE_AND_REPLACE
  QUANTITY_CORRECTION
  DATE_CORRECTION
  REFERENCE_CORRECTION
  FULL_BATCH_REVERSAL
  PARTIAL_REVERSAL
  SUPERSEDE_DECISION
}

enum ManufacturingCorrectionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  APPLYING
  APPLIED
  FAILED
  CANCELLED
}

enum ManufacturingCorrectionRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ManufacturingSourceReversalStatus {
  NOT_REVERSED
  PARTIALLY_REVERSED
  FULLY_REVERSED
  CORRECTED
  SUPERSEDED
}

model ManufacturingTransactionCorrection {
  id                       String                                 @id @default(uuid())
  tenantId                 String
  correctionNumber         String                                 @db.VarChar(64)
  transactionType          ManufacturingCorrectionTransactionType
  correctionType           ManufacturingCorrectionType
  status                   ManufacturingCorrectionStatus          @default(DRAFT)
  riskLevel                ManufacturingCorrectionRisk            @default(MEDIUM)
  sourceEntityType         String                                 @db.VarChar(64)
  sourceEntityId           String
  sourceTransactionId      String?
  productionOrderId        String?
  stageId                  String?
  operationId              String?
  inventoryMovementId      String?
  productionLedgerId       String?
  jobWorkOrderId           String?
