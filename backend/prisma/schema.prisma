// ─── Accounting Phase 4D2 — AP-to-GL reconciliation + close gate ─────────────
// Read-only against GL / open items / periods: this phase persists reconciliation
// runs and close-gate runs only. It never mutates AccountingPeriod, GeneralLedgerEntry,
// PayableOpenItem, or any voucher/posting-event row.

/// Execution lifecycle of a persisted reconciliation run (distinct from the
/// business outcome captured in PayableReconciliationStatus).
enum PayableReconciliationRunStatus {
  STARTED
  COMPLETED
  FAILED
}

/// Business outcome of a completed reconciliation run.
enum PayableReconciliationStatus {
  MATCHED
  MATCHED_WITH_WARNINGS
  MISMATCHED
  FAILED
}

enum PayableReconciliationSourceMode {
  /// asOfDate == today — subledger balances read directly from PayableOpenItem.outstandingAmount.
  CURRENT_BALANCE
  /// asOfDate in the past — subledger balances reconstructed from dated open-item/allocation/reversal facts.
  HISTORICAL_RECONSTRUCTION
}

enum PayableReconciliationExceptionSeverity {
  INFO
  WARNING
  ERROR
  BLOCKER
}

enum PayableReconciliationExceptionCategory {
  CONTROL_ACCOUNT_CONFIGURATION
  SUBLEDGER_BALANCE
  GENERAL_LEDGER_BALANCE
  SOURCE_DOCUMENT
  ACCOUNTING_VOUCHER
  GENERAL_LEDGER_ENTRY
  OPEN_ITEM
  ALLOCATION
  ALLOCATION_REVERSAL
  DOCUMENT_REVERSAL
  POSTING_EVENT
  VENDOR_PARTY
  CURRENCY
  BRANCH
  PERIOD_READINESS
  WORKFLOW
  DATA_INTEGRITY
}

enum PayableCloseGateStatus {
  PASS
  PASS_WITH_WARNINGS
  BLOCKED
  FAILED
}

enum PayableCloseGateCheckStatus {
  PASSED
  WARNING
  BLOCKED
  FAILED
}

/// Persisted AP-to-GL reconciliation run — one row per POST /reconciliation/runs invocation.
/// Unlike AR reconciliation (compute-on-read), AP reconciliation is durable/auditable so a
/// close gate can reference a specific completed run by id.
model PayableReconciliationRun {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  asOfDate   DateTime                        @db.Date
  sourceMode PayableReconciliationSourceMode
  runStatus  PayableReconciliationRunStatus  @default(STARTED)
  status     PayableReconciliationStatus?

  baseCurrency String  @db.VarChar(8)
  tolerance    Decimal @db.Decimal(18, 4)

  includeVendorLevel Boolean @default(true)

  controlAccountCount    Int @default(0)
  matchedAccountCount    Int @default(0)
  mismatchedAccountCount Int @default(0)

  glTotal        Decimal @default(0) @db.Decimal(18, 4)
  subledgerTotal Decimal @default(0) @db.Decimal(18, 4)
  variance       Decimal @default(0) @db.Decimal(18, 4)

  exceptionCount Int @default(0)
  infoCount      Int @default(0)
  warningCount   Int @default(0)
  errorCount     Int @default(0)
  blockerCount   Int @default(0)

  vendorCount         Int @default(0)
  vendorMismatchCount Int @default(0)

  /// Free-text limitations surfaced to callers (e.g. historical reconstruction caveats).
  limitations Json?

  errorMessage String? @db.VarChar(1000)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant                               @relation(fields: [tenantId], references: [id])
  legalEntity    LegalEntity                          @relation(fields: [legalEntityId], references: [id])
  accountResults PayableReconciliationAccountResult[]
  exceptions     PayableReconciliationException[]
  closeGateRuns  PayableCloseGateRun[]

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([tenantId, legalEntityId, asOfDate], map: "pay_recon_run_le_date_idx")
  @@index([tenantId, legalEntityId, status], map: "pay_recon_run_le_status_idx")
  @@index([createdAt])
  @@map("payable_reconciliation_runs")
}

/// Per control-account snapshot of GL vs. subledger balance for a reconciliation run.
/// GL balance convention: baseCredit − baseDebit (liability normal balance).
/// Subledger balance convention: CREDIT outstanding − DEBIT outstanding.
model PayableReconciliationAccountResult {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String
  runId         String

  accountId   String
  accountCode String? @db.VarChar(32)
  accountName String? @db.VarChar(200)

  glBalance        Decimal @db.Decimal(18, 4)
  subledgerBalance Decimal @db.Decimal(18, 4)
  variance         Decimal @db.Decimal(18, 4)
  matched          Boolean @default(false)
  openItemCount    Int     @default(0)

  createdAt DateTime @default(now())

  tenant      Tenant                   @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity              @relation(fields: [legalEntityId], references: [id])
  run         PayableReconciliationRun @relation(fields: [runId], references: [id])
  account     Account                  @relation(fields: [accountId], references: [id])

  @@unique([runId, accountId], map: "pay_recon_acct_run_account_key")
  @@index([tenantId, legalEntityId], map: "pay_recon_acct_le_idx")
  @@index([runId])
  @@index([accountId])
  @@map("payable_reconciliation_account_results")
}

/// Data-quality / control finding raised by a reconciliation run. Acknowledgement is the
/// only mutation this phase performs on its own rows — never on GL / open-item / period data.
model PayableReconciliationException {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String
  runId         String

  severity PayableReconciliationExceptionSeverity
  category PayableReconciliationExceptionCategory
  code     String                                 @db.VarChar(64)
  message  String                                 @db.VarChar(1000)

  accountId    String?
  vendorId     String?
  openItemId   String?
  voucherId    String?
  documentType String? @db.VarChar(64)
  documentId   String?

  details Json?

  isAcknowledged      Boolean   @default(false)
  acknowledgedBy      String?
  acknowledgedAt      DateTime?
  acknowledgementNote String?   @db.VarChar(500)

  createdAt DateTime @default(now())

  tenant      Tenant                   @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity              @relation(fields: [legalEntityId], references: [id])
  run         PayableReconciliationRun @relation(fields: [runId], references: [id])

  @@index([tenantId, legalEntityId], map: "pay_recon_exc_le_idx")
  @@index([runId])
  @@index([runId, severity], map: "pay_recon_exc_run_severity_idx")
  @@index([code])
  @@index([vendorId])
  @@index([openItemId])
  @@map("payable_reconciliation_exceptions")
}

/// Persisted period-close readiness gate for Accounts Payable. Read-only against
/// AccountingPeriod — never updates period status; that remains a manual Finance action.
model PayableCloseGateRun {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  periodId String
  asOfDate DateTime @db.Date

  status PayableCloseGateStatus

  reconciliationRunId String?

  checksTotal   Int @default(0)
  checksPassed  Int @default(0)
  checksWarning Int @default(0)
  checksBlocked Int @default(0)
  checksFailed  Int @default(0)

  summary Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
  legalEntity       LegalEntity               @relation(fields: [legalEntityId], references: [id])
  period            AccountingPeriod          @relation(fields: [periodId], references: [id])
  reconciliationRun PayableReconciliationRun? @relation(fields: [reconciliationRunId], references: [id])
  checks            PayableCloseGateCheck[]

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([tenantId, legalEntityId, periodId], map: "pay_close_gate_le_period_idx")
  @@index([tenantId, legalEntityId, status], map: "pay_close_gate_le_status_idx")
  @@index([periodId])
  @@index([reconciliationRunId])
  @@index([createdAt])
  @@map("payable_close_gate_runs")
}

/// Individual pass/warn/block/fail check within a PayableCloseGateRun.
model PayableCloseGateCheck {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String
  runId         String

  checkCode String                      @db.VarChar(64)
  checkName String                      @db.VarChar(200)
  status    PayableCloseGateCheckStatus
  message   String                      @db.VarChar(1000)
  details   Json?

  createdAt DateTime @default(now())

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity         @relation(fields: [legalEntityId], references: [id])
  run         PayableCloseGateRun @relation(fields: [runId], references: [id])

  @@index([tenantId, legalEntityId], map: "pay_close_gate_chk_le_idx")
  @@index([runId])
  @@index([checkCode])
  @@map("payable_close_gate_checks")
}

// ─── Finance Phase 5A1 — Bank & Cash treasury foundation ─────────────────────
// Treasury account master (bank/cash/clearing) + GL mapping + payment-account
// routing + bank reconciliation settings + bank-statement DB foundation.
// NO statement import/match/reconcile execution APIs, NO GL/voucher mutation
// from any of these setup endpoints — see docs/accounting/BANK_CASH_ARCHITECTURE.md.

enum TreasuryAccountType {
  BANK
  CASH
  CLEARING
}

enum TreasuryAccountStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum TreasuryBankAccountKind {
  CURRENT
  SAVINGS
  OVERDRAFT
  CASH_CREDIT
  ESCROW
  VIRTUAL
  NOSTRO
  OTHER
}

enum PaymentDirection {
  RECEIPT
  PAYMENT
  BOTH
}

enum PaymentUseCase {
  CUSTOMER_RECEIPT
  CUSTOMER_REFUND
  VENDOR_PAYMENT
  VENDOR_ADVANCE
  VENDOR_REFUND
  BANK_TRANSFER_IN
  BANK_TRANSFER_OUT
  CASH_DEPOSIT
  CASH_WITHDRAWAL
  BANK_CHARGE
  BANK_INTEREST
  CARD_SETTLEMENT
  UPI_SETTLEMENT
  CHEQUE_RECEIPT
  CHEQUE_PAYMENT
  OTHER
}

enum PaymentAccountMappingRole {
  DIRECT_POSTING
  CLEARING
  SETTLEMENT
  CHARGE
}

/// Dedicated treasury payment-method enum — deliberately separate from
/// CustomerReceiptPaymentMethod / VendorPaymentMethod (AR/AP enums are frozen;
/// this enum additionally carries PAYMENT_GATEWAY + DIRECT_DEBIT). Values are
/// mapped 1:1 where names overlap — see docs/accounting/PAYMENT_ACCOUNT_MAPPING.md.
enum TreasuryPaymentMethod {
  BANK_TRANSFER
  CASH
  CHEQUE
  UPI
  CARD
  PAYMENT_GATEWAY
  DIRECT_DEBIT
  OTHER
}

enum BankStatementDateBasis {
  TRANSACTION_DATE
  VALUE_DATE
}

enum BankStatementImportFormat {
  CSV
  XLSX
  MT940
  CAMT_053
  MANUAL
  AUTO_DETECT
  OTHER
}

enum BankStatementDuplicatePolicy {
  BLOCK
  WARN
  ALLOW_WITH_REVIEW
}

enum BankStatementImportStatus {
  UPLOADED
  PROCESSING
  IMPORTED
  PARTIALLY_IMPORTED
  FAILED
  CANCELLED
}

enum BankStatementSourceType {
  FILE_UPLOAD
  MANUAL
  BANK_API
  SYSTEM_GENERATED
  OTHER
}

enum BankStatementStatus {
  DRAFT
  IMPORTED
  VALIDATION_FAILED
  VALIDATED
  READY_TO_RECONCILE
  PARTIALLY_RECONCILED
  RECONCILED
  CANCELLED
}

enum BankStatementLineDirection {
  CREDIT
  DEBIT
}

enum BankStatementLineMatchStatus {
  UNMATCHED
  PARTIALLY_MATCHED
  MATCHED
  EXCEPTION
  EXCLUDED
  RECONCILED
  REVERSED
}

enum BankStatementImportIssueSeverity {
  INFO
  WARNING
  ERROR
  BLOCKER
}

enum BankStatementImportIssueCategory {
  FILE
  SHEET
  HEADER
  COLUMN_MAPPING
  DATE
  AMOUNT
  DIRECTION
  REFERENCE
  CURRENCY
  BALANCE
  DUPLICATE_FILE
  DUPLICATE_STATEMENT
  DUPLICATE_LINE
  SECURITY
  ROW
  STATEMENT
}

/// Bank / cash / clearing account master. One ACTIVE TreasuryAccount per
/// glAccountId per tenant+LE is enforced in the service layer (not a DB
/// constraint — INACTIVE/CLOSED rows may still reference the same GL account).
model TreasuryAccount {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  code        String                @db.VarChar(32)
  name        String                @db.VarChar(200)
  accountType TreasuryAccountType
  status      TreasuryAccountStatus @default(ACTIVE)

  glAccountId  String
  currencyCode String @default("INR") @db.VarChar(8)

  description String? @db.VarChar(500)

  activatedAt        DateTime?
  activatedBy        String?
  deactivatedAt      DateTime?
  deactivatedBy      String?
  deactivationReason String?   @db.VarChar(500)
  closedAt           DateTime?
  closedBy           String?
  closeReason        String?   @db.VarChar(500)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])
  branch      Branch?     @relation(fields: [branchId], references: [id])
  glAccount   Account     @relation("TreasuryAccountGlAccount", fields: [glAccountId], references: [id])

  bankProfile                         TreasuryBankProfile?
  cashProfile                         TreasuryCashProfile?
  reconciliationProfile               BankReconciliationProfile?
  paymentAccountMappingsDirect        PaymentAccountMapping[]              @relation("PaymentMappingTreasuryAccount")
  paymentAccountMappingsClearing      PaymentAccountMapping[]              @relation("PaymentMappingClearingAccount")
  bankStatementImportBatches          BankStatementImportBatch[]
  bankStatements                      BankStatement[]
  bankStatementColumnMappingTemplates BankStatementColumnMappingTemplate[]
  bankReconciliationSessions          BankReconciliationSession[]
  bankReconciliationMatches           BankReconciliationMatch[]
  treasuryTransfersAsSource           TreasuryTransfer[]                   @relation("TreasuryTransferSourceAccount")
  treasuryTransfersAsDestination      TreasuryTransfer[]                   @relation("TreasuryTransferDestinationAccount")
  treasuryCheques                     TreasuryCheque[]
  treasuryAdjustments                 TreasuryAdjustment[]
  bankPostingRules                    BankPostingRule[]
  standingInstructions                StandingInstruction[]
  bankConnectors                      BankConnector[]
  fixedAssetDisposals                 FixedAssetDisposal[]

  @@unique([tenantId, legalEntityId, code], map: "treas_acct_tenant_le_code_key")
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([tenantId, legalEntityId, accountType], map: "treas_acct_le_type_idx")
  @@index([tenantId, legalEntityId, status], map: "treas_acct_le_status_idx")
  @@index([glAccountId])
  @@index([branchId])
  @@map("treasury_accounts")
}

/// BANK-type profile. Account numbers are never stored in plaintext — only
/// last4 + display mask are readable via the API; hash/encrypted are
/// write-only fields managed by treasury-account-security.service.ts.
model TreasuryBankProfile {
  id                String @id @default(uuid())
  tenantId          String
  legalEntityId     String
  treasuryAccountId String @unique

  bankName        String                  @db.VarChar(200)
  branchName      String?                 @db.VarChar(200)
  ifscCode        String?                 @db.VarChar(11)
  swiftCode       String?                 @db.VarChar(11)
  micrCode        String?                 @db.VarChar(20)
  bankAccountKind TreasuryBankAccountKind @default(CURRENT)

  /// Last 4 digits only — always safe to return via API.
  accountNumberLast4     String? @db.VarChar(4)
  /// Display mask, e.g. "XXXXXX1234" — always safe to return via API.
  accountNumberMasked    String? @db.VarChar(40)
  /// HMAC-SHA256 of the normalised account number — used only for duplicate
  /// detection; never returned by any API response.
  accountNumberHash      String? @db.VarChar(128)
  /// AES-256-GCM ciphertext (iv+tag encoded); null when no encryption key is
  /// configured. Never returned by any API response.
  accountNumberEncrypted String? @db.Text
  accountHolderName      String? @db.VarChar(200)

  overdraftLimit Decimal? @db.Decimal(18, 4)
  upiVpa         String?  @db.VarChar(100)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity     @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount @relation(fields: [treasuryAccountId], references: [id], onDelete: Cascade)

  @@unique([tenantId, legalEntityId, accountNumberHash], map: "treas_bank_prof_hash_key")
  @@index([tenantId])
  @@index([legalEntityId])
  @@map("treasury_bank_profiles")
}

/// CASH-type profile (petty cash / cash-in-hand custodian details).
model TreasuryCashProfile {
  id                String @id @default(uuid())
  tenantId          String
  legalEntityId     String
  treasuryAccountId String @unique

  custodianName       String?  @db.VarChar(200)
  /// User.id — soft reference (no FK), consistent with other party soft refs in this schema.
  custodianUserId     String?
  locationDescription String?  @db.VarChar(300)
  imprestLimit        Decimal? @db.Decimal(18, 4)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity     @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount @relation(fields: [treasuryAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([legalEntityId])
  @@map("treasury_cash_profiles")
}

/// Routes a payment method + use case (+ optional branch/currency) to the
/// treasury account that should be debited/credited, with an optional
/// clearing/settlement account for two-step postings. Resolution priority and
/// ambiguity/default-conflict rules live in payable-account-mapping-resolve
/// service — see docs/accounting/PAYMENT_ACCOUNT_MAPPING.md.
model PaymentAccountMapping {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  paymentMethod TreasuryPaymentMethod
  direction     PaymentDirection          @default(BOTH)
  useCase       PaymentUseCase            @default(OTHER)
  role          PaymentAccountMappingRole @default(DIRECT_POSTING)

  /// Null = matches any currency (lowest specificity).
  currencyCode String? @db.VarChar(8)

  treasuryAccountId String
  /// Required when role is CLEARING/SETTLEMENT; null for DIRECT_POSTING/CHARGE.
  clearingAccountId String?

  priority  Int     @default(100)
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  description String? @db.VarChar(500)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity      @relation(fields: [legalEntityId], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  treasuryAccount TreasuryAccount  @relation("PaymentMappingTreasuryAccount", fields: [treasuryAccountId], references: [id])
  clearingAccount TreasuryAccount? @relation("PaymentMappingClearingAccount", fields: [clearingAccountId], references: [id])

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([tenantId, legalEntityId, paymentMethod, useCase], map: "pay_acct_map_le_method_use_idx")
  @@index([tenantId, legalEntityId, isActive], map: "pay_acct_map_le_active_idx")
  @@index([treasuryAccountId])
  @@index([clearingAccountId])
  @@index([branchId])
  @@map("payment_account_mappings")
}

/// Reconciliation settings for a BANK TreasuryAccount only (rejected for
/// CASH/CLEARING in the service layer). lastReconciled* fields are read-only
/// via this module's PUT — they are only ever written by the (future) Bank
/// Reconciliation execution phase.
model BankReconciliationProfile {
  id                String @id @default(uuid())
  tenantId          String
  legalEntityId     String
  treasuryAccountId String @unique

  dateBasis                BankStatementDateBasis       @default(TRANSACTION_DATE)
  autoMatchEnabled         Boolean                      @default(false)
  autoMatchToleranceAmount Decimal                      @default(0) @db.Decimal(18, 4)
  autoMatchToleranceDays   Int                          @default(0)
  requireApprovalForMatch  Boolean                      @default(true)
  duplicatePolicy          BankStatementDuplicatePolicy @default(BLOCK)

  /// Phase 5A3 matching controls
  dateToleranceDays               Int     @default(3)
  referenceNormalizationEnabled   Boolean @default(true)
  amountTolerance                 Decimal @default(0) @db.Decimal(18, 4)
  minimumSuggestionScore          Int     @default(65)
  autoReconcileScore              Int     @default(95)
  autoReconcileEnabled            Boolean @default(false)
  groupedSuggestionsEnabled       Boolean @default(true)
  partialSuggestionsEnabled       Boolean @default(false)
  maximumGroupSize                Int     @default(5)
  requireUniqueExactMatch         Boolean @default(true)
  allowManualPartialMatch         Boolean @default(true)
  allowManualGroupedMatch         Boolean @default(true)
  requireFullMatchToFinalize      Boolean @default(true)
  allowFinalizeWithExceptions     Boolean @default(false)
  finalizationDifferenceTolerance Decimal @default(0) @db.Decimal(18, 4)

  /// Written only by the reconciliation execution phase — blocked on this module's PUT.
  lastReconciledDate    DateTime? @db.Date
  lastReconciledBalance Decimal?  @db.Decimal(18, 4)
  lastReconciledAt      DateTime?
  lastReconciledBy      String?

  notes String? @db.VarChar(1000)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity     @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount @relation(fields: [treasuryAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([legalEntityId])
  @@map("bank_reconciliation_profiles")
}

/// Header for one file/manual bank-statement import attempt.
model BankStatementImportBatch {
  id                String @id @default(uuid())
  tenantId          String
  legalEntityId     String
  treasuryAccountId String

  batchReference  String                       @db.VarChar(64)
  sourceType      BankStatementSourceType      @default(FILE_UPLOAD)
  importFormat    BankStatementImportFormat    @default(OTHER)
  duplicatePolicy BankStatementDuplicatePolicy @default(BLOCK)
  status          BankStatementImportStatus    @default(UPLOADED)

  /// Client-visible original filename (sanitised for display).
  fileName          String? @db.VarChar(300)
  originalFileName  String? @db.VarChar(300)
  sanitisedFileName String? @db.VarChar(300)
  fileSizeBytes     Int?
  fileChecksum      String? @db.VarChar(128)
  /// Relative storage key under upload root — never returned by APIs.
  storageKey        String? @db.VarChar(500)
  mimeType          String? @db.VarChar(120)

  mappingTemplateId String?

  /// Last inspect/preview configuration snapshot (sheet, delimiter, mappings…).
  inspectConfig Json?
  mappingConfig Json?
  parsingConfig Json?

  totalLineCount     Int @default(0)
  importedLineCount  Int @default(0)
  failedLineCount    Int @default(0)
  duplicateLineCount Int @default(0)
  warningCount       Int @default(0)
  errorCount         Int @default(0)

  errorSummary Json?

  uploadedBy  String?
  uploadedAt  DateTime  @default(now())
  processedAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant                              @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity                         @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount                     @relation(fields: [treasuryAccountId], references: [id])
  mappingTemplate BankStatementColumnMappingTemplate? @relation(fields: [mappingTemplateId], references: [id])

  statements BankStatement[]
  issues     BankStatementImportIssue[]

  @@unique([tenantId, legalEntityId, batchReference], map: "bank_stmt_batch_ref_key")
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([treasuryAccountId])
  @@index([tenantId, legalEntityId, treasuryAccountId, fileChecksum], map: "bank_stmt_batch_checksum_idx")
  @@index([mappingTemplateId])
  @@map("bank_statement_import_batches")
}

/// One bank statement document (period + opening/closing balance + lines).
model BankStatement {
  id                String  @id @default(uuid())
  tenantId          String
  legalEntityId     String
  treasuryAccountId String
  importBatchId     String?

  statementReference  String                 @db.VarChar(64)
  externalStatementId String?                @db.VarChar(128)
  statementDate       DateTime               @db.Date
  periodStartDate     DateTime               @db.Date
  periodEndDate       DateTime               @db.Date
  dateBasis           BankStatementDateBasis @default(TRANSACTION_DATE)

  currencyCode String @default("INR") @db.VarChar(8)

  openingBalance    Decimal @default(0) @db.Decimal(18, 4)
  closingBalance    Decimal @default(0) @db.Decimal(18, 4)
  totalCreditAmount Decimal @default(0) @db.Decimal(18, 4)
  totalDebitAmount  Decimal @default(0) @db.Decimal(18, 4)
  balanceDifference Decimal @default(0) @db.Decimal(18, 4)
  lineCount         Int     @default(0)

  status       BankStatementStatus        @default(DRAFT)
  sourceType   BankStatementSourceType    @default(FILE_UPLOAD)
  importFormat BankStatementImportFormat?

  /// Dedupe key across re-imports: tenant|LE|treasuryAccount|reference|periodStart|periodEnd.
  statementUniquenessKey String? @unique @db.VarChar(300)

  validationErrors Json?
  validatedAt      DateTime?
  validatedBy      String?
  reopenReason     String?   @db.VarChar(500)
  reopenedAt       DateTime?
  reopenedBy       String?

  reconciledAt DateTime?
  reconciledBy String?

  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?   @db.VarChar(500)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant                    @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity               @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount           @relation(fields: [treasuryAccountId], references: [id])
  importBatch     BankStatementImportBatch? @relation(fields: [importBatchId], references: [id])

  lines                 BankStatementLine[]
  issues                BankStatementImportIssue[]
  reconciliationSession BankReconciliationSession?

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([treasuryAccountId])
  @@index([importBatchId])
  @@index([tenantId, legalEntityId, status], map: "bank_stmt_le_status_idx")
  @@map("bank_statements")
}

/// Individual bank-statement transaction line. Phase 5A2 writers always leave
/// matchStatus = UNMATCHED (matching is Phase 5A3).
model BankStatementLine {
  id              String @id @default(uuid())
  tenantId        String
  legalEntityId   String
  bankStatementId String

  lineNumber      Int
  /// Original source file row number (1-based); null for manual lines.
  sourceRowNumber Int?

  transactionDate DateTime  @db.Date
  valueDate       DateTime? @db.Date

  direction BankStatementLineDirection
  amount    Decimal                    @db.Decimal(18, 4)

  description               String? @db.VarChar(500)
  normalizedDescription     String? @db.VarChar(500)
  referenceNumber           String? @db.VarChar(128)
  utrReference              String? @db.VarChar(128)
  chequeNumber              String? @db.VarChar(64)
  transactionCode           String? @db.VarChar(64)
  counterpartyName          String? @db.VarChar(200)
  /// Masked only — never store full counterparty account numbers.
  counterpartyAccountMasked String? @db.VarChar(40)
  counterpartyBankCode      String? @db.VarChar(32)
  bankTransactionId         String? @db.VarChar(128)
  externalLineId            String? @db.VarChar(128)
  externalTransactionId     String? @db.VarChar(128)

  runningBalance Decimal? @db.Decimal(18, 4)

  matchStatus BankStatementLineMatchStatus @default(UNMATCHED)

  /// Sum of ACTIVE statement-allocation amounts (read model; updated with matches).
  matchedAmount Decimal @default(0) @db.Decimal(18, 4)

  /// Soft link to a statement-created journal draft (Phase 5A3).
  linkedJournalId String?

  /// Content hash for exact duplicate detection across statements on the same treasury account.
  lineHash String @db.VarChar(128)

  /// Soft-exclude before validation (imported evidence retained via import issues).
  isExcluded Boolean @default(false)

  rawPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  legalEntity   LegalEntity   @relation(fields: [legalEntityId], references: [id])
  bankStatement BankStatement @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)

  issues                   BankStatementImportIssue[]
  statementAllocations     BankReconciliationStatementAllocation[]
  reconciliationExceptions BankReconciliationException[]
  /// Phase 5B3 — set once a TreasuryAdjustment is created from this line (statement-led path). One-to-one via the FK on TreasuryAdjustment.
  treasuryAdjustment       TreasuryAdjustment?

  @@unique([bankStatementId, lineNumber], map: "bank_stmt_line_num_key")
  @@unique([bankStatementId, lineHash], map: "bank_stmt_line_hash_key")
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([bankStatementId])
  @@index([bankStatementId, matchStatus], map: "bank_stmt_line_match_idx")
  @@index([tenantId, legalEntityId, lineHash], map: "bank_stmt_line_content_hash_idx")
  @@map("bank_statement_lines")
}

/// Reusable column-mapping configuration for CSV/XLSX bank statement imports.
model BankStatementColumnMappingTemplate {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  treasuryAccountId String?
  /// Normalised bank name key for bank-scoped templates (uppercase trimmed).
  bankNameKey       String? @db.VarChar(200)

  name         String                    @db.VarChar(120)
  importFormat BankStatementImportFormat

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  sheetNamePattern   String? @db.VarChar(120)
  headerRowNumber    Int?
  dataStartRowNumber Int?

  delimiter String? @db.VarChar(8)
  encoding  String? @db.VarChar(32)

  mappingConfig Json
  parsingConfig Json?

  createdById String?
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity      @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount? @relation(fields: [treasuryAccountId], references: [id])

  importBatches BankStatementImportBatch[]

  @@unique([tenantId, legalEntityId, name], map: "bank_stmt_map_tmpl_name_key")
  @@index([tenantId, legalEntityId, treasuryAccountId, isActive], map: "bank_stmt_map_tmpl_acct_idx")
  @@index([tenantId, legalEntityId, bankNameKey, isActive], map: "bank_stmt_map_tmpl_bank_idx")
  @@map("bank_statement_column_mapping_templates")
}

/// Immutable row/file/statement validation issue recorded during import or validation.
model BankStatementImportIssue {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  importBatchId       String?
  bankStatementId     String?
  bankStatementLineId String?

  rowNumber  Int?
  columnName String? @db.VarChar(120)

  severity BankStatementImportIssueSeverity
  category BankStatementImportIssueCategory
  code     String                           @db.VarChar(120)
  message  String                           @db.VarChar(1000)

  rawValue        String? @db.Text
  normalizedValue String? @db.VarChar(500)
  metadata        Json?

  createdAt DateTime @default(now())

  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
  legalEntity       LegalEntity               @relation(fields: [legalEntityId], references: [id])
  importBatch       BankStatementImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  bankStatement     BankStatement?            @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)
  bankStatementLine BankStatementLine?        @relation(fields: [bankStatementLineId], references: [id], onDelete: SetNull)

  @@index([tenantId, legalEntityId, importBatchId, severity], map: "bank_stmt_issue_batch_sev_idx")
  @@index([tenantId, legalEntityId, bankStatementId], map: "bank_stmt_issue_stmt_idx")
  @@map("bank_statement_import_issues")
}

// ─── Finance Phase 5A3 — Bank reconciliation matching ────────────────────────

enum BankReconciliationSessionStatus {
  OPEN
  IN_PROGRESS
  READY_TO_FINALIZE
  FINALIZED
  REOPENED
  CANCELLED
}

enum BankReconciliationMatchMethod {
  AUTO_EXACT
  AUTO_ACCEPTED
  MANUAL
  GROUPED_MANUAL
  PARTIAL_MANUAL
}

enum BankReconciliationMatchSource {
  DIRECT_BANK_GL
  CLEARING_GL
  JOURNAL_CREATED_FROM_STATEMENT
}

enum BankReconciliationMatchStatus {
  ACTIVE
  REVERSED
}

enum BankReconciliationPostingMode {
  NONE
  CLEARING_SETTLEMENT
}

enum BankReconciliationSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  INVALIDATED
}

enum BankReconciliationSuggestionType {
  ONE_TO_ONE
  ONE_TO_MANY
  MANY_TO_ONE
  MANY_TO_MANY
}

enum BankReconciliationMatchRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum BankLedgerReconciliationPositionStatus {
  UNRECONCILED
  PARTIALLY_RECONCILED
  FULLY_RECONCILED
}

enum BankReconciliationExceptionReason {
  UNKNOWN_TRANSACTION
  REFERENCE_MISSING
  AMOUNT_MISMATCH
  DATE_MISMATCH
  POSSIBLE_DUPLICATE
  BANK_CHARGE_REQUIRES_JOURNAL
  INTEREST_REQUIRES_JOURNAL
  CURRENCY_MISMATCH
  SOURCE_DOCUMENT_NOT_POSTED
  OTHER
}

enum BankReconciliationExceptionStatus {
  OPEN
  RESOLVED
}

model BankReconciliationSession {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  treasuryAccountId String
  bankStatementId   String @unique

  status BankReconciliationSessionStatus @default(OPEN)

  statementStartDate DateTime @db.Date
  statementEndDate   DateTime @db.Date

  statementOpeningBalance Decimal? @db.Decimal(18, 4)
  statementClosingBalance Decimal? @db.Decimal(18, 4)
  totalStatementDebit     Decimal  @default(0) @db.Decimal(18, 4)
  totalStatementCredit    Decimal  @default(0) @db.Decimal(18, 4)

  matchedStatementAmount   Decimal @default(0) @db.Decimal(18, 4)
  unmatchedStatementAmount Decimal @default(0) @db.Decimal(18, 4)
  matchedBookAmount        Decimal @default(0) @db.Decimal(18, 4)
  unmatchedBookAmount      Decimal @default(0) @db.Decimal(18, 4)

  adjustedStatementBalance Decimal? @db.Decimal(18, 4)
  adjustedBookBalance      Decimal? @db.Decimal(18, 4)
  reconciliationDifference Decimal? @db.Decimal(18, 4)

  finalSummaryJson Json?

  finalizedAt   DateTime?
  finalizedById String?
  reopenedAt    DateTime?
  reopenedById  String?
  reopenReason  String?   @db.VarChar(500)

  createdById String
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  legalEntity     LegalEntity     @relation(fields: [legalEntityId], references: [id])
  treasuryAccount TreasuryAccount @relation(fields: [treasuryAccountId], references: [id])
  bankStatement   BankStatement   @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)

  matches     BankReconciliationMatch[]
  suggestions BankReconciliationSuggestion[]
  matchRuns   BankReconciliationMatchRun[]
  exceptions  BankReconciliationException[]

  @@unique([tenantId, bankStatementId], map: "bank_recon_sess_tenant_stmt_key")
  @@index([tenantId])
  @@index([legalEntityId])
  @@index([treasuryAccountId])
  @@index([tenantId, legalEntityId, status], map: "bank_recon_sess_le_status_idx")
  @@map("bank_reconciliation_sessions")
}

model BankReconciliationMatch {
  id            String  @id @default(uuid())
  tenantId      String
  legalEntityId String
  branchId      String?

  reconciliationSessionId String
  treasuryAccountId       String

  matchReference String @db.VarChar(64)

  matchMethod BankReconciliationMatchMethod
  matchSource BankReconciliationMatchSource
  matchStatus BankReconciliationMatchStatus @default(ACTIVE)

  confidenceScore Decimal? @db.Decimal(8, 2)
  confidenceLevel String?  @db.VarChar(16)
  reasonCodes     Json?

  accountCurrencyCode String @db.VarChar(8)

  matchedAmount     Decimal @db.Decimal(18, 4)
  baseMatchedAmount Decimal @db.Decimal(18, 4)

  postingMode BankReconciliationPostingMode @default(NONE)

  accountingVoucherId    String?
  postingEventId         String?
  reversalVoucherId      String?
  reversalPostingEventId String?

  note String? @db.VarChar(1000)

  idempotencyKey String @unique @db.VarChar(128)
  payloadHash    String @db.VarChar(64)

  matchedAt   DateTime
  matchedById String

  reversedAt     DateTime?
  reversedById   String?
  reversalReason String?   @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                    @relation(fields: [tenantId], references: [id])
  legalEntity           LegalEntity               @relation(fields: [legalEntityId], references: [id])
  reconciliationSession BankReconciliationSession @relation(fields: [reconciliationSessionId], references: [id], onDelete: Cascade)
  treasuryAccount       TreasuryAccount           @relation(fields: [treasuryAccountId], references: [id])
  accountingVoucher     AccountingVoucher?        @relation("BankReconMatchVoucher", fields: [accountingVoucherId], references: [id])
  reversalVoucher       AccountingVoucher?        @relation("BankReconMatchReversalVoucher", fields: [reversalVoucherId], references: [id])

  statementAllocations BankReconciliationStatementAllocation[]
  ledgerAllocations    BankReconciliationLedgerAllocation[]

  @@index([tenantId])
  @@index([legalEntityId])
  @@index([reconciliationSessionId])
  @@index([treasuryAccountId])
  @@index([tenantId, matchStatus], map: "bank_recon_match_status_idx")
  @@index([matchReference])
  @@map("bank_reconciliation_matches")
}

model BankReconciliationStatementAllocation {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  reconciliationMatchId String
  bankStatementLineId   String

  matchedAmount     Decimal @db.Decimal(18, 4)
  baseMatchedAmount Decimal @db.Decimal(18, 4)

  createdAt DateTime @default(now())

  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  legalEntity         LegalEntity             @relation(fields: [legalEntityId], references: [id])
  reconciliationMatch BankReconciliationMatch @relation(fields: [reconciliationMatchId], references: [id], onDelete: Cascade)
  bankStatementLine   BankStatementLine       @relation(fields: [bankStatementLineId], references: [id])

  @@unique([reconciliationMatchId, bankStatementLineId], map: "bank_recon_stmt_alloc_match_line_key")
  @@index([tenantId])
  @@index([reconciliationMatchId])
  @@index([bankStatementLineId])
  @@map("bank_reconciliation_statement_allocations")
}

model BankReconciliationLedgerAllocation {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  reconciliationMatchId String

  generalLedgerEntryId String
  accountingVoucherId  String?

  sourceDocumentType   String? @db.VarChar(64)
  sourceDocumentId     String?
  sourceDocumentNumber String? @db.VarChar(64)

  accountId           String
  accountCurrencyCode String @db.VarChar(8)

  matchedAmount     Decimal @db.Decimal(18, 4)
  baseMatchedAmount Decimal @db.Decimal(18, 4)

  createdAt DateTime @default(now())

  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  legalEntity         LegalEntity             @relation(fields: [legalEntityId], references: [id])
  reconciliationMatch BankReconciliationMatch @relation(fields: [reconciliationMatchId], references: [id], onDelete: Cascade)
  generalLedgerEntry  GeneralLedgerEntry      @relation(fields: [generalLedgerEntryId], references: [id])

  @@unique([reconciliationMatchId, generalLedgerEntryId], map: "bank_recon_led_alloc_match_gl_key")
  @@index([tenantId])
  @@index([reconciliationMatchId])
  @@index([generalLedgerEntryId])
  @@map("bank_reconciliation_ledger_allocations")
}

/// Reconciliation read model for GL entry remaining balances (updated with matches).
model BankLedgerReconciliationPosition {
  id                   String @id @default(uuid())
  tenantId             String
  legalEntityId        String
  generalLedgerEntryId String @unique

  originalAmount     Decimal @db.Decimal(18, 4)
  reconciledAmount   Decimal @default(0) @db.Decimal(18, 4)
  unreconciledAmount Decimal @db.Decimal(18, 4)

  status BankLedgerReconciliationPositionStatus @default(UNRECONCILED)

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  legalEntity        LegalEntity        @relation(fields: [legalEntityId], references: [id])
  generalLedgerEntry GeneralLedgerEntry @relation(fields: [generalLedgerEntryId], references: [id], onDelete: Cascade)

  @@index([tenantId, legalEntityId, status], map: "bank_led_recon_pos_le_status_idx")
  @@map("bank_ledger_reconciliation_positions")
}

model BankReconciliationSuggestion {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  reconciliationSessionId String

  suggestionReference String                           @db.VarChar(64)
  suggestionType      BankReconciliationSuggestionType
  confidenceScore     Decimal                          @db.Decimal(8, 2)
  confidenceLevel     String                           @db.VarChar(16)
  reasonCodes         Json?

  statementLineIds Json
  ledgerEntryIds   Json

  suggestedAmount String                        @db.VarChar(32)
  postingMode     BankReconciliationPostingMode

  payloadHash String                             @db.VarChar(64)
  status      BankReconciliationSuggestionStatus @default(PENDING)

  expiresAt    DateTime?
  acceptedAt   DateTime?
  rejectedAt   DateTime?
  resolvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                    @relation(fields: [tenantId], references: [id])
  legalEntity           LegalEntity               @relation(fields: [legalEntityId], references: [id])
  reconciliationSession BankReconciliationSession @relation(fields: [reconciliationSessionId], references: [id], onDelete: Cascade)

  @@unique([reconciliationSessionId, suggestionReference], map: "bank_recon_sugg_sess_ref_key")
  @@index([tenantId])
  @@index([reconciliationSessionId, status], map: "bank_recon_sugg_sess_status_idx")
  @@map("bank_reconciliation_suggestions")
}

model BankReconciliationMatchRun {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  reconciliationSessionId String

  status BankReconciliationMatchRunStatus @default(RUNNING)

  settingsSnapshot Json?

  linesScanned               Int @default(0)
  matchesCreated             Int @default(0)
  suggestionsCreated         Int @default(0)
  ambiguousLines             Int @default(0)
  noCandidateLines           Int @default(0)
  postingRequiredSuggestions Int @default(0)

  durationMs   Int?
  errorCode    String? @db.VarChar(120)
  errorMessage String? @db.VarChar(500)

  startedById String
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  tenant                Tenant                    @relation(fields: [tenantId], references: [id])
  legalEntity           LegalEntity               @relation(fields: [legalEntityId], references: [id])
  reconciliationSession BankReconciliationSession @relation(fields: [reconciliationSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([reconciliationSessionId])
  @@map("bank_reconciliation_match_runs")
}

model BankReconciliationException {
  id            String @id @default(uuid())
  tenantId      String
  legalEntityId String

  reconciliationSessionId String
  bankStatementLineId     String

  reason  BankReconciliationExceptionReason
  comment String?                           @db.VarChar(1000)
  status  BankReconciliationExceptionStatus @default(OPEN)

  assignedToId        String?
  createdById         String
  resolvedAt          DateTime?
  resolvedById        String?
  resolutionReference String?   @db.VarChar(128)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant                    @relation(fields: [tenantId], references: [id])
  legalEntity           LegalEntity               @relation(fields: [legalEntityId], references: [id])
  reconciliationSession BankReconciliationSession @relation(fields: [reconciliationSessionId], references: [id], onDelete: Cascade)
  bankStatementLine     BankStatementLine         @relation(fields: [bankStatementLineId], references: [id])

  @@index([tenantId, status], map: "bank_recon_exc_tenant_status_idx")
  @@index([reconciliationSessionId])
  @@index([bankStatementLineId])
  @@map("bank_reconciliation_exceptions")
}

