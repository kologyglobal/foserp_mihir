  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  deliveryChallan DeliveryChallan @relation(fields: [deliveryChallanId], references: [id], onDelete: Cascade)
  package         DispatchPackage @relation(fields: [packageId], references: [id])

  @@unique([deliveryChallanId, packageId], map: "delivery_challan_pkg_challan_pkg_uidx")
  @@index([tenantId, deliveryChallanId], map: "delivery_challan_pkg_tenant_challan_idx")
  @@index([tenantId, packageId], map: "delivery_challan_pkg_tenant_pkg_idx")
  @@map("delivery_challan_packages")
}

model DeliveryChallanTrackingAllocation {
  id                    String   @id @default(uuid())
  tenantId              String
  deliveryChallanId     String
  deliveryChallanLineId String
  packageId             String?
  lotRef                String?  @db.VarChar(100)
  serialRef             String?  @db.VarChar(100)
  heatNumber            String?  @db.VarChar(100)
  quantity              Decimal  @db.Decimal(18, 4)
  createdAt             DateTime @default(now())

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  deliveryChallan     DeliveryChallan     @relation(fields: [deliveryChallanId], references: [id], onDelete: Cascade)
  deliveryChallanLine DeliveryChallanLine @relation(fields: [deliveryChallanLineId], references: [id], onDelete: Cascade)

  @@index([tenantId, deliveryChallanLineId], map: "delivery_challan_trk_tenant_line_idx")
  @@index([tenantId, deliveryChallanId], map: "delivery_challan_trk_tenant_challan_idx")
  @@index([tenantId, serialRef], map: "delivery_challan_trk_tenant_serial_idx")
  @@index([tenantId, lotRef], map: "delivery_challan_trk_tenant_lot_idx")
  @@map("delivery_challan_tracking_allocations")
}

// ─── Purchase Phase 3B — Purchase Requisition foundation ─────────────────────
// PR header + lines only. No RFQ / PO / GRN / conversion in this phase.
// Production creates PR (not PO) for shortages — ADR-030.

enum PurchaseRequisitionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum PurchaseRequisitionSource {
  MANUAL
  PRODUCTION_SHORTAGE
  MRP
  SALES_ORDER
}

enum PurchaseRequisitionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model PurchaseRequisition {
  id                 String                      @id @default(uuid())
  tenantId           String
  prNumber           String                      @db.VarChar(64)
  source             PurchaseRequisitionSource   @default(MANUAL)
  status             PurchaseRequisitionStatus   @default(DRAFT)
  priority           PurchaseRequisitionPriority @default(MEDIUM)
  purpose            String?                     @db.VarChar(500)
  requestedByUserId  String?
  requiredByDate     DateTime?                   @db.Date
  warehouseId        String?
  /// Primary production order this PR supports (optional; lines may refine).
  productionOrderId  String?
  salesOrderId       String?
  projectRef         String?                     @db.VarChar(100)
  notes              String?                     @db.Text
  submittedAt        DateTime?
  submittedBy        String?
  approvedAt         DateTime?
  approvedBy         String?
  rejectedAt         DateTime?
  rejectedBy         String?
  rejectionReason    String?                     @db.Text
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?                     @db.Text
  idempotencyKey     String?                     @db.VarChar(150)
  createdBy          String?
  updatedBy          String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  deletedAt          DateTime?

  tenant              Tenant                    @relation(fields: [tenantId], references: [id])
  warehouse           MasterWarehouse?          @relation(fields: [warehouseId], references: [id])
  productionOrder     ProductionOrder?          @relation(fields: [productionOrderId], references: [id])
  salesOrder          CrmSalesOrder?            @relation(fields: [salesOrderId], references: [id])
  lines               PurchaseRequisitionLine[]
  productionMaterials ProductionOrderMaterial[]

  @@unique([tenantId, prNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, productionOrderId])
  @@index([tenantId, salesOrderId])
  @@index([tenantId, deletedAt])
  @@map("purchase_requisitions")
}

model PurchaseRequisitionLine {
  id                String    @id @default(uuid())
  tenantId          String
  requisitionId     String
  lineNo            Int
  itemId            String
  warehouseId       String?
  uomId             String?
  quantity          Decimal   @db.Decimal(18, 4)
  requiredDate      DateTime? @db.Date
  productionOrderId String?
  /// Soft refs — validated when present; no mandatory FK to avoid Phase 2A coupling churn.
  stageId           String?
  operationId       String?
  bomLineId         String?
  salesOrderId      String?
  salesOrderLineKey String?   @db.VarChar(150)
  preferredVendorId String?
  remarks           String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  requisition     PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  item            MasterItem          @relation(fields: [itemId], references: [id])
  warehouse       MasterWarehouse?    @relation(fields: [warehouseId], references: [id])
  productionOrder ProductionOrder?    @relation(fields: [productionOrderId], references: [id])

  @@index([tenantId])
  @@index([requisitionId, lineNo])
  @@index([tenantId, productionOrderId])
  @@index([tenantId, itemId])
  @@map("purchase_requisition_lines")
}

// ─── Quality Phase 4A — Inspection foundation (no Job Work / subcontracting) ─

model QualityParameter {
  id              String                   @id @default(uuid())
  tenantId        String
  parameterCode   String                   @db.VarChar(64)
  parameterName   String                   @db.VarChar(200)
  parameterType   QualityParameterType
  uomCode         String?                  @db.VarChar(32)
  minValue        Decimal?                 @db.Decimal(18, 4)
  maxValue        Decimal?                 @db.Decimal(18, 4)
  targetValue     Decimal?                 @db.Decimal(18, 4)
  mandatory       Boolean                  @default(true)
  severity        QualityParameterSeverity @default(MAJOR)
  passFailRule    QualityPassFailRule      @default(MANUAL)
  dropdownOptions Json?
  active          Boolean                  @default(true)
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  tenant    Tenant                      @relation(fields: [tenantId], references: [id])
  planLines QualityInspectionPlanLine[]

  @@unique([tenantId, parameterCode])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, deletedAt])
  @@map("quality_parameters")
}

model QualityInspectionPlan {
  id                  String                      @id @default(uuid())
  tenantId            String
  planCode            String                      @db.VarChar(64)
  planName            String                      @db.VarChar(200)
  category            QualityInspectionCategory
