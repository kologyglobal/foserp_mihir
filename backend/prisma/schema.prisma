model VendorComparisonLine {
  id                        String   @id @default(uuid())
  tenantId                  String
  vendorComparisonId        String
  lineNumber                Int
  requestForQuotationLineId String?
  vendorQuotationId         String?
  vendorQuotationLineId     String?
  itemId                    String?  @db.VarChar(36)
  quantity                  Decimal  @default(0) @db.Decimal(18, 4)
  rate                      Decimal  @default(0) @db.Decimal(18, 2)
  amount                    Decimal  @default(0) @db.Decimal(18, 2)
  rank                      Int?
  isSelected                Boolean  @default(false)
  remarks                   String?  @db.Text
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  vendorComparison        VendorComparison         @relation(fields: [vendorComparisonId], references: [id])
  requestForQuotationLine RequestForQuotationLine? @relation(fields: [requestForQuotationLineId], references: [id])
  vendorQuotation         VendorQuotation?         @relation(fields: [vendorQuotationId], references: [id])
  vendorQuotationLine     VendorQuotationLine?     @relation(fields: [vendorQuotationLineId], references: [id])

  @@unique([tenantId, vendorComparisonId, lineNumber])
