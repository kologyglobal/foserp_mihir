  baseAllocatableAmount    Decimal @default(0) @db.Decimal(18, 4)
  baseAllocatedAmount      Decimal @default(0) @db.Decimal(18, 4)
  baseUnallocatedAmount    Decimal @default(0) @db.Decimal(18, 4)

