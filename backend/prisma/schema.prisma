  @@unique([tenantId, idempotencyKey], map: "dispatch_pick_event_tenant_idem_uidx")
  @@index([tenantId, pickListId], map: "dispatch_pick_event_tenant_list_idx")
  @@index([tenantId, pickLineId], map: "dispatch_pick_event_tenant_line_idx")
