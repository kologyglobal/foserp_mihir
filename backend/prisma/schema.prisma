  countryRef MasterCountry? @relation(fields: [countryId], references: [id])
  stateRef   MasterState?   @relation(fields: [stateId], references: [id])
  cityRef    MasterCity?    @relation(fields: [cityId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([tenantId, countryId])
  @@index([tenantId, stateId])
  @@index([tenantId, cityId])
  @@map("master_vendors")
}

// ─── Finance Phase 1 — Legal entity / setup (no GL posting) ───────────────────

