  purchasePlanningPreferred         PurchasePlanningRow[]     @relation("PlanningPreferredVendor")
  purchasePlanningSelected          PurchasePlanningRow[]     @relation("PlanningSelectedVendor")
  purchasePlanningLastPurchase      PurchasePlanningRow[]     @relation("PlanningLastPurchaseVendor")
  rfqVendors                        RfqVendor[]
