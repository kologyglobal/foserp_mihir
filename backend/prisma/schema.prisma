// ─── Dispatch Phase 7C4 — Delivery Challan (document only; no stock / fulfilment) ──
// Issuance does not post FG_DISPATCH, consume reservations, or update SO fulfilment.

enum DeliveryChallanStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  ISSUED
  SENT_BACK
  CANCELLED
  SUPERSEDED
}

enum DeliveryChallanMovementReason {
  SALES_DELIVERY
  JOB_WORK_DISPATCH
  SAMPLE
  DEMONSTRATION
  REPAIR
  REPLACEMENT
  STOCK_TRANSFER
  RETURNABLE_MATERIAL
  NON_RETURNABLE_MATERIAL
  OTHER
}

enum DeliveryChallanDocumentGenStatus {
  NOT_GENERATED
  GENERATING
  GENERATED
  FAILED
  SUPERSEDED
}

enum DeliveryChallanPackageLinkStatus {
  ACTIVE
  CANCELLED
}

model DeliveryChallan {
  id                      String                           @id @default(uuid())
  tenantId                String
  /// Official number assigned on ISSUE (NUMBER_ON_ISSUE). Null while Draft/Review.
  challanNumber           String?                          @db.VarChar(64)
  status                  DeliveryChallanStatus            @default(DRAFT)
  versionNumber           Int                              @default(1)
  supersedesChallanId     String?
  supersededByChallanId   String?
  outboundDispatchId      String
  packingSessionId        String
  customerId              String?
  shipToKey               String?                          @db.VarChar(200)
  sourceWarehouseId       String
  documentDate            DateTime                         @db.Date
  movementDate            DateTime?                        @db.Date
  movementReason          DeliveryChallanMovementReason    @default(SALES_DELIVERY)
  transportMode           String?                          @db.VarChar(64)
  transporterName         String?                          @db.VarChar(200)
  transporterDocumentRef  String?                          @db.VarChar(100)
  vehicleNumber           String?                          @db.VarChar(64)
  driverName              String?                          @db.VarChar(120)
  driverPhone             String?                          @db.VarChar(32)
  lrGrNumber              String?                          @db.VarChar(100)
  lrGrDate                DateTime?                        @db.Date
  /// Manual reference only — never claim external e-Way verification.
  eWayBillReference       String?                          @db.VarChar(100)
  eWayBillDate            DateTime?                        @db.Date
  destination             String?                          @db.VarChar(300)
  totalPackages           Int                              @default(0)
  totalQuantity           Decimal                          @default(0) @db.Decimal(18, 4)
  grossWeight             Decimal?                         @db.Decimal(18, 4)
  netWeight               Decimal?                         @db.Decimal(18, 4)
  weightUomId             String?
  remarks                 String?                          @db.Text
  termsText               String?                          @db.Text
  sourceVersion           Int                              @default(1)
  sourceFingerprint       String?                          @db.VarChar(128)
  /// Immutable snapshots (JSON) locked at issue.
  customerSnapshotJson    Json?
  shipToSnapshotJson      Json?
  legalEntitySnapshotJson Json?
  salesOrderRefsJson      Json?
  documentHtml            String?                          @db.LongText
  documentGenStatus       DeliveryChallanDocumentGenStatus @default(NOT_GENERATED)
  documentFileKey         String?                          @db.VarChar(500)
  documentGenError        String?                          @db.Text
  issuedAt                DateTime?
  issuedBy                String?
  approvedAt              DateTime?
  approvedBy              String?
  cancelledAt             DateTime?
  cancelledBy             String?
  cancellationReason      String?                          @db.Text
  sentBackAt              DateTime?
  sentBackBy              String?
  sendBackReason          String?                          @db.Text
  idempotencyKey          String?                          @db.VarChar(150)
  createdBy               String?
  updatedBy               String?
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  deletedAt               DateTime?

  tenant           Tenant                              @relation(fields: [tenantId], references: [id])
  outboundDispatch OutboundDispatch                    @relation(fields: [outboundDispatchId], references: [id])
  packingSession   DispatchPackingSession              @relation(fields: [packingSessionId], references: [id])
  sourceWarehouse  MasterWarehouse                     @relation(fields: [sourceWarehouseId], references: [id])
  weightUom        MasterUom?                          @relation("DeliveryChallanWeightUom", fields: [weightUomId], references: [id])
  supersedes       DeliveryChallan?                    @relation("DeliveryChallanSupersession", fields: [supersedesChallanId], references: [id], onDelete: SetNull)
  supersededByList DeliveryChallan[]                   @relation("DeliveryChallanSupersession")
  lines            DeliveryChallanLine[]
  packages         DeliveryChallanPackage[]
  tracking         DeliveryChallanTrackingAllocation[]

  @@unique([tenantId, challanNumber], map: "delivery_challan_tenant_number_uidx")
  @@unique([tenantId, idempotencyKey], map: "delivery_challan_tenant_idem_uidx")
  @@index([tenantId, status], map: "delivery_challan_tenant_status_idx")
  @@index([tenantId, outboundDispatchId], map: "delivery_challan_tenant_ob_idx")
  @@index([tenantId, packingSessionId], map: "delivery_challan_tenant_pack_sess_idx")
  @@index([tenantId, customerId], map: "delivery_challan_tenant_customer_idx")
  @@index([tenantId, documentDate], map: "delivery_challan_tenant_doc_date_idx")
  @@index([tenantId, issuedAt], map: "delivery_challan_tenant_issued_idx")
  @@index([tenantId, deletedAt], map: "delivery_challan_tenant_del_idx")
  @@map("delivery_challans")
}

model DeliveryChallanLine {
  id                      String   @id @default(uuid())
  tenantId                String
  deliveryChallanId       String
  lineNumber              Int
  outboundDispatchLineId  String
  dispatchRequirementId   String?
