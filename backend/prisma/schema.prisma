  countryId           String?
  stateId             String?
  cityId              String?
  email               String?            @db.VarChar(255)
  gstin               String             @default("") @db.VarChar(20)
  gstVendorType       String?            @default("registered") @db.VarChar(32)
  pan                 String?            @db.VarChar(10)
  panStatus           String?            @default("pan_applied") @db.VarChar(32)
  paymentMethod       String?            @db.VarChar(64)
  bankDetails         String?            @db.Text
  vendorType          String             @default("manufacturer") @db.VarChar(32)
  contactPerson       String             @default("") @db.VarChar(200)
  contactPhone        String             @default("") @db.VarChar(30)
  paymentTermsDays    Int                @default(30)
  defaultLeadTimeDays Int                @default(7)
  suppliedCategories  Json               @default("[]")
  rating              Decimal            @default(4) @db.Decimal(3, 1)
  status              MasterRecordStatus @default(ACTIVE)
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  tenant                            Tenant                    @relation(fields: [tenantId], references: [id])
  countryRef                        MasterCountry?            @relation(fields: [countryId], references: [id])
  stateRef                          MasterState?              @relation(fields: [stateId], references: [id])
  cityRef                           MasterCity?               @relation(fields: [cityId], references: [id])
