model DispatchPickEvent {
  id                String                @id @default(uuid())
  tenantId          String
  pickListId        String
  pickLineId        String
  eventType         DispatchPickEventType
  quantity          Decimal               @db.Decimal(18, 4)
  lotRef            String?               @db.VarChar(100)
  serialRef         String?               @db.VarChar(100)
  heatNumber        String?               @db.VarChar(100)
  reasonCode        String?               @db.VarChar(64)
  remarks           String?               @db.Text
  sourceVersion     Int                   @default(1)
  idempotencyKey    String?               @db.VarChar(150)
  performedBy       String
  performedAt       DateTime              @default(now())
  reversalOfEventId String?

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
