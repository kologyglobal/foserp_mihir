  tdsSectionDescription String? @db.VarChar(200)
  tdsRate               Decimal @default(0) @db.Decimal(9, 4)
  tdsBaseAmount         Decimal @default(0) @db.Decimal(18, 4)
  tdsAmount             Decimal @default(0) @db.Decimal(18, 4)
