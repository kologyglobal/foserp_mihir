  @@index([tenantId, legalEntityId, postingDate])
  @@index([tenantId, legalEntityId, accountId, postingDate])
  @@index([accountId, postingDate])
  @@index([partyType, partyId, postingDate])
  @@index([voucherId])
  @@index([accountingPeriodId])
  @@index([sourceModule, sourceDocumentType, sourceDocumentId], map: "gl_src_doc_idx")
  @@index([costCentreId, postingDate])
  @@index([reversalOfEntryId])
  @@map("general_ledger_entries")
}

model PostingEvent {
