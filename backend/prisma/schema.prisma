model FinanceSettings {
  id                               String         @id @default(uuid())
  tenantId                         String
  legalEntityId                    String         @unique
  baseCurrency                     String         @default("INR") @db.VarChar(8)
  dateFormat                       String         @default("DD/MM/YYYY") @db.VarChar(32)
  amountPrecision                  Int            @default(2)
  quantityPrecision                Int            @default(3)
  roundingMethod                   RoundingMethod @default(ROUND_HALF_UP)
  roundingTolerance                Decimal        @default(1) @db.Decimal(18, 4)
  allowBackdatedPosting            Boolean        @default(false)
  backdatedDaysLimit               Int            @default(0)
  requireAttachmentAbove           Decimal?       @db.Decimal(18, 4)
  receiptApprovalLimit             Decimal?       @db.Decimal(18, 4)
  paymentApprovalLimit             Decimal?       @db.Decimal(18, 4)
  journalApprovalLimit             Decimal?       @db.Decimal(18, 4)
  writeOffTolerance                Decimal?       @db.Decimal(18, 4)
  bankChargeTolerance              Decimal?       @db.Decimal(18, 4)
  allowManualControlAccountPosting Boolean        @default(false)
  financeActivated                 Boolean        @default(false)
  activatedAt                      DateTime?
  activatedBy                      String?
  /// Phase 4D2 — AP-to-GL reconciliation tolerance override. Null → fall back to roundingTolerance or 0.01.
  apReconciliationTolerance        Decimal?       @db.Decimal(18, 4)
  /// Phase 4D2 — minutes after which a FAILED/PROCESSING PostingEvent is flagged as stuck by AP reconciliation integrity checks.
  apPostingEventStuckMinutes       Int            @default(30)

  /// Phase 5B1 — bank source balance policy for treasury transfers: ALLOW | WARN | BLOCK
  treasuryTransferBankBalancePolicy        String   @default("WARN") @db.VarChar(16)
  /// Force IN_TRANSIT for all transfers when true.
  treasuryTransferRequireInTransit         Boolean  @default(false)
  /// Amount (base) above which IN_TRANSIT is forced. Null = no threshold force.
  treasuryTransferInTransitThreshold       Decimal? @db.Decimal(18, 4)
  /// Optional approval limit for treasury transfers (base currency). Null = use journalApprovalLimit rules / no limit.
  treasuryTransferApprovalLimit            Decimal? @db.Decimal(18, 4)
  /// Maker-checker: creator cannot approve own transfer.
  treasuryTransferPreventSelfApprove       Boolean  @default(true)
  /// Maker-checker: dispatcher cannot confirm destination receipt.
  treasuryTransferPreventDispatcherReceive Boolean  @default(true)

  /// Phase 5B2 — optional approval limit for treasury cheques (base currency). Null = no limit.
  treasuryChequeApprovalLimit             Decimal? @db.Decimal(18, 4)
  /// Maker-checker: creator cannot approve own cheque.
  treasuryChequePreventSelfApprove        Boolean  @default(true)
  /// Require a resolvable counterpart GL account (provided or default mapping) before POST_ON_LIFECYCLE issue/deposit.
  treasuryChequeRequireCounterpartAccount Boolean  @default(true)

  /// Phase 5B3 — when true, the statement workspace "Create Bank Transaction" action creates a TreasuryAdjustment
  /// (new path). When false, the legacy `create-journal-draft` bank-reconciliation route stays the compatibility path.
  useTreasuryAdjustmentsForStatementItems Boolean  @default(true)
  /// Optional approval limit for treasury adjustments (base currency). Null = no amount-based limit (type-based rules still apply).
  treasuryAdjustmentApprovalLimit         Decimal? @db.Decimal(18, 4)
  /// Maker-checker: creator cannot approve own treasury adjustment.
  treasuryAdjustmentPreventSelfApprove    Boolean  @default(true)

  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  legalEntity LegalEntity @relation(fields: [legalEntityId], references: [id])

  @@index([tenantId])
  @@map("finance_settings")
}

