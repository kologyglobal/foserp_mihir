{
  "name": "fos-erp-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm install && prisma generate && tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:purchase-phase15": "vitest run tests/purchase-phase15-unit.test.ts tests/purchase-planning-workflow.test.ts tests/purchase-requisition-workflow.test.ts tests/purchase-error-catalog.test.ts tests/purchase-rbac-permissions.test.ts tests/purchase-rfq-workflow.test.ts tests/purchase-audit-timeline.test.ts",
    "test:purchase-phase15-live": "vitest run tests/purchase-phase15-integration.test.ts tests/purchase-requisition-lifecycle.test.ts tests/purchase-planning-sheet.test.ts tests/purchase-module-coverage.test.ts --hookTimeout=120000",
    "test:purchase-coverage-live": "vitest run tests/purchase-module-coverage.test.ts --hookTimeout=120000",
    "test:crm-live": "tsx scripts/run-crm-live-tests.ts",
    "test:backend-structure": "tsx scripts/test-backend-structure.ts",
    "db:purge-business": "tsx scripts/purge-business-data.ts",
    "test:watch": "vitest",
    "db:generate": "tsx scripts/prisma-cli.ts generate",
    "db:migrate": "tsx scripts/prisma-cli.ts migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:purchase-demo": "tsx scripts/seed-purchase-demo-data.ts",
    "db:sync-permissions": "tsx scripts/sync-permissions.ts",
    "db:setup": "npm run db:generate && tsx scripts/prisma-cli.ts migrate deploy && npm run db:seed",
    "db:studio": "tsx scripts/prisma-cli.ts studio"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.19.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.8.3",
    "uuid": "^11.1.0",
    "zod": "^3.25.67",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "vitest": "^3.2.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
