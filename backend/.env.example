DB_HOST=localhost
DB_PORT=3306
DB_NAME=fos_erp
DB_USER=root
DB_PASS=

# Hostinger sets PORT automatically — do not hardcode in production.
PORT=5000
NODE_ENV=development

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Local: Vite. Stage API: set to the React stage origin (CORS).
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://stage.dhurandharcrm.com

# Optional — auto-built from DB_* by src/config/env.ts and scripts/prisma-cli.ts if omitted.
# Set explicitly when running one-off Prisma scripts without importing env.ts:
# DATABASE_URL=mysql://root:@localhost:3306/fos_erp
