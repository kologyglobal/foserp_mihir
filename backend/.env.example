DB_HOST=localhost
DB_PORT=3306
DB_NAME=fos_erp
DB_USER=root
DB_PASS=

# Hostinger sets PORT automatically — do not hardcode in production.
PORT=5000
NODE_ENV=development

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Local: Vite. Stage API: set to the React stage origin (CORS).
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://stage.dhurandharcrm.com

# Optional — Phase 5A1 treasury bank account number HMAC / encryption
# TREASURY_ACCOUNT_HMAC_SECRET=change-me-hmac-secret-min-16
# FIELD_ENCRYPTION_KEY=

# Optional — Phase 5D2–5D3 bank connectors
# BANK_CONNECTOR_SANDBOX_ENABLED=true
# BANK_CONNECTOR_SANDBOX_ROOTS=D:/bank-inbox,D:/Projects/FOS/trailer-erp 2/backend/tests/fixtures/bank-statements
# BANK_CONNECTOR_ALLOWED_HOSTS=localhost,127.0.0.1,bank-api.example.com
# BANK_CONNECTOR_SFTP_ALLOWED_HOSTS=localhost,127.0.0.1,sftp.bank.example.com
# Secrets are never stored in DB — set e.g. BANK_CONNECTOR_API_KEY_HDFC=... / SFTP_USER=... and reference via *EnvKey fields
# FIELD_ENCRYPTION_KEY= (required to store Open Banking consent tokens; 32-byte base64/hex or any string hashed to AES key)
